# ================================
# LUXEWAY BACKEND ENVIRONMENT VARIABLES
# ================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git (already in .gitignore)

# ====== DATABASE CONFIGURATION ======
# SQL Server (Primary)
DB_HOST=localhost
DB_PORT=1433
DB_NAME=luxeway_db
DB_USERNAME=sa
DB_PASSWORD=YourStrongPassword123!

# ====== JWT SECURITY ======
# CRITICAL: Generate a new random 256-bit secret key for production
# Use: openssl rand -base64 32
JWT_SECRET=CHANGE_THIS_TO_RANDOM_256BIT_KEY_IN_PRODUCTION
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ====== EMAIL CONFIGURATION ======
# Gmail SMTP (use App-Specific Password, not your actual Gmail password)
# Generate at: https://myaccount.google.com/apppasswords
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password-here

# ====== GOOGLE OAUTH2 ======
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ====== VNPAY PAYMENT GATEWAY ======
# Contact VNPay support to get your credentials
VNPAY_TMN_CODE=your-vnpay-tmn-code
VNPAY_SECRET_KEY=your-vnpay-secret-key
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html

# VNPay IP Whitelist (comma-separated)
# Get actual IPs from VNPay documentation
VNPAY_ALLOWED_IPS=203.171.19.146,203.171.19.147

# ====== STRIPE PAYMENT (Optional) ======
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# ====== PAYOS PAYMENT GATEWAY ======
PAYOS_CLIENT_ID=your-payos-client-id
PAYOS_API_KEY=your-payos-api-key
PAYOS_CHECKSUM_KEY=your-payos-checksum-key
PAYOS_ENDPOINT=https://api-merchant.payos.vn/v2/payment-requests
PAYOS_RETURN_URL=http://localhost:5173/payment/payos/return
PAYOS_CANCEL_URL=http://localhost:5173/payment/payos/return

# ====== APPLICATION CONFIGURATION ======
SPRING_PROFILES_ACTIVE=sqlserver
FRONTEND_URL=http://localhost:5173

# Production URLs (uncomment for production)
# FRONTEND_URL=https://luxeway.vn
# VNPAY_URL=https://pay.vnpay.vn/vpcpay.html

# ====== FILE STORAGE ======
FILE_UPLOAD_DIR=uploads/
FILE_MAX_SIZE=10MB

# ====== LOGGING ======
LOG_LEVEL=INFO

# ====== ENTERPRISE SUPPORT CONFIGURATION ======
GEMINI_API_KEY=your-gemini-api-key-here
GOONG_MAPS_KEY=your-goong-maps-key-here
