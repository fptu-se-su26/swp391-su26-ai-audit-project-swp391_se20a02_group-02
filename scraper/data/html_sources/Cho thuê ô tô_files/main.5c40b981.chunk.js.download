t\u1eebng lo\u1ea1i xe.","q2":"T\xf4i c\xf3 th\u1ec3 \u0111\u0103ng k\xfd thu\xea xe cho ng\u01b0\u1eddi kh\xe1c kh\xf4ng?","a2":"B\u1ea1n c\xf3 th\u1ec3 \u0111\u1ee9ng t\xean h\u1ee3p \u0111\u1ed3ng \u0111\u1ec3 thu\xea cho ng\u01b0\u1eddi th\xe2n ho\u1eb7c b\u1ea1n b\xe8. T\xf9y t\u1eebng nh\xe0 xe s\u1ebd y\xeau c\u1ea7u b\u1ea1n b\u1ed5 sung th\xeam 1 s\u1ed1 gi\u1ea5y t\u1edd ph\xf9 h\u1ee3p \u0111\u1ec3 \u0111\u1ee9ng t\xean h\u1ee3p \u0111\u1ed3ng cho thu\xea xe.","q3":"T\xf4i c\u1ea7n l\u01b0u \xfd g\xec khi nh\u1eadn xe?","a3":"Ki\u1ec3m tra k\u0129 gi\u1ea5y t\u1edd c\u1ee7a xe xem c\xf2n h\u1ea1n hay kh\xf4ng. Mang \u0111\u1ea7y \u0111\u1ee7 gi\u1ea5y t\u1edd, \u0111\u1eb7c bi\u1ec7t l\xe0 B\u1eb1ng l\xe1i xe, v\xe0 Ch\u1ee9ng minh nh\xe2n d\xe2n. \\n\u0110\u1ecdc k\u1ef9 bi\xean b\u1ea3n b\xe0n giao xe nh\u01b0 xem c\xf3 v\u1ebft tr\u1ea7y x\u01b0\u1edbc n\xe0o kh\xf4ng, v\u1ea1ch x\u0103ng th\u1ef1c t\u1ebf khi b\xe0n giao","q4":"Khi g\u1eb7p s\u1ef1 c\u1ed1 tr\xean \u0111\u01b0\u1eddng t\xf4i ph\u1ea3i l\xe0m g\xec?","a4":"B\u1ea1n n\xean g\u1ecdi \u0111i\u1ec7n cho Hotline (090 450 9596) c\u1ee7a Chungxe \u0111\u1ed3ng th\u1eddi li\xean l\u1ea1c tr\u1ef1c ti\u1ebfp cho nh\xe0 xe \u0111\u1ec3 th\xf4ng b\xe1o v\xe0 th\u1ed1ng nh\u1ea5t c\xe1ch s\u1eeda ch\u1eefa v\xe0 thanh to\xe1n chi ph\xed d\u1ef1a tr\xean th\u1ecfa thu\u1eadn c\u1ee7a hai b\xean.","q5":"Gi\xe1 thu\xea xe g\u1ed3m nh\u1eefng g\xec, c\xf3 ph\u1ee5 ph\xed g\xec ph\u1ea3i l\u01b0u \xfd kh\xf4ng?","a5":"Gi\xe1 thu\xea xe s\u1ebd \u0111\u01b0\u1ee3c t\xednh k\u1ebft h\u1ee3p theo ng\xe0y v\xe0 theo gi\u1edd. N\u1ebfu b\u1ea1n tr\u1ea3 xe mu\u1ed9n h\u01a1n gi\u1edd trong th\u1ecfa thu\u1eadn, t\xf9y t\u1eebng nh\xe0 xe s\u1ebd c\xf3 m\u1ee9c t\xednh ph\xed ph\xe1t sinh d\u1ef1a tr\xean s\u1ed1 gi\u1edd qu\xe1 h\u1ea1n ho\u1eb7c theo s\u1ed1 kilomet v\u01b0\u1ee3t qu\xe1. Gi\xe1 thu\xea xe d\u1ecbp l\u1ec5 t\u1ebft ho\u1eb7c cu\u1ed1i tu\u1ea7n th\u01b0\u1eddng cao h\u01a1n so v\u1edbi ng\xe0y th\u01b0\u1eddng.","q6":"L\xe0m th\u1ebf n\xe0o \u0111\u1ec3 \u0111\u1eb7t xe tr\xean Chungxe","a6":"B\u1ea1n c\xf3 th\u1ec3 \u0111\u1eb7t xe qua email, \u0111i\u1ec7n tho\u1ea1i ho\u1eb7c \u0111\u0103ng k\xfd ngay tr\xean trang web ho\u1eb7c app Chungxe","q7":"Chungxe cho thu\xea nh\u1eefng lo\u1ea1i xe n\xe0o?","a7":"Ch\xfang t\xf4i c\xf3 nhi\u1ec1u d\xf2ng c\u1ea3 xe m\xe1y v\xe0 \xf4 t\xf4 \u0111\u1ec3 ph\xf9 h\u1ee3p v\u1edbi nhu c\u1ea7u c\u1ee7a kh\xe1ch h\xe0ng c\u1ea3 thu\xea ng\u1eafn v\xe0 d\xe0i ng\xe0y nh\u01b0 Xe \xf4 t\xf4 4-5 ch\u1ed7, 7 ch\u1ed7, 9 ch\u1ed7; Xe m\xe1y tay ga, xe s\u1ed1, xe c\xf4n.","q8":"T\xf4i c\xf3 th\u1ec3 thanh to\xe1n b\u1eb1ng nh\u1eefng h\xecnh th\u1ee9c n\xe0o?","a8":"Thanh to\xe1n chuy\u1ec3n kho\u1ea3n, ph\xed chuy\u1ec3n kho\u1ea3n s\u1ebd do kh\xe1ch h\xe0ng chi tr\u1ea3. Thanh to\xe1n ti\u1ec1n m\u1eb7t. Thanh to\xe1n th\u1ebb t\xedn d\u1ee5ng","q9":"N\u1ebfu h\u1ee7y \u0111\u1eb7t xe t\xf4i c\xf3 ph\u1ea3i ch\u1ecbu ph\xed ph\u1ea1t kh\xf4ng?","a9":"B\u1ea1n ho\xe0n to\xe0n kh\xf4ng ph\u1ea3i ch\u1ecbu ph\xed ph\u1ea1t n\xe0o v\xec hu\u1ef7 c\u1ecdc tr\u01b0\u1edbc th\u1eddi \u0111i\u1ec3m th\u1ef1c hi\u1ec7n h\u1ee3p \u0111\u1ed3ng thu\xea xe ( kh\xf4ng \xe1p d\u1ee5ng thu\xea xe trong ng\xe0y l\u1ec5, t\u1ebft,\u2026).","q10":"Xe c\xf3 m\u1edbi kh\xf4ng? Ch\u1ea5t l\u01b0\u1ee3ng xe c\xf3 t\u1ed1t kh\xf4ng?","a10":"Chungxe cung c\u1ea5p c\xe1c d\xf2ng xe m\u1edbi v\xe0 \u0111\u01b0\u1ee3c \u0111\u0103ng ki\u1ec3m \u0111\u0103ng k\xfd, b\u1ea3o tr\xec b\u1ea3o d\u01b0\u1ee1ng theo \u0111\u1ecbnh k\u1ef3."},"social_widget":{"zalo":{"description":"Chat v\u1edbi ch\xfang t\xf4i qua Zalo","welcome_message":"R\u1ea5t vui \u0111\u01b0\u1ee3c h\u1ed7 tr\u1ee3 b\u1ea1n"},"phone":{"description":"G\u1ecdi ngay","modal":{"or_contact_us_by_hotline":"Ho\u1eb7c li\xean h\u1ec7 v\u1edbi ch\xfang t\xf4i theo hotline","time_in_works":"Gi\u1edd h\xe0nh ch\xednh"}}},"deposit_pay":{"title":"Ch\u1ecdn h\xecnh th\u1ee9c thanh to\xe1n","method":{"group1":"\u0110\u1ea3m b\u1ea3o b\u1eb1ng th\u1ebb t\xedn d\u1ee5ng","papal_note":"(Kho\u1ea3n k\xfd qu\u1ef9 s\u1ebd \u0111\u01b0\u1ee3c t\u1ea1m gi\u1eef trong v\xf2ng 30 ng\xe0y v\xe0 \u0111\u01b0\u1ee3c t\u1ef1 \u0111\u1ed9ng ho\xe0n l\u1ea1i n\u1ebfu chuy\u1ebfn \u0111i kh\xf4ng c\xf3 s\u1ef1 ki\u1ec7n ph\xe1t sinh chi ph\xed ngo\xe0i chi ph\xed thu\xea xe)","paypal":"PayPal","group2":"\u0110\u1ea3m b\u1ea3o b\u1eb1ng ti\u1ec1n m\u1eb7t ho\u1eb7c chuy\u1ec3n kho\u1ea3n","atm":"Th\u1ebb ATM n\u1ed9i \u0111\u1ecba","visa_master":"VISA / Master Card (Th\u1ebb ph\xe1t h\xe0nh t\u1ea1i Vi\u1ec7t Nam)","vnpay":"V\xed VNPAY","bank":"Chuy\u1ec3n kho\u1ea3n ng\xe2n h\xe0ng","group3":"\u0110\u1ea3m b\u1ea3o b\u1eb1ng t\xe0i s\u1ea3n t\u01b0\u01a1ng \u0111\u01b0\u01a1ng ti\u1ec1n","cash_note":"(v\xed d\u1ee5: xe m\xe1y,...)"}},"quick_pay":{"title":"Thanh to\xe1n \u0111\u01a1n \u0111\u1eb7t","title1":"Thanh to\xe1n k\xfd qu\u1ef9 \u0111\u1ea3m b\u1ea3o","label":"Ch\u1ecdn h\xecnh th\u1ee9c thanh to\xe1n","book_code":"M\xe3 \u0111\u01a1n"},"service_highlights":"D\u1ecbch v\u1ee5 n\u1ed5i b\u1eadt","other_request":{"request":"VAT (+8%)","personal":"C\xe1 nh\xe2n","company":"Doanh nghi\u1ec7p","otherreq":"Y\xeau c\u1ea7u kh\xe1c (t\xf9y ch\u1ecdn)","sen_tax":"Xu\u1ea5t h\xf3a \u0111\u01a1n VAT"},"Business_vat":{"company_info":"Th\xf4ng tin doanh nghi\u1ec7p","name":"T\xean doanh nghi\u1ec7p","company":"\u0110\u1ecba ch\u1ec9 c\xf4ng ty","tax_code":"M\xe3 s\u1ed1 thu\u1ebf","mail":"\u0110\u1ecba ch\u1ec9 email nh\u1eadn h\xf3a \u0111\u01a1n \u0111i\u1ec7n t\u1eed"}}')}},[[300,178,179]]]);