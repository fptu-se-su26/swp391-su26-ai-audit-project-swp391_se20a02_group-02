et_password_by_email":"Reset password by email","reset_password_by_phone":"Reset password by phone"},"payment_method":{"amount_type":{"full":"Pay now","deposit":"Pay later"},"method":"Method","offline":"Payment offline (Cash)","momo":{"name":"Money transfer via MoMo","instruction":{"title":"Momo transfer instruction"}},"cash":"On contact","momo_step1":"Step 1","momo_step1_desc":"Open MoMo App and choose \'Qu\xe9t m\xe3\'","momo_step2":"Step 2","momo_step2_desc":["Scan ChungXe\'s MoMo payment QR code","(Hoang Hong Minh - 090.322.9906)"],"momo_step3":"Step 3","momo_step3_desc":["In the Message for the recipient section, please enter:","[Name][Mobile][Deposit (Vehicle\'s name)][Rental Date][Return Date]"],"transfer":{"name":"Transfer via bank account","instruction":{"title":"Bank transfer instruction"}},"transfer_techcombank":"Vietnam Technology and Commercial Joint Stock Bank <br />(Techcombank)","transfer_techcombank_desc":"- Acount number: 19035651301016 <br />- Branch: Ha Noi <br />- Account holder: Hoang Hong Minh <br />- Content of transfer: <br />[Name][Mobile][Deposit (Vehicle\'s name)][Rental Date][Return Date]","transfer_mbbank":"Military Commercial Joint Stock Bank (MBBank)","payment_order_no":"Transaction number","transfer_mbbank_desc":[["Account holder","Chung Xe., JSC"],["Account number","4001155599999"],["Branch","Ba Dinh"]],"transfer_mbbank_personal_desc":[["Account holder","Nguy\u1ec5n Th\xe0nh Nam"],["Account number","0934646766"]],"transfer_mbbank_note":"Customers <b>do not need</b> to issue a <b>VAT</b> invoice, please transfer:","transfer_mbbank_personal_note":"If customers <b>need</b> to issue <b>VAT</b> invoice, please add <b>10%</b> of the rent","transfer_mbbank_content_title":"Transfer content:","transfer_mbbank_content_invoice":"When you are done, please take photos and upload them here","transfer_mbbank_content":"[Name] [Phone] [vehicle rental deposit (name of vehicle)] [ day rent ] [ day return]","transfer_mbbank_deposit":"vehicle rental deposit","online":"Payment online","online_atm":"ATM vehicled of local bank","online_visa_master":"VISA/ Master Card (Card issued in Vietnam)","online_vnpay":"VNPAY","paypal":"PayPal (5% transaction fee)","amount":"Payment amount","amount_type_1":["Pay later","Deposit to hold: 30% rental price"],"amount_type_2":["Pay now","Pay 100% of the bill","5% discount on rental price"],"payment_status":"Payment status","payment_success":"Payment success","payment_failed":"Payment failed","payment_vnpay_failed":"The order has been created but the payment has failed. Please contact Chungxe for further assistance.","payment_vnpay_success":"You have successfully paid for your order at Chungxe, your transaction code is","online_promotion":"5% discount. Not applicable for pubic holidays and Tet"},"process":{"one":"Select vehicle","two":"See price and procedure","three":"Customer\'s information","four":"Completed"},"complete":{"content":{"title":"SUCCESSFUL BOOKING","text":{"line1":"Thank you for using Chungxe\'s service! <br />Please follow the next steps to complete the transaction.","line2":"Please kindly transfer your deposit to secure your booking.","note2":"To complete the rental process, Chungxe needs to verify your documents. Please provide a photo of your documents as required below:","note3":"Thank you for using ChungXe\'s service !","note_create_acc":"We have created an account for you. You can check your email for login information."},"book_code":"Your booking code:","btn_home":"Back to homepage","btn_info":"Upload your profile","btn_deposit":"Parking deposit","btn_payment":"Pay for Car Rental","btn_cancel":"Cancel booking","book_status":"The vehicle is ready","book_status_receive":"On hold","book_status_processing":"Processing","book_status_ready":"Vehicle is ready","add_to_gg_calendar":"Add to Google calendar","add_to_ical_calendar":"Add to iCal/Outlook calendar","note-content1":"Uploading a vehicle rental profile makes the vehicle rental process faster and more convenient.","note-content2":"Chungxe gives you the code 50000 VN\u0110 if you complete the upload.","note-content3":"Quick deposit to complete the parking.","note-content4":"{{count}} others are checking this vehicle.","note-content5":"Remaining parking time:","note-content6":"Make a deposit to secure the car and protect your benefits","note-shk":"Can select multiple household register files at the same time","note":"Note:","content_note":["Remember to prepare all the required documents and collateral to make the vehicle rental convenient.","Read vehicleefully the vehicle rental contract and the vehicle handover record of the vehicle lessor.","Check the exterior, interior and machinery thoroughly during the process of receiving the vehicle.","When the vehicle is operating, regularly pay attention to the warning lights on the dashboard, if you see an incident light, or the vehicle has unusual phenomena, you must stop the vehicle to check and call immediately to notify the vehicle lessor to In case of arbitrarily handling or taking the vehicle for repair without notice or consent of the Lessor, the lessor will have to take full responsibility.","Strictly abide by the road traffic laws. Self-responsibility for civil and criminal matters during the rental period. In case of violation of road traffic laws and fines, you will have to bear full responsibility. about the penalty fee payable to the legal authority.","The cost of renting a vehicle does not include the costs of driver, petrol, ferry bridge, yard, etc. during the vehicle rental process."],"content_note_motor":{"l1":"- Prepare all the documents needed for the rental vehicle: ID vehicled, driving license","l2":"- Select the type of vehicle (number vehicle, motor scooters, motorcycle) suitable to the terrain and your habits.","l3":"- Check vehicle\'s quality with the vehicle hire company when picking the vehicle up :  headlights, blinker, mirrors, foot brake, handbrake, intake manifold ...","l4":"- Carefully read the vehicle rental contract and the additional conditions, such as limited mileage, the time of renting a vehicle ..."}},"customer":{"title":"CUSTOMER INFORMATION","fullname":"Full name","phone":"Phone number","email":"Email","address":"Pick-up Address","btn":"Edit"},"vehicle":{"title":"Vehicle booking details","status":"Status","payment":"Payment method","code":"Booking code","type":"Type of vehicle","form":"Received vehicle method","time":"Time","btn":"Edit","value":"Value set vehicle","amount":"Due amount","equals":"or similar"}},"select_carriage":{"vehicle":{"btn_detail":"Rent now","note1":"Price per day","note2":"Price doesn\'t included delivery fee","unit":"VND","day":"day","note3":"(*) days are calculated from 7h-19h","note4":"Chungxe proposed","note5":"Chungxe recommends this vehicle based on the common needs of users!","text_not_load_more":"No more vehicles. You can change the filter to see more vehicles."},"left":{"car":"Car","motor":"Motor","motorbike":"Motor scooters","handclutch":"Motorcycle","hanoi":"Ha Noi","hcm":"Ho Chi Minh","hue":"Hue","price_range":"Price range","select_seat":"Select the number of seats","select_type":"Select type of vehicle","keyword":"Enter brand, model, version... E.g. vios 2019","vehicle_types":{"luxury":"Luxury","pickup":"Pickup"},"select_transmission":"Select transmission type","select_brand":"Select vehicle brand","select_city":"Select location","select_district":"Select district","car_types":{"pickup":"Pickup truck","luxury":"Luxury"}},"options":{"range":"Sort results","increase":"From low to high","reduction":"From high to low","grid":"Grid","list":"List","map":"Map","new":"New"},"unit":"\u20ab","day":"/ day","if_pay_online":"for online payment"},"preview_price":{"unit":"VND","hour":"hour(s)","day":"/ day","discount":"Discount","info_right":{"at_home":"Get the vehicle at home","delivery":"Giao xe","at_dealer":"Get the vehicle at dealer","rental_range":"Rental time","notifiname":"Holiday notice","noti_content":"Chungxe has holidays scheduling from Sep 01 to Sep 04, 2022, so all vehicle booking activities, customer support and partners, handling arising will suspend operation. <br /><br />Customers can contact Chungxe through the only channel that is email contact@chungxe.vn. Chungxe will respond to enquiries starting Sep 05.","time":"TIME","promotion_code":"PROMOTION CODE","placeholder_promotion":"Enter promo code ...","limit_distance":"DISTANCE\'S LIMITATION","price_detail":"PRICE DETAILS","price":"Unit price","day":"Rental time","total":"Total","payment":"Deposit","note":"* Total amount not include delivery vehicles","btn_continue":"Book a vehicle","btn_back":"Go back","total_day":"TOTAL","total_package":"SPECIAL OFFER","subscription":"SUBSCRIPTION PACKAGE","addon":{"title":"Additional service","title1":"Total price","title2":"Service Pack Simplify the procedure","facilitation":"Support package","head_popup":"By choosing the service packages for exemption and reduction of rental procendure, Chungxe understands that you have agreed to the terms of package policy as below.","content_popup":"The service packages helps you to have a simplier procedure when renting a vehicle on Chungxe, because Chungxe guaranties with our partners on vehicle rental procedures for customers who are eligible to register for these packages. The three kinds of service package are:","note":"Notes","note1":"You must to present the valid ID and Driver\'s license before picking up the vehicle","note2":"Some of our supplier partners may apply only of these packages, or not apply all of them. Chungxe will notify you in the process of receiving orders, and will refund the service fee (if any) to you.","conditions":"Conditions to be applied:","conditions1":"1. You need to upload required rental documents including:","conditions1_content1":"Household registration/ Passport","conditions1_content2":"ID vehicled (2 sides)","conditions1_content3":"Valid driver\'s license (2 sides)","conditions1_content4":"Labor contract / Certificate of employment / Guarantee letter from employer","conditions2":"2. Prioritize with customers who:","conditions2_content1":"Rented a vehicle many times on Chungxe (>=2 times)","conditions2_content2":"Or pay by Credit vehicled","conditions2_content3":"Or is an office staffs","conditions3":"3. Book a vehicle at least 2 days in advance (48 hours)","conditions4":"4. With deposit reduction package, you still need to prepare all the required documents","conditions5":"5. You need to pay in advange the service fee and booking holding deposit before Chungxe conducts the appraisal of the application. The service fee will be refunded if your application is not successful","expertise":"Customer Verification","expertise1":"1. After receiving the application and service fee, Chungxe will verify the information and give the feedback within 6 hours from the time you complete the application","expertise2":"2. Chungxe reserves the right to refuse to provide services to you in the following cases:","expertise2_content1":"Your documents are found to have signs of forgery or mismatched information","expertise2_content2":"The information provided is not correct, does not cooperate in the verification process","expertise2_content3":"There are not enough required documents at the pick-up time (for deposit reduction package)","expertise2_content4":"Unable to present the driver\'s license and ID vehicled/Passport at the pick-up time","expertise2_content5":"Do not pre-pay the service fee together with booking holding deposit","name":"Package name","fee":"Service fee","description":"Description","insurance":{"name":"Vehicle Insurance"},"full_guarantee":{"name":"Procedure exemption","description":"No paper, no deposit","fee":"20% rental price"},"partial_guarantee":{"name":"Procedure reduction","description":"No paper, min. VND 5 millions deposit","fee":"15% rental price"},"financial_support":{"name":"Deposit reduction","description":"No deposit","fee":"10% rental price"},"driver":{"name":"Including a driver","description":"Chungxe is now offering Additional Driver option with these conditions applied:","description_list":["No paper needed, no deposit required","Basic daily fee (8AM- 6PM): VND 500,000","Extra fee for overnight: VND 300,000","Maximum working hour for driver: 10 hour/day. Extra fee each hour exceeding is VND 100,000"],"fee":"VND 500,000/day"},"title3":"Service rent driver"},"can_apply":"Price above does not include","DELIVERY_SOON":"Early pick-up fee","RETURN_LATE":"Late drop-off fee","BOTH_EXTRA_FEE":"Early pick-up and late drop-off fee","mode":"RECEIVED VEHICLE METHOD"},"info_left":{"describe":"DESCRIBE","features":"FUNCTION","procedure":"PROCEDURE","payment":"ACCEPT PAYMENT","prepay":"Prepay","postpaid":"Postpaid","same":"or similar","manu_year":"Manufactured in","note":"NOTE","address":"ADDRESS","verificationOnly":"Documents only need to be verified (vehicle owner does not keep)","deposit":"Security deposit information","deposit_amount":"Deposit amount","alternative_asset":"Asset of equivalent value"},"info_vehicle":{"seat":"seat","gasoline":"gasoline","auto":"Automatic","air_conditioner":"Air conditioning","motorbike":"Motor","cmnd_passport":"ID/ Passport","sunroof":"Sunroof","bluetooth":"Bluetooth","gprs":"GPS","usb":"USB","note":"(For tourists)"},"info_motor":{"gasoline":"Gasoline","disc_brakes":"Brake discs","scooter":"Scooter","anti_lock":"Anti-lock brakes","smart_lock":"Smart key","license":"License","cmnd_passport":"ID/ Passport"},"note":"Prices shown are weekdays, excluding surcharges for Public holidays, please leave contact information and complete your booking for specific advice.","note_lunar":"Due to high demand, the prices for Tet holidays will increase by about 1.5 - 2.5 times compared to the normal day prices shown above. Please leave your contact information and complete your reservation for specific advice. See the updated price list of Tet holiday HERE:","note_special_day":"The prices shown above is not including extra fee (about 30-50%) for public holidays, due to high demand.","label-note":"Note","label-promotion":"Promotion","info_car":{"seat":"seat"},"promotion-payment-online-discount":"Payment online discount 5% on unit price"},"about":{"company":{"title":"ABOUT US","l1":"Chungxe is a pioneer startup in the development of online platforms for rent and shared vary kinds of vehicles in Vietnam.","l2":"Chungxe helps customers who want to hire a self-drive vehicle (vehicles and motorcycles) to connect the dealers as well as individuals with vehicle idle across the country through our website or mobile app . Customers can search, compare and rent a vehicle easily and quickly.","l3":"Chungxe was born with the mission to bring modern technology platform that helps to rent and share a vehicle quickly, safety and economically. Chungxe towards rental & sharing vehicles community and transportation in a civilized and friendly environment."},"why-do":{"title":"Why we do?","l1":"Do not exist a good vehicle rental/ vehicle-sharing platform in Vietnam.","l2":"Customer hard to rent a vehicle while provider do not have good technology to manage asset.","l3":"Customer already familiar with booking transportation service via online/mobile channel and vehicle-sharing technology already mature enough.","l4":"A global trend to transform vehicle- ownership to vehicle-sharing."},"operating":{"title":"How we do?","l1":"Even the most complex of problems has a simple yet elegant solution. At Chungxe we don\u2019t just rent vehicles, we create disruptive products which complete the existing ecosystem. We build technology which provides a comprehensive solution to the issue of ground transportation by connecting commuters to vendors in the self drive vehicle rental business. Our mission at Chungxe is to provide a platform where customers can easily rent a desired vehicles while owners can engage customers and conduct business seamlessly. We concentrate our efforts on simplifying the process of renting vehicles by creating tools to conduct and facilitate transactions from price comparisons to online payment, from rental insurance to reduction of rental procedures and a lot of utilities for both renters and vehicle owners."}},"policy":{"title":"INCIDENTS AND COMPLAINTS","purpose":{"title":"INFORMATION PRIVACY POLICY","l0":"Your personal information will only be used for the purposes below:","l1":"Support for placing vehicles and providing vehicle for you.","l2":"Contact you in for Chungxe\'s marketing purposes.","l3":"Improve the service\'s quality and customer support.","l4":"Solve the case and disputes arising in relation to the usage of Chungxe\'s service.","l5":"Provide information to law enforcement agencies as required."},"limit":{"title":"Scope of information used","l0":"Chungxe platform uses member\'s information provided to:","l1":"Send notices of activities of exchange information between members and Chungxe platform.","l2":"Prevent activities that destroy the user account or prevent fake member fake.","l3":"Contact and deal with members in special case.","l4":"Do not use member\'s personal information unless to confirm or contact relating the vehicle and booking vehicle.","l5":"In case the request of law: Platform Chungxe is responsible for providing personal information members upon request from judicial authorities include: procuracy, courts, public security organs that investigations related to member\'s violations of laws. Nobody else has the right to infringe on the member\'s personal information."},"time":{"title":"Information\'s retention time","l1":"Customer\'s personal data will be stored until a cancel request or Customer login and cancel yourself. In others case, customers\'s personal information will be secured on the company\'s servers."},"service":{"title":"OPERATION\'S REGULATION","title1":"Accept the terms","title2":"Service\'s description","title3":"Responsibility of account and password provided","title4":"Responsibility for providing information","title5":"Responsible for the content posted","title6":"Limited activity","title7":"Liability\'s limitation","title8":"Security","title9":"Intellectual property","l1":"The following agreement is a legal agreement between you bound (can be \'Owner\', or \'Driver\') and Chungxe community network operators group( \'We\'). The agreement covers the terms of service that you have to adhere to access and use our services. Terms of service apply even if you do not have an account. Your usage of Chungxe service means you accept the terms of this service. At each period, we may update the Terms of Service in accordance with its decision without direct notice to you. You are responsible for consulting the latest version by visiting the website www.chungxe.vn.","l2":"PLEASE READ THIS TERMS SERVICE BEFORE REGISTERING MEMBERSHIP. IF YOU DO NOT AGREE WITH THESE TERMS OF SERVICE, PLEASE DO NOT USE OR ACCESS OUR SERVICES","l3":"Chungxe is a online community sharing self-driving vehicles (motorcycles, vehicles) in the market; a connection between who have a vehicle for rent and who want to rent a self-driving vehicle. When you have an account at Chungxe, you can easily propose or rent a self-driving vehicle (motorcycles, vehicles) through the gadgets that we offer. These gadgets are referred to collectively as the \'Services\'. You also understand and agree that the Service include some contact information of the Managing Board Chungxe through means such as email, SMS, website .. and that this communication is considered an integral part of the Services and You will not be able to refuse to receive this information unless you terminate your account.","l4":"","l5":"You will receive a password and account designation upon completing the Service\'s registration history. You are responsible for the security password and account and are fully responsible for all activities that occur under your password or use your account.","l51":"You agree to immediately notify us of any cases of unauthorized use of your password or your account or any other breach cases security","l52":"Ensure that you exit from your account after each use. We can not and will not be liable for any loss or damage incurred by you not comply with this","l6":"As people use the service, you must commit to:","sv161":"You have the legal status and behavior as when using the service","sv162":"Providing the latest information, complete, honest and accurate about yourself in the Personal Profile","sv163":"Maintain and promptly update the Personal Profile to ensure that this data is complete, truthful and accurate.","sv164":"If you provide any information that is not dishonest or inaccurate, or if Chungxe have reasonable grounds to suspect that such information untruthful or inaccurate, Chungxe the right to suspend or close your account stopped; refuse partial or full use of services at the present time or in the future","l7":"You understand that you are entirely responsible before the law for the content you create, including but not limited to data, text, software, sound, photographs, video, email. We have no obligation to monitor the materials posted and, therefore, does not guarantee the legality, accuracy, integrity or quality of such Content. In areas allowed to upload content, you can share information allowed under the format we default and you are solely responsible for the content, information, photographs, and any your shared with other individuals or groups who use users. However, in any case, we still reserve the right to process the information published in accordance with the habits and customs, rules of ethics and the rules to ensure national security, and we reserves the right to allow or not allow your articles appear or exist in the area are allowed to share information.","l8":"Unlimited remedial measures differently, we may terminate your participation, your information removed, warning the community about your actions and refuse to provide services if:","sv181":"You have used the wrong purpose of the service, with acts of unlawful or morality","sv182":"We have reasonable grounds to suspect that the information you provide dishonest or inaccurate","sv183":"We believe that your actions as fraudulent, deceptive and can cause loss or financial liabilities or our community","sv184":"Use of services for commercial purposes without the prior written consent of us agree","sv185":"Violations of our rights or third parties, including but not limited to intellectual property rights, copyright, patent, trademark, trade secret or privacy rights","sv186":"Spreading malicious application or attack seized control system, data or personal information","l9":"You understand and agree that:","sv91":"Your use of transport services of other participants in traffic is your decision. You bear all risks incurred. We explicitly reject all warranties under any kind of quality of service or personal prestige of the parties.","sv92":"We have no obligation to handle complaints related to the quality of transport services by the parties to provide and deny all the constraints related to liability both ethical legal contract when have unfortunate consequences in the process of the members used means of transport.","sv93":"We are not responsible for transport services of third parties to use our information to provide services to you.","sv94":"We do not guarantee that:","sv941":"The services will be uninterrupted, timely, secure or error","sv942":"Services can be accessed at any time or from time to time through the channel of your choice or use","sv943":"Information, content, or advertisements contained in the service will be accurate or reliable","sv944":"The loss of data and other contents are guaranteed maximum","sv95":"We reserve the right to modify, temporarily or permanently stop the service with or without notice. We have no obligation to any correction, suspended or not to continue providing services.","l10":"We do not sell or rent your personal information to third parties without your permission, and we only use your information as described in the Terms of privacy. We see the protection of the privacy of users as an important principle of leading the community. You can review the privacy policy at our current privacy policy.","l11":"All intellectual property rights exist in the Service Chungxe belong Chungxe or legal licensed for use Chungxe. Accordingly, all of the legal rights are guaranteed. Unless the consent of Chungxe, you may not upload, post, publish, modify, reproduce, transmit or distribute in any form any part of the Service Chungxe provided. We have full rights, including but not limited to copyright, trademark, and other proprietary rights that we have in the Service Chungxe.Tat both elements to the Service that we provide are in range of our property whether registered or unregistered. The use rights and ownership of us should be our prior permission in writing. In addition to written authorization, we are not licensed in any other form whether it is the form of announced or implied, or through the services you use. And therefore, you have no right to use our services in commercial purposes without permission in writing from us before. You agree to us freely use, disclose, adopt and modify any ideas, concepts, methods, recommendations, suggestions, comments or form other notice that you give us ( \'Feedback\') relating to Chungxe and / or services Chungxe completely free. You waive and agree to waive any rights and claims to any bonuses, fees, royalties, fees and / or type of other payments related to our use, disclosure, application , and / or modify any or all of your Feedback."},"incident":{"title":"Incidents and complaints","l0":"Mechanism for resolving complaints relating to the personal information of customers:","l1":"Chungxe  will be the unit intermediary to receive complaints from customers. When detecting a violation, the hotel vehicle rental, vehicle owners may submit a complaint about the Chungxe. Chungxe will review and assist with standing out work directly with state agencies competent support provided information necessary to serve the complaint.","l2":"In the case of information systems under attack raises the risk of loss of consumer information, Chungxe will notify authorities within 24 (twenty four) hours after discovering the problem.","l3":"Companies and vehicle owners are responsible for receiving complaints and customer support related to the transaction are connected through the Exchange. The complaint related to the provision, use the vehicle rental service on the Exchange by the company responsible for the independent settlement on the basis of the provisions of law, the Terms and Conditions for using the service, the notices and regulations published with the member (Customer and vehicle owner). When disputes arise, the Company uphold negotiated solution, reconciliation between the parties in order to maintain confidence in the quality of Member of the Exchange service. Customers can follow these steps:","l4":"Step 1:","l41":"Customer can complaints about service via Chungxe hotline 090 450 9596 or send an email to contact@chungxe.vn. Time for receiving the complaints is 3 days of using the service or from the date of the incident.","l5":"Step 2:","l50":"Within (3) working days after receiving the information of the customer complaint, the Customer Care department confirmed the information complaints and classify information and notify customers:","l51":"2a. Noting the requests and complaints relating to the Company and within the complaint.","l52":"2b. Refusal of requests, complaints are not related to the company and the expiration of the appeal.","l6":"Step 3: Solve the problem","l60":"Chungxe will conduct the verification, verification and analysis of the nature and extent of the contents of the complaint, the scope of claims and handling responsibility to coordinate with the vehicle and Party Service Provider th 3 outlines specific measures to assist customers solve their dispute.","l61":"3a. Transfer issues related directly to the Company for the relevant department and reference checks.","l62":"3b. Transfer issues related to all vehicles settlement.","abc":"Within three (3) working days after receiving notice of the complaint, all vehicles shall coordinate with Chungxe to solve and handle complaints. Car owners will notify the Customer remedies or authorization notice to the Company.","l7":"Step 4: Close complaints","l71":"4a. Customer agrees to feedback Customer Care Unit -> End complaint. Client does not agree -> Back to step 3","l72":"4b. Subscribe to resolve complaints all vehicles -> End of complaints when customers and vehicle owners have agreed to complete.","l8":"Upon receiving notice of remedial measures from all vehicles, but customers do not agree, the company will take the lead in negotiations, mediation between customers and vehicle owners to go to the settlement results consistent with both parties . In case the Customer and vehicle owners do not go to the general agreement or the Customer does not agree with the measures to settle the last of all vehicles and / or beyond the capability and competence of the company, the customer or the vehicle possible thanks to the State agency authorized to intervene and settle according to law in order to ensure the legitimate interests of the parties.","l9":"Companies respect and strictly implement the provisions of the Law on the Protection of the rights of users. The company recommends customers and vehicle owners provide accurate, truthful and detailed personal information and posting content related to the service. We also suggested that vehicle owners need to seriously adhere to the provisions of law, as well as appropriate behavior towards clients. All acts of fraud, fraud in business, harm to others are condemned and must bear full responsibility before the law. The parties include customers and all vehicles will have a positive responsibility in resolving complaints. Vehicle owners should be responsible for handling the initiative and provide identification papers written information relating to the matter are complaints or disputes with customers. The company only serves to support and coordinate the negotiation, mediation and settlement of complaints and keep customers and vehicle owners. The company is also responsible for providing information related to the Customer and vehicle owner if the vehicle owner or the Customer or the law enforcement agencies have the competence required.","l10":"After Customer and vehicle owner has settled the dispute, it should be responsible for the Company reports to update the situation. In case of transactions arising conflicts that errors belong to all vehicles: The Company will apply measures to handle violations respectively, including but not limited to: a warning, key account or transferred to the law enforcement agencies competent according to the degree of violation. The company will terminate and remove the whole story about the products and services of all vehicles on the trading floor which simultaneously require vehicle owners to reimburse the customer on the basis of satisfactory agreements with customers."},"refund_cancel":{"title":"Cancellation & Refund Policy","title1":"Service Terms and Conditions","content1":"I. Before renting","content2":"<strong>1. Booking confirmation</strong>: Chungxe will confirm your reservation within 24 hours. However, due to the high demand during Tet holidays, Chungxe recommends you to make a booking at least 2 days before the hire date (3 days before the weekend) for vehicles and 1 day for motorcycles.","content3":"<strong>2. Reserve deposit</strong>:  When booking a vehicle at Chungxe, you only need to deposit 30% - 50% of the total renting fee (as Chungxe confirmed via email/sms via phone/zalo/viber...).","content4":"3. Cancellation policy:","content5":"If you make a deposit less than 5 days before the renting date (eg: the renting date is January 15 and deposit on January 10 or earlier), <strong>YOU WILL BE FULLY REFUNDED</strong> when cancelling your booking within 24 hours from the time Chungxe receives the money. In case you cancel the rental after 24 hours from the time Chungxe received the deposit, there will be <strong>NO REFUND</strong>). In addition,if you have paid online, you will lose 30% - 50% of the total booking value (equal to the value of the reserve deposit).","content6":"If you make a deposit less than 5 days before the renting date, you will not be refunded the deposit when cancelling the rental vehicle (eg: the renting date is January 15, if you make the deposit on January 11 or later when canceling your booking, the deposit <strong>WILL NOT BE REFUNDED</strong>. In case of online payment, you will lose 30% - 50% of the total booking value (equal to the value of the reserve deposit).","content7":"4. Rental procendures","content8":"Household registration book or KT3 (with local renter)","content9":"Valid driver\'s license (Vietnamese or International License)","content10":"ID or Passport","content11":"Deposit in cash or equivalent value (Motorbike and it\'s registration document)","content12":"Other documents (if needed): Flight booking, hotel booking (with tourists)","content13":"*** Note: During the vehicle delivery process, if: <br /> - The customer does not hand in all of the above documents <br /> - Paperworks are detected suspicious <br /> - Purpose of vehicle rental is unclear <br /> The booking will be cancelled and the customer will be required to comply with the Cancellation Policy as above.","content14":"<strong>5. Re-confirm with customers</strong>: Chungxe or our partners will be the representative directly confirming with customers about vehicle rental information.","content15":"<strong>6. Information about the owner/vehicle rental partner</strong> at Chungxe will be provided to customers up to 6 hours before the date of renting (At least 2 phone numbers to contact).","content16":"II. Vehicle delivery","content17":"<strong>1. Delivery location</strong>: You can pick up and drop off your vehicle at the location of Chungxe\'s partner garage for FREE or receive the vehicle at your requested location (home, airport, hotel) for an amount of fee based on km.","content18":"<strong>2. In case of being unable to contact and meet the owner,</strong> Chungxe will assist you to contact the owner. If they can not be reached before the maximum of 1 hour, Chungxe will assign another vehicle to ensure the time and plan for customers.","content19":"<strong>3. Support policy</strong>: Chungxe will try our best to support customers between 8am and 9pm via Email, Live Chat, OTT (Zalo, Viber, FB Messenger), Hotline.","title2":"Refund Policy","content20":"- If we are not able to provide the same type of vehicle as you have ordered, Chungxe will arrange the equivalent vehicle and discount 5% on rental fee.","content21":"<strong>If there is no vehicle,</strong> Chungxe will return the deposit and compensate 100% (maximum VND 500,000) together with 5% discount voucher for next booking","content22":"- In case of Chungxe\'s mistake in not confirming a customer\'s booking or providing partner\'s information, you will get a 5% discount of the rental price.","content23":"See details of compensation conditions.","content24":"Compensation conditions.","content25":"Compensation conditions.","content26":"Customers meet Chungxe\'s rental requirements. This policy does not apply to those who are not eligible to rent or found that suspicious signs about the documents and the purpose of the rental.","content27":"The customer has order confirmation with Chungxe\'s partner, but at the pick-up time, there was no vehicle to rent.","content28":"The customer has order confirmation with Chungxe\'s partner, but the partner cancels the order before the pick-up time, and Chungxe cannot arrange another vehicle for the customer.","content29":"Chungxe will not compensate in the following cases:","content30":"Chungxe or Chungxe\'s partner has arrange another vehicle for customer","content31":"Chungxe\'s partners have to cancel due to force majeure events such as: earthquakes, tsunamis, landslides, floods, thunderstorms, epidemics, wars, strikes, etc.","content32":"Detect fraud incidents to claim compensation."},"supply_partner":{"title":"SERVICE COMMITMENT POLICY FOR SUPPLIER PARTNERS","title1":"Service standards","content1":"I. Before renting the vehicle","content55":"<strong>1.Receiving the deposit of customer</strong>","content56":"Chungxe and partner have responsibility for receiving the deposit of customer with the minimum value of 30%/ order before the customer\'s departure date. The customer\'s deposit 1 of 2 parties is <strong className=\'text-danger\'>the same value</strong>. (both parties can send evidence via bank statements). In case the customers book and go urgently in a day, we would be flexible in receiving deposit based on customers\' need","content57":"For customers traveling within the day: Maximum  <strong className=\'text-danger\'>5 minutes</strong> upon receiving the order","content58":"For customers going ahead> 1 day: Maximum  <strong className=\'text-danger\'>15 minutes</strong> upon receiving the order","content2":"<strong>1. Confirmation of order </strong>:","content3":"For customers traveling within the day: Maximum  <strong className=\'text-danger\'>15 minutes</strong> upon receiving the order","content4":"For customers going ahead> 1 day: Maximum  <strong className=\'text-danger\'>2 hours</strong> upon receiving the order","content5":"<strong>2. Contact with customers</strong>:","content6":"<strong>3. Notification of Order Status (close the sale)</strong>","content7":"The partner (owner of the vehicle) needs to notify Chungxe of the order status, including the Customer\'s rental conditions (after verification), the status of order confirmation with the customer, additional information required (if any). ..through communication channels that have been dealed (App/Web, Zalo Group,...)","content8":"4. <strong>Cancellation of Order</strong>","content9":"- If you want to cancel an order that has been closed before the customer\'s departure date> = 2 days (eg, if the departure day of customer is January 15, the order shall be cancelled on January 13 or earlier)","content10":"+ Notifying Chungxe to change orders for customers","content11":"Or if the partner has changed or arranged the vehicle for the customer, it is necessary to notify Chungxe within <strong className=\'text-danger\'>1 hour</strong> after the notice of order cancellation.","content12":"- If you want to cancel an order that has been closed less than 2 days before the customer\'s departure date (eg, if the departure date is January 15, the order shall be cancelled on January 14 or later):","content13":"+ Partners must mobilize or arrange equivalent vehicles for customer, and notify Chungxe to support to talk with customer, but make sure not to exceed <strong className=\'text-danger\'>6 hours</strong> in advance until the time of departure. If the notification is late, it will be considered that Chungxe did not receive the notice and must implement <strong className=\'text-danger\'>the support and compensation policy for customers below</strong>.","content14":"+ In case the customer disagrees, Chungxe will arrange other vehicles to ensure that there is a vehicle at the same price as the vehicle that the customer has booked. In case all vehicles with the same price of Partners are unavailable, the partner needs to bear <strong className=\'text-danger\'>50% of the price difference</strong> with Chungxe (Chungxe takes <strong className=\'text-danger\'>50% of the price difference</strong>) to compensate for the customer.","content59":"In case the customers book and go urgently in a day (between booking and departure time <strong className=\'text-danger\'>< 6 hours)</strong>,after the vehicle owner closed order, If the notification is late <strong className=\'text-danger\'>15 minutes</strong> after closing the order , it will be considered that Chungxe did not receive the notice and must implement <strong className=\'text-danger\'>the support and compensation policy for customers</strong> below.","content15":"II. During the transaction and time to use the vehicle","content16":"1. Hand over the vehicle","content17":"Handing over the vehicle on time and location according to the agreement with the customer","content18":"Handing over the vehicle in accordance with the policy of delivering the vehicle with Chungxe","content19":"Being responsible for providing 2 phone numbers to customers or at least 1 number but need to ensure smooth communication at the time of delivery with customers.","content20":"2. The process of using the vehicle by the customer","content21":"Supporting for customers to solve problems in the process of using the vehicle","content22":"III.Customer support policy","content23":"1. Time of support","content24":"According to the vehicle owner\'s service hours, however, you need to ensure assistance when customers need help","content25":"2. Support channel","content26":"Zalo/Phone/SMS/Viber/Messenger","title2":"Service regulations and customer compensation policy","content27":"I. Vehicle","content28":"<strong>1.There is no vehicle category as booked by the customer(without notice to Chungxe)</strong>","content29":"Arranging equivalent vehicle lines for guests. In case there is no equivalent vehicle, it is necessary to arrange another vehicle, the owner must take the same price as the vehicle booked by the passenger.","content30":"<strong>2.  No vehicle for rent or voluntary cancellation of order (without notice to Chungxe)</strong>","content31":"If the vehicle owner holds the deposit: Return 100% of the deposit to the customer + also reimburse an additional 50% of the deposit (<strong className=\'text-danger\'>up to 300000 VND</strong>) for Chungxe and the customer to solve the problem arising from  missing the customer\'s schedule. Chungxe will review the priority order to receive the order if there is more than 1 violation (if there is no reasonable reason)<br>- If Chungxe holds the deposit: Return 100% of the deposit to the customer and the vehicle owner reimburses an additional 50% of the deposit (<strong className=\'text-danger\'>up to 300000 VND</strong>) for Chungxe and the customer to solve the problem arising from  missing the customer\'s schedule. Chungxe will review the priority order to receive the order if there is more than 1 violation (if there is no reasonable reason)","content32":"II. Service","content33":"<strong>1. No confirmation of booking </strong>","content34":"Chungxe will transfer the application to another partner","content35":"<strong>2. Having a bad attitude towards customers which influences Chungxe brand</strong>","content36":"Depending on the level of situation, The Partner\'s priority of receiving booking will be reconsidered or stop cooperation between Chungxe and Partners","content37":"<strong>3. No notification of order status</strong>","content38":"Chungxe will transfer the booking to another partner","title3":"Support policy of Chungxe","content39":"I. Order","content40":"<strong>1. Customer evaluation</strong>","content41":"Chungxe supports soft-check assessment through consulting, paperwork to minimize risks for partners. The owner of the vehicle has the right to decide  whether their vehicle to be rented or not and Chungxe does not bear the risk of the number of plugs and collisions during the time customer use the vehicle.","content42":"<strong>2. Sending photos of papers and procedures that the customer has</strong>","content43":"Chungxe will support to attach all documents and procedures that the customer currently has in the order to help the vehicle owner reduce the appraisal time.","content44":"<strong>3.Receiving Booking</strong>","content45":"Chungxe takes customer Feedback on service quality and will regularly evaluate services quality of Partners and give priority to increase the number of orders with vehicle owners who have quality service, price, simple procedures to make customers satisfied","content46":"<strong>4. The vehicle booking is cancelled by the customer</strong>","content47":"If a customer cancels a closed order 4 days prior to the customer\'s departure date, Chungxe will provide maximum support to send another order to supplement partners (if there is a matching order).","content48":"If the customer cancels the finished order <4 days before the customer\'s departure date, Chungxe will transfer <strong className=\'text-danger\'>50% of the amount deposited by the customer</strong> and also support another order (if any).","content49":"If the customer cancels the order within 6 hours before the departure time, but Chungxe can not timely support the new orderfor the partner, affecting the business interruption, in addition to Chungxe will transfer the owner. vehicle <strong className=\'text-danger\'>50% of the amount that customers have deposited</strong>, Chungxe will reimburse 1 additional FREE commission (with the maximum value of 1,000,000 VND) at another time.","content50":"II. Risk","content51":"<strong>1. The vehicle is pledged as collateral by the customer </strong>","content52":"Chungxe will assist the owner of the vehicle to not take commission of the booking, if the vehicle identified as being pledged (with verification through the evidence provided by the owner) + 2 orders of FREE commission (with a maximum value of 1,000,000 VND / order) at another time.","content53":"<strong>2. Any collision or risk that occurs to the vehicle during the course of the rental </strong>","content54":"If the partner\'s vehicle does not have physical insurance, Chungxe will provide  insurance package to support both the owner partner and the vehicle rental customer."}},"promotion":{"title":"PROMOTION","btn_detail":"See details","copy":"Copy the code","title_lowcase":"Promotion","max_discount_amount":"Max discount amount"},"guide":{"title":"SUPPORT","title1":"Vehicle rental guide","process1":"Find vehicle","content1":"Visit website or app Chungxe , choose the time & location you need to rent a vehicle.","process2":"Book a vehicle","content2":"Based on price comparison system, choose your favorite vehicle & send us request.","process3":"Pickup the vehicle","content3":"Complete rental procedures, pickup the vehicle & start the journey. You can pick up the vehicle at home or at our dealers.","process4":"Drop off","content4":"Drop off after the journey. Grading services to improve quality.","title2":"Frequently asked questions"},"guide-fadil":{"title":"SUPPORT","title1":"Booking Step","process1":"Find vehicle","content1":"Visit https://chungxe.vn/thue-xe-vinfast, Select your time, location and information of renting a vehicle.","content1e":"Visit https://chungxe.vn/thue-xe-vinfast-fadil, Select your time, location and information of renting a vehicle.","process2":"Book a vehicle","content2":"Based on price comparison system, choose your favorite vehicle & send us request.","process3":"Pickup the vehicle","content3":"Complete rental procedures, pickup the vehicle & start the journey. You can pick up the vehicle at home or at our dealers.","process4":"Drop off","content4":"Drop off after the journey. Grading services to improve quality.","title2":"Frequently asked questions"},"questions":{"title":"FREQUENTLY ASKED QUESTIONS","frequently":{"title":"General questions","l1":"Become a Chungxe\'s partner.","l2":"Chungxe is a fast and reliable online booking system of self-driving vehicles. Chungxe offers the opportunity to reach millions of customers across the country. This is a great opportunity for self-driving vehicle rentals companies for cooperation and development."},"why-do":{"title":"Why should you become our partner?","step1":"How to participate in community Chungxe","step2":"Conditions of participation","l1":"- Ability to reach millions customers through online channels of Chungxe and regularly receive vehicle rental orders, increase revenue and optimize the vehicle\'s retention time.","l2":"- Keep abreast of consumer trends is searching and booking online or via mobile app","l3":"- Chungxe support the develop the online booking channels without losing the investment costs, maintenance costs and system without dedicated IT personnel (for the vehicle rental company)","l4":"- Allows book and pay in advance, to ensure revenue and initiative in business.","l5":"- System passenger feedback on vehicle quality and service as well as customer vehiclee automation allows to improve quality of service.","l6":"- Registration for participation in filling the Registration Form for partnership Chungxe","l7":"- Chungxe test service provider capability and vehicle quality","l8":"- Contracted transport cooperation and revenue sharing","l9":"- Companies / individuals with self-drive vehicle rental","l11":"- Chungxe provide contract model and guidelines on principles of conduct between owners and renters in order to all vehicle transactions take place smoothly. Renters are responsible for their decisions and vehicle rental information you need to consider before deal with owners. Chungxe will help provide information and support to the parties to work with the police when it\'s necessary.","l12":"- When you hire vehicles are on the road and damaged, you must quickly call the vehicle owner to notice the situation. Vehicle owners who best understand the condition of the vehicle, it will give you the most practical advice. In addition, the two sides also need to clarify the cause of the damage was due to the following parties specify who will pay for the fix that. You should also take the phone number for emergency rescue in case something bad happens.","l13":"- For vehicle owners in case their request began temple failures not caused by them, you should take pictures, shoot the vehicle\'s condition as soon as you get the vehicle detailed. If you see signs of damage or are about to damage it must immediately notify the owner and recorded in vehicle leasing contract between the two parties. Chungxe provided model contracts for vehicle owners and you should keep it in the contract. In case the vehicle caught the damaged house without errors caused by you, then you should bring proof of receipt and a contract vehicle for vehicle owners to view. You are absolutely right to refuse compensation for the errors that you did not cause.","l14":"- Chungxe providing model contracts and guidelines on principles of conduct between tenants and all vehicle transactions take place smoothly. Vehicle owners are responsible for deciding your rental vehicle and you need to consider information about the tenants before the transaction. Chungxe will help provide information and support to the parties to work with the police when necessary.","l15":"To ensure the safety of vehicle rental, vehicle owners should:","l16":"- In case of long term lease, you should periodically ask renters about vehicle situation,","l17":"- Registration of voluntary insurance in insurance companies","l18":"- Install GPS to check the position of the vehicle regularly","l19":"- If it detects the vehicle moving to a suspicious location (borders, go beyond the expected ...) shall immediately notify Chungxe.","l20":"- If the detected GPS disconnected,notify immediately Chungxe and report local police.","l21":"- In the case of vehicles damaged during use, please guide the renter repair and pay based on vehicle rental agreement signed between the renter and owner."}},"announce":{"error_api":"An error occurred!","success_register":"Registered successfully!","error_network":"An error occurred, please try again later!","success_change_info":"Change information success!","error_login":"Your login session has expired!","success_change_pass":"Change password succeeded","error_phone1":"Please enter the phone number","error_phone2":"Phone number incorrect","error_email1":"Please enter your email","error_email2":"Email invalidate","error_name":"Please enter a name","error_address":"Please enter your address","error_promotion":"Code do not exist!","no_booking_found":"Sorry. No booking found!","mailchip":{"sending":"Sending...","error":"Your email has been registered earlier!","success":"Thank you for your interest in us!"}},"email":{"register_partner":{"subject":"Registration information partner","note1":"Information register your partner have been recorded","note2":"We will call you as soon as if possible!","content":{"name":"Unit/Partner name:","phone":"Phone number:","email":"Email:","address":"Address:","title":"Title:","content":"Content:"},"footer":{"contact":"Tel: 090 450 9596","email":"Email: contact@chungxe.vn","address":"5th Floor, 166 Pho Hue, Ngo Thi Nham, Hai Ba Trung District, Hanoi."}},"special_requirement":{"subject":"Booking information","content":{"title":"Special requirements","customer":"Customer:","phone":"Phone number:","email":"Email:","address":"Address:","requirement":"Request:"},"note":{"title":"Note:","p1":"Free trip information changes","p2":"Chungxe commitment to service\'s quality, vehicle\'s quality for trips booked in Chungxe","link1":"Frequently asked questions","link2":"Privacy policy","link3":"Add to Google calendar","link4":"Upload your profile","p3":"Uploading personal documents makes the process of renting a vehicle faster and more convenient"}},"booking":{"subject":"Booking information","note":"(Your booking request was recorded. We will contact you shortly to assist. Please provide a ticket code information when contacting us.)","content":{"book_code":"Ticket code:","create_date":"Date created:","customer":"Customer:","phone":"Phone number:","email":"Email:","number_day":"Number of rental days:","address":"Pick-up address:","rental_time":"Rental time:","return_time":"Return time:","rental_date":"Rental day:","return_date":"Drop-off day:","vhc_type":"Type of vehicle:","vhc_name":"Vehicle name:","customer_note":"Customer\'s note:","payment":"Payment methods:","payment_status":"Payment status:","price_total":"Total price:","partner_name":"Partner:"}}},"partner_form":{"title":"Register as a Partner","form":{"name_label":"Unit/Partner name *","name_placeholder":"Enter the name of units/partner ...","phone_label":"Phone number *","phone_placeholder":"Enter your phone number ...","email_label":"Email *","email_placeholder":"Enter your email address ...","address_label":"Address","address_placeholder":"Enter the address ...","title_label":"Title","title_placeholder":"Enter a title ...","content_label":"Content","content_placeholder":"Enter content ...","message_label":"Your registration information has been received. We will contact you as soon as possible.","tax_code":"Tax code","personal_label":"Personal","company_label":"Company","basic":"Tax code","personal":"Tax code/ ID vehicled","company":"Tax code/ Business registration"},"btn_register":"Registration","btn_back":"Go back to the homepage"},"partner_page":{"title":"BECOME SUPPLIER PARTNERS","description":{"p1":"Chung Xe., JSC send greeting to our Partners,","p2":"Chungxe is a platform connecting the vehicle rental company as well as individuals with idle vehicle to customers on online platforms and mobile. Customers can easily search, compare prices, rent a vehicle, pay smoothly and save cost."},"benefit":{"title":"Benefits of partnering with Chungxe","p1":"Access to a large amount of customer through ChungXe platform, - an effective sales channel","p2":"No advertising and personnel cost to maintain a website, fanpage ...","p3":"No cost to register and maintain participation at Chungxe","p4":"Only charge upon successful transaction (commission)","p5":"An effective vehicle & customers management tool.","p6":"Supported to run your own promotions program with coupon codes.","p7":"Initiative in propose vehicles, prices and procedures in the system","p8":"Grasp the information, transaction history of the customer and have full power in deciding whether or not rentable.","p9":"Introduced in the communications & marketing campaign at Chungxe"},"offer":{"title":"Propose the cooperation","p1":"Chungxe has strength in collective customers in tourism and business trips from Hanoi and Ho Chi Minh City and also the others tourist destinations in the country (Nha Trang, Phu Quoc, Da Nang, Hoi An, ...) as well as corporate customers foreign buyers need to reserve service.","p2":"Chungxe will act as an agent providing customers from online channels for vehicle rental company to supplement existing sales channels.","p3":"The lessors will pay the brokerage fees for Chungxe based on successful transactions (commissions)."},"procedure":{"title":"Process collaboration","p1":"Partners provide the information about vehicles, prices and procedures","p2":"The two sides sign cooperation agreement","p3":"Account for partners to receive bookings","p4":"When guests book a vehicle, information will be pushed into Partner\'s Email / account","p8":"At the end of each month, two sides  will check and pay based on successful transactions","p7":"After each trip, customers will provide an assessment of service experience","p6":"Partners will work with customers for the contracts, procedures, pick up/drop off time \u0303 place.","p5":"Partner guaranteed vehicle to serve customers"}},"change_info":{"title":"Change personal information","name_label":"Full name","name_placeholder":"Enter a name ...","phone_label":"Phone number","phone_placeholder":"Enter your phone number...","email_label":"Email","email_placeholder":"Enter the email ...","btn_save":"Save","btn_back":"Go back"},"upload_image":{"btn_upload":"Upload photos","preview_text":"Please select an image to preview"},"special_requirement":{"title":"Vehicle rental special request","form":{"title":"Customer\'s requirements","require_label":"Request","require_placeholder":"Enter the required ...","btn_send":"Send require"},"request_form":{"title":"Submit your request immediately to Chungxe when:","li1":"You can\'t find the vehicle you need","li2":"Other requirements","note":"We are always ready to assist you, send us a request!","note2":"If you can not find the desired vehicle? Please submit a request to us !","note3":"Booking vehicles on request","note4":"Can/\'t find the vehicle you need? Send us a request, we are always ready to assist you!","note5":"Or try to find on map"}},"info_unit_price":{"title":"PRICE AND PROCEDURES","distance":"Extra distance:","unit":"Km","price":"Extra costs:","price_message":"The vehicle delivery fee from address of Chungxe partner to address of customer will be calculated according to: <br />- Under 5 km: VND 50,000/times <br />- Over 5 km: VND 10,000/Km","unit_price":"VND","rental_date_label":"Pick up time","rental_date_placeholder":"Pick up day","return_date_label":"Drop off time","return_date_placeholder":"Drop off day","promotion":"Discount code","distance_limit":"Maximum","unit_distance":"km/day","extra":"Additional","unit_extra":"VND/km","day":"day","hour":"hour","base_price":"Base cost","extra_fee":"Extra fees weekend","deli_price":"Vehicle delivery price","unit_distance_week":"km/week","unit_distance_2week":"km/2 weeks","unit_distance_month":"km/month","unit_distance_quarter":"km/quarter","unit_distance_halfyear":"km/6 months","unit_distance_year":"km/year","unit_distance_2hours":"km/day","unit_distance_4hours":"km/day","unit_distance_8hours":"km/day","unit_distance_12hours":"km/day","unit_distance_24hours":"km/day","rental_date_error":"There are no vehicles left for the selected time period"},"loading":"Loading ...","loading_booking":"Creating your booking...","result_list":"Currently no vehicle you find ...","fetching_vehicle":"We are finding vehicle for you...","select_all":"All","select_all_seats":"All seats","select_all_transmission":"All kinds of transmission","select_all_brand":"All brands","question":{"q0":"What do I need to prepare to rent a motorcycle?","a0":"Identity vehicled (original); Driving license (original and copy); Passport (passport) if a foreigner; Deposit of VND 3,000,000 or more depending on type of vehicle.","q1":"What do I need to prepare to rent a self-driving vehicle?","a1":"Household registration book or KT3 (long-term temporary book), ID (original or copy), motorcycle and motorcycle registration document. Deposit of motorbike or cash worth VND 15,000,000 or more depending on the type of vehicle.","q2":"Can I rent a vehicle for someone else?","a2":"You can sign contracts to rent for relatives or friends. Depending on the vehicle rental partner who will ask you to add 1 to the relevant documents in the name of the vehicle rental contract.","q3":"What do I need to pay attention to when I receive a vehicle?","a3":"Check vehicleefully whether the vehicle\'s papers are still valid or not. Bring full documents, especially Driver\'s License, and Identity Card. Read vehicleefully the vehicle handover report as if there are any scratches, the actual petrol line when handing over","q4":"What should I do when I have a problem on the road?","a4":"You should call Chungxe\'s Hotline (090 450 9596) and contact the garage directly to inform and agree on the repair and payment costs based on the agreement of both parties.","q5":"What do the vehicle rental price include? Do the extra fees need to note?","a5":"Vehicle rental rates will be calculated by day and by hour. If you pay the vehicle later than the agreed time, it will be charged based on the number of hours past due or in excess of the kilometer. Vehicle rental prices for holidays or weekends are often higher than on weekdays.","q6":"How to book a vehicle on Chungxe?","a6":"You can book a vehicle via email, phone or sign up on website or app Chungxe","q7":"Chungxe leases any vehicles?","a7":"We have many lines of both motorcycles and vehicles to match the needs of customers both short and long-term lease vehicles as 4-5 seats, 7 seats, 9 seats; Automatic transmission, semi-automation transmission, manual transmission.","q8":"How payment methods can I pay with?","a8":"Transfer payment, transfer fees will be paid by the customer. Cashing. Credit vehicled payment","q9":"Do I have to pay a penalty if I cancel my booking?","a9":"You absolutely do not incur any penalty fees for canceling a deposit before the time of the performance of the vehicle rental contract (this don\'t apply vehicle rental on holidays, Tet, ...).","q10":"Is the vehicle new? Is the vehicle quality good?","a10":"Chungxe provides new vehicle models and is registered and maintenance periodically."},"social_widget":{"zalo":{"description":"Chat with us via Zalo","welcome_message":"Nice to assist you"},"phone":{"description":"Call now","modal":{"or_contact_us_by_hotline":"Or contact us by hotline","time_in_works":"Working time"}}},"deposit_pay":{"title":"Choose a payment method","method":{"group1":"Guarantee with credit card","papal_note":"(The deposit will be temporarily held for 30 days and will be automatically refunded if no additional costs arise apart from the car rental fee)","paypal":"PayPal","group2":"Guarantee with cash or bank transfer","atm":"Domestic ATM card","visa_master":"VISA / Master Card (Issued in Vietnam)","vnpay":"VNPAY e-wallet","bank":"Bank transfer","group3":"Guarantee with assets equivalent to cash","cash_note":"(e.g.: motorbike, ...)"}},"quick_pay":{"title":"Pay for your booking","title1":"Deposit Guarantee Payment","label":"Choose your payment mothod","book_code":"Booking code"},"service_highlights":"Service highlights","other_request":{"request":"VAT","personal":"Personal","company":"Business","otherreq":"Other requests (optional)","sen_tax":"Generate a VAT invoice"},"Business_vat":{"company_info":"Company information","name":"Company name","company":"Company address","tax_code":"Tax code","mail":"Billing email"}}')},98:fun