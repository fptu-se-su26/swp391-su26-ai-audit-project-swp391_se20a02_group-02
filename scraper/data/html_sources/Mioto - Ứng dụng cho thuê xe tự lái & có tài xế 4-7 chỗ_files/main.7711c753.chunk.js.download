ng v\u1edbi ch\xfang t\xf4i/kh\xe1ch h\xe0ng c\u1ee7a ch\xfang t\xf4i, ho\u1eb7c khi s\u1eed d\u1ee5ng c\xe1c s\u1ea3n ph\u1ea9m v\xe0 d\u1ecbch v\u1ee5 c\u1ee7a ch\xfang t\xf4i;"}),Object(oe.jsx)("p",{children:"- Khi t\u01b0\u01a1ng t\xe1c v\u1edbi ch\xfang t\xf4i, ch\u1eb3ng h\u1ea1n nh\u01b0 th\xf4ng qua c\xe1c cu\u1ed9c g\u1ecdi \u0111i\u1ec7n tho\u1ea1i (c\xf3 th\u1ec3 \u0111\u01b0\u1ee3c ghi \xe2m l\u1ea1i), th\u01b0 t\u1eeb, fax, g\u1eb7p g\u1ee1 tr\u1ef1c ti\u1ebfp, th\xf4ng qua t\xednh n\u0103ng giao ti\u1ebfp trong \u1ee9ng d\u1ee5ng c\u1ee7a ch\xfang t\xf4i, c\xe1c n\u1ec1n t\u1ea3ng, \u1ee9ng d\u1ee5ng truy\u1ec1n th\xf4ng x\xe3 h\u1ed9i v\xe0 email;"}),Object(oe.jsx)("p",{children:"- Khi s\u1eed d\u1ee5ng c\xe1c d\u1ecbch v\u1ee5 \u0111i\u1ec7n t\u1eed c\u1ee7a ch\xfang t\xf4i, ho\u1eb7c t\u01b0\u01a1ng t\xe1c v\u1edbi ch\xfang t\xf4i qua n\u1ec1n t\u1ea3ng ho\u1eb7c trang web ho\u1eb7c c\xe1c d\u1ecbch v\u1ee5 c\u1ee7a ch\xfang t\xf4i. Tr\u01b0\u1eddng h\u1ee3p n\xe0y bao g\u1ed3m th\xf4ng qua t\u1eadp tin cookie m\xe0 ch\xfang t\xf4i c\xf3 th\u1ec3 tri\u1ec3n khai khi t\u01b0\u01a1ng t\xe1c v\u1edbi c\xe1c n\u1ec1n t\u1ea3ng ho\u1eb7c trang web c\u1ee7a ch\xfang t\xf4i;"}),Object(oe.jsx)("p",{children:"- Khi li\xean k\u1ebft t\xe0i kho\u1ea3n Mioto v\u1edbi t\xe0i kho\u1ea3n m\u1ea1ng x\xe3 h\u1ed9i c\u1ee7a Kh\xe1ch h\xe0ng ho\u1eb7c c\xe1c t\xe0i kho\u1ea3n b\xean ngo\xe0i kh\xe1c ho\u1eb7c s\u1eed d\u1ee5ng c\xe1c t\xednh n\u0103ng m\u1ea1ng x\xe3 h\u1ed9i kh\xe1c, ph\xf9 h\u1ee3p v\u1edbi c\xe1c ch\xednh s\xe1ch c\u1ee7a nh\xe0 cung c\u1ea5p;"}),Object(oe.jsx)("p",{children:"- Khi th\u1ef1c hi\u1ec7n c\xe1c giao d\u1ecbch thanh to\xe1n ho\u1eb7c giao d\u1ecbch kh\xe1c th\xf4ng qua d\u1ecbch v\u1ee5 c\u1ee7a ch\xfang t\xf4i;"}),Object(oe.jsx)("p",{children:"- Khi cung c\u1ea5p \xfd ki\u1ebfn ph\u1ea3n h\u1ed3i ho\u1eb7c g\u1eedi khi\u1ebfu n\u1ea1i cho ch\xfang t\xf4i;"}),Object(oe.jsx)("p",{children:"- Khi g\u1eedi d\u1eef li\u1ec7u c\xe1 nh\xe2n c\u1ee7a Kh\xe1ch h\xe0ng cho ch\xfang t\xf4i v\xec b\u1ea5t k\u1ef3 l\xfd do g\xec."}),Object(oe.jsx)("p",{children:"C\xe1c tr\u01b0\u1eddng h\u1ee3p tr\xean kh\xf4ng nh\u1eb1m m\u1ee5c \u0111\xedch li\u1ec7t k\xea \u0111\u1ea7y \u0111\u1ee7 c\xe1c tr\u01b0\u1eddng h\u1ee3p v\xe0 ch\u1ec9 \u0111\u01b0a ra m\u1ed9t s\u1ed1 tr\u01b0\u1eddng h\u1ee3p ph\u1ed5 bi\u1ebfn v\u1ec1 th\u1eddi \u0111i\u1ec3m d\u1eef li\u1ec7u c\xe1 nh\xe2n c\u1ee7a Kh\xe1ch h\xe0ng c\xf3 th\u1ec3 b\u1ecb thu th\u1eadp. Trong m\u1ed9t s\u1ed1 tr\u01b0\u1eddng h\u1ee3p, Kh\xe1ch h\xe0ng c\xf3 th\u1ec3 cung c\u1ea5p D\u1eef li\u1ec7u c\xe1 nh\xe2n c\u1ee7a c\xe1c c\xe1 nh\xe2n kh\xe1c cho ch\xfang t\xf4i. Khi Kh\xe1ch h\xe0ng th\xeam h\u1ecd nh\u01b0 ng\u01b0\u1eddi li\xean h\u1ec7 kh\u1ea9n c\u1ea5p, s\u1eed d\u1ee5ng tr\xf2 chuy\u1ec7n trong \u1ee9ng d\u1ee5ng, ho\u1eb7c Kh\xe1ch h\xe0ng th\xeam h\u1ecd nh\u01b0 ng\u01b0\u1eddi th\u1ee5 h\u01b0\u1edfng b\u1ea5t k\u1ef3 vi\u1ec7c s\u1eed d\u1ee5ng d\u1ecbch v\u1ee5 c\u1ee7a ch\xfang t\xf4i. Vi\u1ec7c cung c\u1ea5p nh\u01b0 v\u1eady, Kh\xe1ch h\xe0ng cam \u0111oan v\xe0 b\u1ea3o \u0111\u1ea3m r\u1eb1ng Kh\xe1ch h\xe0ng \u0111\xe3 c\xf3 \u0111\u01b0\u1ee3c s\u1ef1 ch\u1ea5p thu\u1eadn c\u1ee7a h\u1ecd \u0111\u1ec3 d\u1eef li\u1ec7u c\xe1 nh\xe2n c\u1ee7a h\u1ecd \u0111\u01b0\u1ee3c thu th\u1eadp, s\u1eed d\u1ee5ng v\xe0 ti\u1ebft l\u1ed9 nh\u01b0 quy \u0111\u1ecbnh trong Ch\xednh s\xe1ch n\xe0y."}),Object(oe.jsx)("h6",{children:"3. Ph\u1ea1m vi, m\u1ee5c \u0111\xedch thu th\u1eadp v\xe0 s\u1eed d\u1ee5ng th\xf4ng tin"}),Object(oe.jsx)("h6",{children:"3.1. Ph\u1ea1m vi thu th\u1eadp"}),Object(oe.jsx)("p",{children:"- \u0110\u1ed1i v\u1edbi Kh\xe1ch h\xe0ng l\xe0 Ch\u1ee7 xe: H\u1ecd t\xean, email, s\u1ed1 c\u0103n c\u01b0\u1edbc c\xf4ng d\xe2n/c\u0103n c\u01b0\u1edbc, m\xe3 s\u1ed1 thu\u1ebf, s\u1ed1 \u0111i\u1ec7n tho\u1ea1i, \u0111\u1ecba ch\u1ec9 th\u01b0\u1eddng tr\xfa, \u0111\u1ecba ch\u1ec9 t\u1ea1m tr\xfa, th\xf4ng tin s\u1ed1 t\xe0i kho\u1ea3n ng\xe2n h\xe0ng v\xe0 th\xf4ng tin thanh to\xe1n, c\xe1c h\xecnh \u1ea3nh v\xe0 th\xf4ng tin v\u1ec1 s\u1ea3n ph\u1ea9m mu\u1ed1n \u0111\u0103ng t\u1ea3i tr\xean n\u1ec1n t\u1ea3ng."}),Object(oe.jsx)("p",{children:"- \u0110\u1ed1i v\u1edbi Kh\xe1ch h\xe0ng l\xe0 Kh\xe1ch thu\xea xe: H\u1ecd t\xean, email, s\u1ed1 c\u0103n c\u01b0\u1edbc c\xf4ng d\xe2n/c\u0103n c\u01b0\u1edbc, th\xf4ng tin gi\u1ea5y ph\xe9p l\xe1i xe \xf4 t\xf4, s\u1ed1 \u0111i\u1ec7n tho\u1ea1i, \u0111\u1ecba ch\u1ec9 th\u01b0\u1eddng tr\xfa, \u0111\u1ecba ch\u1ec9 t\u1ea1m tr\xfa, t\xe0i kho\u1ea3n ng\xe2n h\xe0ng v\xe0 th\xf4ng tin thanh to\xe1n \u0111\u1ec3 h\u1ed7 tr\u1ee3 qu\xe1 tr\xecnh \u0111\u1eb7t ch\u1ed7 v\u1edbi nh\xe0 cung c\u1ea5p l\xe0 \u0111\u1ed1i t\xe1c ch\u1ee7 xe c\u1ee7a ch\xfang t\xf4i, x\u1eed l\xfd y\xeau c\u1ea7u ho\xe0n ti\u1ec1n ho\u1eb7c y\xeau c\u1ea7u b\u1ea3o hi\u1ec3m v\xe0 h\u1ee7y \u0111\u1eb7t ch\u1ed7."}),Object(oe.jsx)("p",{children:"- Kh\xe1ch h\xe0ng s\u1ebd t\u1ef1 ch\u1ecbu tr\xe1ch nhi\u1ec7m v\u1ec1 b\u1ea3o m\u1eadt v\xe0 l\u01b0u gi\u1eef m\u1ecdi ho\u1ea1t \u0111\u1ed9ng s\u1eed d\u1ee5ng d\u1ecbch v\u1ee5 d\u01b0\u1edbi t\xean \u0111\u0103ng k\xfd, m\u1eadt kh\u1ea9u v\xe0 h\u1ed9p th\u01b0 \u0111i\u1ec7n t\u1eed c\u1ee7a m\xecnh. Ngo\xe0i ra, Kh\xe1ch h\xe0ng c\xf3 tr\xe1ch nhi\u1ec7m th\xf4ng b\xe1o k\u1ecbp th\u1eddi cho Mioto v\u1ec1 nh\u1eefng h\xe0nh vi s\u1eed d\u1ee5ng tr\xe1i ph\xe9p, l\u1ea1m d\u1ee5ng, vi ph\u1ea1m b\u1ea3o m\u1eadt, l\u01b0u gi\u1eef t\xean \u0111\u0103ng k\xfd v\xe0 m\u1eadt kh\u1ea9u c\u1ee7a b\xean th\u1ee9 ba \u0111\u1ec3 c\xf3 bi\u1ec7n ph\xe1p gi\u1ea3i quy\u1ebft ph\xf9 h\u1ee3p."}),Object(oe.jsx)("p",{children:"- Kh\xe1ch h\xe0ng \u0111\u1ed3ng \xfd kh\xf4ng cung c\u1ea5p cho ch\xfang t\xf4i b\u1ea5t c\u1ee9 th\xf4ng tin n\xe0o kh\xf4ng ch\xednh x\xe1c ho\u1eb7c g\xe2y hi\u1ec3u nh\u1ea7m v\xe0 Kh\xe1ch h\xe0ng \u0111\u1ed3ng \xfd s\u1ebd th\xf4ng b\xe1o cho ch\xfang t\xf4i v\u1ec1 b\u1ea5t c\u1ee9 th\xf4ng tin n\xe0o kh\xf4ng ch\xednh x\xe1c ho\u1eb7c khi c\xf3 s\u1ef1 thay \u0111\u1ed5i th\xf4ng tin."}),Object(oe.jsx)("p",{children:"- N\u1ebfu Kh\xe1ch h\xe0ng \u0111\u0103ng nh\u1eadp \u0111\u1ec3 tr\u1edf th\xe0nh ng\u01b0\u1eddi d\xf9ng c\xe1c n\u1ec1n t\u1ea3ng c\u1ee7a ch\xfang t\xf4i s\u1eed d\u1ee5ng t\xe0i kho\u1ea3n m\u1ea1ng x\xe3 h\u1ed9i (\u201cT\xe0i kho\u1ea3n M\u1ea1ng X\xe3 h\u1ed9i\u201d), li\xean k\u1ebft t\xe0i kho\u1ea3n c\u1ee7a Kh\xe1ch h\xe0ng v\u1edbi T\xe0i kho\u1ea3n M\u1ea1ng X\xe3 h\u1ed9i c\u1ee7a Kh\xe1ch h\xe0ng ho\u1eb7c s\u1eed d\u1ee5ng b\u1ea5t c\u1ee9 t\xednh n\u0103ng m\u1ea1ng x\xe3 h\u1ed9i n\xe0o, ch\xfang t\xf4i c\xf3 quy\u1ec1n truy c\u1eadp th\xf4ng tin v\u1ec1 Kh\xe1ch h\xe0ng m\xe0 Kh\xe1ch h\xe0ng \u0111\xe3 cung c\u1ea5p m\u1ed9t c\xe1ch t\u1ef1 nguy\u1ec7n cho nh\xe0 cung c\u1ea5p d\u1ecbch v\u1ee5 T\xe0i kho\u1ea3n M\u1ea1ng X\xe3 h\u1ed9i c\u1ee7a Kh\xe1ch h\xe0ng v\xe0 tu\xe2n theo c\xe1c ch\xednh s\xe1ch c\u1ee7a c\xe1c nh\xe0 cung c\u1ea5p d\u1ecbch v\u1ee5 n\xe0y, v\xe0 ch\xfang t\xf4i s\u1ebd qu\u1ea3n l\xfd v\xe0 s\u1eed d\u1ee5ng c\xe1c d\u1eef li\u1ec7u c\xe1 nh\xe2n n\xe0y c\u1ee7a Kh\xe1ch h\xe0ng theo c\xe1c quy \u0111\u1ecbnh c\u1ee7a Ch\xednh s\xe1ch n\xe0y t\u1ea1i m\u1ecdi th\u1eddi \u0111i\u1ec3m."}),Object(oe.jsx)("p",{children:"- V\u1ec1 d\u1eef li\u1ec7u nh\u1ea1y c\u1ea3m, vui l\xf2ng l\u01b0u \xfd r\u1eb1ng c\xe1c d\u1eef li\u1ec7u n\xe0y c\xf3 th\u1ec3 l\xe0 b\u1eaft bu\u1ed9c \u0111\u1ec3 th\u1ef1c hi\u1ec7n m\u1ed9t s\u1ed1 giao d\u1ecbch \u0111\u1eb7t ch\u1ed7 ho\u1eb7c \u0111\u1ec3 x\u1eed l\xfd h\u1ed3 s\u01a1 c\u1ee7a Kh\xe1ch h\xe0ng, v\xe0 ch\xfang t\xf4i c\xf3 th\u1ec3 kh\xf4ng th\u1ec3 ho\xe0n t\u1ea5t c\xe1c giao d\u1ecbch \u0111\u1eb7t ch\u1ed7 n\u1ebfu thi\u1ebfu th\xf4ng tin n\xe0y."}),Object(oe.jsx)("h6",{children:"3.2. M\u1ee5c \u0111\xedch thu th\u1eadp v\xe0 s\u1eed d\u1ee5ng th\xf4ng tin"}),Object(oe.jsx)("p",{children:"Mioto thu th\u1eadp v\xe0 s\u1eed d\u1ee5ng th\xf4ng tin c\xe1 nh\xe2n c\u1ee7a Kh\xe1ch h\xe0ng cho c\xe1c m\u1ee5c \u0111\xedch sau \u0111\xe2y:"}),Object(oe.jsx)("p",{className:"fontWeight-7",children:"Cung c\u1ea5p d\u1ecbch v\u1ee5 cho Kh\xe1ch h\xe0ng:"}),Object(oe.jsx)("p",{children:"- X\xe1c minh danh t\xednh Kh\xe1ch h\xe0ng; t\u1ea1o l\u1eadp, qu\u1ea3n l\xfd, v\u1eadn h\xe0nh, c\u1eadp nh\u1eadt v\xe0 b\u1ea3o m\u1eadt t\xe0i kho\u1ea3n tr\u1ef1c tuy\u1ebfn m\xe0 Kh\xe1ch h\xe0ng \u0111\xe3 ho\u1eb7c c\xf3 th\u1ec3 thi\u1ebft l\u1eadp tr\xean n\u1ec1n t\u1ea3ng c\u1ee7a Mioto."}),Object(oe.jsx)("p",{children:"- Li\xean h\u1ec7 x\xe1c nh\u1eadn th\xf4ng tin khi Kh\xe1ch h\xe0ng \u0111\u0103ng k\xfd v\xe0 s\u1eed d\u1ee5ng d\u1ecbch v\u1ee5 tr\xean n\u1ec1n t\u1ea3ng nh\u1eb1m \u0111\u1ea3m b\u1ea3o quy\u1ec1n v\xe0 l\u1ee3i \xedch h\u1ee3p ph\xe1p c\u1ee7a Kh\xe1ch h\xe0ng."}),Object(oe.jsx)("p",{children:"- H\u1ed7 tr\u1ee3 vi\u1ec7c \u0111\u1eb7t xe, cung c\u1ea5p xe v\xe0 c\xe1c d\u1ecbch v\u1ee5 li\xean quan cho Kh\xe1ch h\xe0ng."}),Object(oe.jsx)("p",{children:"- X\u1eed l\xfd c\xe1c \u0111\u01a1n \u0111\u1eb7t h\xe0ng, y\xeau c\u1ea7u giao d\u1ecbch v\xe0 c\xe1c ho\u1ea1t \u0111\u1ed9ng ph\xe1t sinh t\u1eeb vi\u1ec7c Kh\xe1ch h\xe0ng s\u1eed d\u1ee5ng n\u1ec1n t\u1ea3ng."}),Object(oe.jsx)("p",{children:"- Cung c\u1ea5p c\xe1c s\u1ea3n ph\u1ea9m, d\u1ecbch v\u1ee5 theo nhu c\u1ea7u c\u1ee7a Kh\xe1ch h\xe0ng th\xf4ng qua n\u1ec1n t\u1ea3ng Mioto."}),Object(oe.jsx)("p",{children:"- N\xe2ng cao ch\u1ea5t l\u01b0\u1ee3ng s\u1ea3n ph\u1ea9m, d\u1ecbch v\u1ee5 v\xe0 tr\u1ea3i nghi\u1ec7m ng\u01b0\u1eddi d\xf9ng m\xe0 Mioto cung c\u1ea5p."}),Object(oe.jsx)("p",{children:"- Li\xean h\u1ec7 \u0111\u1ec3 ti\u1ebfp nh\u1eadn, x\u1eed l\xfd v\xe0 ph\u1ea3n h\u1ed3i c\xe1c y\xeau c\u1ea7u, th\u1eafc m\u1eafc, khi\u1ebfu n\u1ea1i, tranh ch\u1ea5p c\u1ee7a Kh\xe1ch h\xe0ng, tr\u1ef1c ti\u1ebfp ho\u1eb7c th\xf4ng qua b\xean th\u1ee9 ba cung c\u1ea5p d\u1ecbch v\u1ee5 ch\u0103m s\xf3c kh\xe1ch h\xe0ng \u0111\u01b0\u1ee3c Mioto \u1ee7y quy\u1ec1n h\u1ee3p ph\xe1p."}),Object(oe.jsx)("p",{children:"- Th\u1ef1c hi\u1ec7n c\xe1c ho\u1ea1t \u0111\u1ed9ng n\u1ed9i b\u1ed9 c\u1ea7n thi\u1ebft \u0111\u1ec3 duy tr\xec, v\u1eadn h\xe0nh v\xe0 cung c\u1ea5p d\u1ecbch v\u1ee5, bao g\u1ed3m nh\u01b0ng kh\xf4ng gi\u1edbi h\u1ea1n \u1edf vi\u1ec7c kh\u1eafc ph\u1ee5c l\u1ed7i k\u1ef9 thu\u1eadt, l\u1ed7i ph\u1ea7n m\u1ec1m v\xe0 s\u1ef1 c\u1ed1 v\u1eadn h\xe0nh."}),Object(oe.jsx)("p",{children:"- Ng\u0103n ch\u1eb7n, \u0111i\u1ec1u tra v\xe0 x\u1eed l\xfd c\xe1c h\xe0nh vi gian l\u1eadn, h\xe0nh vi vi ph\u1ea1m \u0110i\u1ec1u kho\u1ea3n d\u1ecbch v\u1ee5, h\xe0nh vi tr\xe1i ph\xe1p lu\u1eadt, thi\u1ebfu s\xf3t ho\u1eb7c h\xe0nh vi sai tr\xe1i kh\xe1c, cho d\xf9 c\xf3 ho\u1eb7c kh\xf4ng ph\xe1t sinh t\u1eeb vi\u1ec7c Kh\xe1ch h\xe0ng s\u1eed d\u1ee5ng d\u1ecbch v\u1ee5 c\u1ee7a Mioto."}),Object(oe.jsx)("p",{className:"fontWeight-7",children:"Ph\u1ed1i h\u1ee3p v\u1edbi \u0111\u1ea1i l\xfd/\u0111\u01a1n v\u1ecb b\u1ea3o hi\u1ec3m trong ph\u1ea1m vi c\u1ea7n thi\u1ebft \u0111\u1ec3 cung c\u1ea5p d\u1ecbch v\u1ee5 cho Kh\xe1ch h\xe0ng."}),Object(oe.jsx)("p",{children:"- K\u1ebft n\u1ed1i Kh\xe1ch h\xe0ng v\u1edbi \u0111\u1ea1i l\xfd/\u0111\u01a1n v\u1ecb b\u1ea3o hi\u1ec3m \u0111\u1ec3 cung c\u1ea5p h\u1ee3p \u0111\u1ed3ng b\u1ea3o hi\u1ec3m trong qu\xe1 tr\xecnh s\u1eed d\u1ee5ng d\u1ecbch v\u1ee5 thu\xea xe."}),Object(oe.jsx)("p",{children:"- H\u1ed7 tr\u1ee3 vi\u1ec7c x\xe1c l\u1eadp, duy tr\xec v\xe0 th\u1ef1c hi\u1ec7n h\u1ee3p \u0111\u1ed3ng b\u1ea3o hi\u1ec3m gi\u1eefa Kh\xe1ch h\xe0ng v\xe0 \u0111\u01a1n v\u1ecb b\u1ea3o hi\u1ec3m;"}),Object(oe.jsx)("p",{children:"- Ti\u1ebfp nh\u1eadn, x\xe1c minh v\xe0 x\u1eed l\xfd th\xf4ng tin v\u1ec1 s\u1ef1 c\u1ed1, tai n\u1ea1n, h\u01b0 h\u1ecfng xe \u0111\u1ec3 ph\u1ee5c v\u1ee5 gi\xe1m \u0111\u1ecbnh, b\u1ed3i th\u01b0\u1eddng b\u1ea3o hi\u1ec3m;"}),Object(oe.jsx)("p",{children:"- H\u1ed7 tr\u1ee3 gi\u1ea3i quy\u1ebft khi\u1ebfu n\u1ea1i, tranh ch\u1ea5p li\xean quan \u0111\u1ebfn b\u1ea3o hi\u1ec3m ph\xe1t sinh trong qu\xe1 tr\xecnh s\u1eed d\u1ee5ng d\u1ecbch v\u1ee5."}),Object(oe.jsx)("p",{children:"- Vi\u1ec7c x\u1eed l\xfd v\xe0 chia s\u1ebb d\u1eef li\u1ec7u c\xe1 nh\xe2n \u0111\u01b0\u1ee3c th\u1ef1c hi\u1ec7n tr\xean c\u01a1 s\u1edf s\u1ef1 \u0111\u1ed3ng \xfd c\u1ee7a Kh\xe1ch h\xe0ng, ph\xf9 h\u1ee3p v\u1edbi m\u1ee5c \u0111\xedch \u0111\xe3 th\xf4ng b\xe1o, trong ph\u1ea1m vi c\u1ea7n thi\u1ebft v\xe0 tu\xe2n th\u1ee7 quy \u0111\u1ecbnh ph\xe1p lu\u1eadt v\u1ec1 b\u1ea3o v\u1ec7 d\u1eef li\u1ec7u c\xe1 nh\xe2n."}),Object(oe.jsx)("p",{className:"fontWeight-7",children:"Qu\u1ea3ng c\xe1o c\xe1c d\u1ecbch v\u1ee5 v\xe0 ho\u1ea1t \u0111\u1ed9ng th\u01b0\u01a1ng m\u1ea1i kh\xe1c ph\xf9 h\u1ee3p nhu c\u1ea7u c\u1ee7a Kh\xe1ch h\xe0ng:"}),Object(oe.jsx)("p",{children:"- G\u1eedi th\xf4ng b\xe1o li\xean quan \u0111\u1ebfn qu\xe1 tr\xecnh trao \u0111\u1ed5i th\xf4ng tin gi\u1eefa Kh\xe1ch h\xe0ng v\xe0 Mioto, bao g\u1ed3m nh\u01b0ng kh\xf4ng gi\u1edbi h\u1ea1n \u1edf c\xe1c ch\u01b0\u01a1ng tr\xecnh khuy\u1ebfn m\u1ea1i, kh\u1ea3o s\xe1t \xfd ki\u1ebfn, ho\u1ea1t \u0111\u1ed9ng ti\u1ebfp th\u1ecb v\xe0 qu\u1ea3ng c\xe1o s\u1ea3n ph\u1ea9m, d\u1ecbch v\u1ee5."}),Object(oe.jsx)("p",{children:"- Th\u1ef1c hi\u1ec7n ho\u1ea1t \u0111\u1ed9ng qu\u1ea3ng c\xe1o, gi\u1edbi thi\u1ec7u s\u1ea3n ph\u1ea9m, h\xe0ng h\xf3a, d\u1ecbch v\u1ee5 v\xe0 c\xe1c ho\u1ea1t \u0111\u1ed9ng th\u01b0\u01a1ng m\u1ea1i kh\xe1c ph\xf9 h\u1ee3p v\u1edbi nhu c\u1ea7u c\u1ee7a Kh\xe1ch h\xe0ng ho\u1eb7c theo \u0111\xe1nh gi\xe1 c\u1ee7a Mioto l\xe0 Kh\xe1ch h\xe0ng c\xf3 th\u1ec3 quan t\xe2m."}),Object(oe.jsx)("p",{className:"fontWeight-7",children:"Th\u1ef1c hi\u1ec7n c\xe1c ngh\u0129a v\u1ee5 c\u1ee7a Mioto theo quy \u0111\u1ecbnh ph\xe1p lu\u1eadt:"}),Object(oe.jsx)("p",{children:"- Th\u1ef1c hi\u1ec7n c\xe1c quy tr\xecnh t\xecm hi\u1ec3u, x\xe1c minh, s\xe0ng l\u1ecdc (bao g\u1ed3m nh\u01b0ng kh\xf4ng gi\u1edbi h\u1ea1n \u1edf vi\u1ec7c ki\u1ec3m tra l\xfd l\u1ecbch) nh\u1eb1m tu\xe2n th\u1ee7 c\xe1c ngh\u0129a v\u1ee5 theo quy \u0111\u1ecbnh ph\xe1p lu\u1eadt, y\xeau c\u1ea7u c\u1ee7a c\u01a1 quan nh\xe0 n\u01b0\u1edbc c\xf3 th\u1ea9m quy\u1ec1n ho\u1eb7c theo c\xe1c th\u1ee7 t\u1ee5c qu\u1ea3n l\xfd r\u1ee7i ro n\u1ed9i b\u1ed9 c\u1ee7a Mioto."}),Object(oe.jsx)("p",{children:"- L\u1eadp d\u1eef li\u1ec7u th\u1ed1ng k\xea, ph\xe2n t\xedch, nghi\xean c\u1ee9u nh\u1eb1m ph\u1ee5c v\u1ee5 c\xf4ng t\xe1c b\xe1o c\xe1o, qu\u1ea3n l\xfd n\u1ed9i b\u1ed9 v\xe0/ho\u1eb7c \u0111\xe1p \u1ee9ng y\xeau c\u1ea7u theo quy \u0111\u1ecbnh c\u1ee7a ph\xe1p lu\u1eadt."}),Object(oe.jsx)("p",{children:"- Tr\u01b0\u1eddng h\u1ee3p c\xf3 y\xeau c\u1ea7u h\u1ee3p ph\xe1p t\u1eeb c\u01a1 quan nh\xe0 n\u01b0\u1edbc c\xf3 th\u1ea9m quy\u1ec1n, Mioto c\xf3 tr\xe1ch nhi\u1ec7m h\u1ee3p t\xe1c v\xe0 cung c\u1ea5p th\xf4ng tin c\xe1 nh\xe2n c\u1ee7a Kh\xe1ch h\xe0ng theo \u0111\xfang quy \u0111\u1ecbnh, bao g\u1ed3m nh\u01b0ng kh\xf4ng gi\u1edbi h\u1ea1n \u1edf y\xeau c\u1ea7u t\u1eeb c\u01a1 quan thu\u1ebf, t\xf2a \xe1n, vi\u1ec7n ki\u1ec3m s\xe1t ho\u1eb7c c\u01a1 quan c\xf4ng an; ngo\xe0i c\xe1c tr\u01b0\u1eddng h\u1ee3p n\xe0y, kh\xf4ng t\u1ed5 ch\u1ee9c ho\u1eb7c c\xe1 nh\xe2n n\xe0o \u0111\u01b0\u1ee3c ph\xe9p x\xe2m ph\u1ea1m th\xf4ng tin c\xe1 nh\xe2n c\u1ee7a Kh\xe1ch h\xe0ng."}),Object(oe.jsx)("p",{children:"- B\u1ea3o v\u1ec7 quy\u1ec1n, l\u1ee3i \xedch h\u1ee3p ph\xe1p, t\xe0i s\u1ea3n c\u1ee7a Mioto v\xe0 c\xe1c \u0111\u1ed1i t\xe1c li\xean quan; vi\u1ec7c cung c\u1ea5p th\xf4ng tin c\xe1 nh\xe2n c\u1ee7a Kh\xe1ch h\xe0ng (n\u1ebfu c\xf3) ch\u1ec9 \u0111\u01b0\u1ee3c th\u1ef1c hi\u1ec7n trong ph\u1ea1m vi c\u1ea7n thi\u1ebft v\xe0 ph\xf9 h\u1ee3p v\u1edbi quy \u0111\u1ecbnh ph\xe1p lu\u1eadt Vi\u1ec7t Nam."}),Object(oe.jsx)("p",{children:"- Ng\u0103n ng\u1eeba, ph\xe1t hi\u1ec7n v\xe0 x\u1eed l\xfd c\xe1c h\xe0nh vi x\xe2m nh\u1eadp tr\xe1i ph\xe9p, gi\u1ea3 m\u1ea1o, ph\xe1 ho\u1ea1i t\xe0i kho\u1ea3n Kh\xe1ch h\xe0ng ho\u1eb7c c\xe1c h\xe0nh vi \u1ea3nh h\u01b0\u1edfng \u0111\u1ebfn an to\xe0n, b\u1ea3o m\u1eadt c\u1ee7a n\u1ec1n t\u1ea3ng."}),Object(oe.jsx)("h6",{children:"4. S\u1ef1 \u0111\u1ed3ng \xfd v\xe0 r\xfat l\u1ea1i s\u1ef1 \u0111\u1ed3ng \xfd cho ph\xe9p thu th\u1eadp, x\u1eed l\xfd d\u1eef li\u1ec7u c\xe1 nh\xe2n"}),Object(oe.jsx)("p",{children:"Vi\u1ec7c Mioto thu th\u1eadp, s\u1eed d\u1ee5ng, ti\u1ebft l\u1ed9 v\xe0 x\u1eed l\xfd d\u1eef li\u1ec7u c\xe1 nh\xe2n c\u1ee7a Kh\xe1ch h\xe0ng \u0111\u01b0\u1ee3c th\u1ef1c hi\u1ec7n tr\xean c\u01a1 s\u1edf c\xf3 c\u0103n c\u1ee9 ph\xe1p l\xfd h\u1ee3p l\u1ec7, bao g\u1ed3m nh\u01b0ng kh\xf4ng gi\u1edbi h\u1ea1n \u1edf: (i) s\u1ef1 \u0111\u1ed3ng \xfd c\u1ee7a Kh\xe1ch h\xe0ng; (ii) ngh\u0129a v\u1ee5 ph\xe1p l\xfd m\xe0 Mioto ph\u1ea3i th\u1ef1c hi\u1ec7n theo quy \u0111\u1ecbnh ph\xe1p lu\u1eadt; (iii) vi\u1ec7c th\u1ef1c hi\u1ec7n h\u1ee3p \u0111\u1ed3ng m\xe0 Kh\xe1ch h\xe0ng l\xe0 m\u1ed9t b\xean; ho\u1eb7c (iv) c\xe1c c\u0103n c\u1ee9 h\u1ee3p ph\xe1p kh\xe1c theo quy \u0111\u1ecbnh c\u1ee7a ph\xe1p lu\u1eadt v\u1ec1 b\u1ea3o v\u1ec7 d\u1eef li\u1ec7u c\xe1 nh\xe2n."}),Object(oe.jsx)("p",{children:"S\u1ef1 \u0111\u1ed3ng \xfd c\u1ee7a Kh\xe1ch h\xe0ng (trong tr\u01b0\u1eddng h\u1ee3p ph\xe1p lu\u1eadt y\xeau c\u1ea7u ph\u1ea3i c\xf3 s\u1ef1 \u0111\u1ed3ng \xfd) \u0111\u01b0\u1ee3c th\u1ec3 hi\u1ec7n m\u1ed9t c\xe1ch r\xf5 r\xe0ng, c\u1ee5 th\u1ec3 v\xe0 c\xf3 th\u1ec3 ch\u1ee9ng minh, th\xf4ng qua m\u1ed9t ho\u1eb7c nhi\u1ec1u h\xecnh th\u1ee9c sau, t\xf9y t\u1eebng m\u1ee5c \u0111\xedch x\u1eed l\xfd d\u1eef li\u1ec7u: (i) H\xe0nh vi t\xedch ch\u1ecdn, x\xe1c nh\u1eadn \u0111i\u1ec7n t\u1eed tr\xean n\u1ec1n t\u1ea3ng c\u1ee7a Mioto; (ii) K\xfd k\u1ebft h\u1ee3p \u0111\u1ed3ng, th\u1ecfa thu\u1eadn, v\u0103n b\u1ea3n ch\u1ea5p thu\u1eadn; (iii) X\xe1c nh\u1eadn th\xf4ng qua ph\u01b0\u01a1ng ti\u1ec7n \u0111i\u1ec7n t\u1eed, \u1ee9ng d\u1ee5ng, email ho\u1eb7c h\xecnh th\u1ee9c t\u01b0\u01a1ng \u0111\u01b0\u01a1ng kh\xe1c theo quy \u0111\u1ecbnh ph\xe1p lu\u1eadt."}),Object(oe.jsx)("p",{children:"\u0110\u1ed1i v\u1edbi t\u1eebng m\u1ee5c \u0111\xedch x\u1eed l\xfd d\u1eef li\u1ec7u c\xe1 nh\xe2n kh\xf4ng b\u1eaft bu\u1ed9c theo quy \u0111\u1ecbnh ph\xe1p lu\u1eadt, Mioto ch\u1ec9 th\u1ef1c hi\u1ec7n sau khi c\xf3 s\u1ef1 \u0111\u1ed3ng \xfd h\u1ee3p l\u1ec7 c\u1ee7a Kh\xe1ch h\xe0ng. Trong nhi\u1ec1u tr\u01b0\u1eddng h\u1ee3p, vi\u1ec7c kh\xe1ch h\xe0ng t\u1eeb ch\u1ed1i cung c\u1ea5p ho\u1eb7c cung c\u1ea5p kh\xf4ng \u0111\u1ea7y \u0111\u1ee7, kh\xf4ng ch\xednh x\xe1c d\u1eef li\u1ec7u c\xe1 nh\xe2n c\u1ee7a kh\xe1ch h\xe0ng c\xf3 th\u1ec3 xem l\xe0 h\xe0nh vi vi ph\u1ea1m ngh\u0129a v\u1ee5 ph\xe1p l\xfd v\u1ec1 vi\u1ec7c cung c\u1ea5p d\u1eef li\u1ec7u c\xe1 nh\xe2n, v\xe0 c\xf3 th\u1ec3 d\u1eabn \u0111\u1ebfn Mioto kh\xf4ng th\u1ec3 h\u1ee3p t\xe1c v\u1edbi Kh\xe1ch h\xe0ng \u0111\u1ec3 cung c\u1ea5p s\u1ea3n ph\u1ea9m, d\u1ecbch v\u1ee5 ho\u1eb7c kh\xf4ng th\u1ec3 cung c\u1ea5p s\u1ea3n ph\u1ea9m, d\u1ecbch v\u1ee5 m\u1ed9t c\xe1ch \u0111\u1ea7y \u0111\u1ee7 v\xe0 ch\u1ea5t l\u01b0\u1ee3ng theo tuy\xean b\u1ed1."}),Object(oe.jsxs)("p",{children:["\u0110\u1ed1i v\u1edbi m\u1ee5c \u0111\xedch ti\u1ebfp th\u1ecb v\xe0 qu\u1ea3ng c\xe1o, Mioto s\u1ebd ch\u1ec9 g\u1eedi th\xf4ng tin qu\u1ea3ng c\xe1o khi Kh\xe1ch h\xe0ng \u0111\xe3 ch\u1ee7 \u0111\u1ed9ng t\xedch ch\u1ecdn (opt-in) \u0111\u1ed3ng \xfd nh\u1eadn. Kh\xe1ch h\xe0ng c\xf3 th\u1ec3 t\u1eeb ch\u1ed1i nh\u1eadn th\xf4ng tin ti\u1ebfp th\u1ecb b\u1ea5t k\u1ef3 l\xfac n\xe0o b\u1eb1ng c\xe1ch: (i) t\u1eaft th\xf4ng b\xe1o trong m\u1ee5c C\xe1 nh\xe2n >> Ch\xednh s\xe1ch b\u1ea3o v\u1ec7 d\u1eef li\u1ec7u tr\xean \u1ee9ng d\u1ee5ng Mioto; ho\u1eb7c (iii) li\xean h\u1ec7 tr\u1ef1c ti\u1ebfp v\u1edbi ch\xfang t\xf4i qua email: ",re.h,". Vi\u1ec7c t\u1eeb ch\u1ed1i nh\u1eadn th\xf4ng tin ti\u1ebfp th\u1ecb kh\xf4ng \u1ea3nh h\u01b0\u1edfng \u0111\u1ebfn quy\u1ec1n s\u1eed d\u1ee5ng d\u1ecbch v\u1ee5 c\u1ee7a Kh\xe1ch h\xe0ng."]}),Object(oe.jsx)("p",{children:"Kh\xe1ch h\xe0ng c\xf3 quy\u1ec1n y\xeau c\u1ea7u r\xfat l\u1ea1i s\u1ef1 \u0111\u1ed3ng \xfd cho ph\xe9p x\u1eed l\xfd d\u1eef li\u1ec7u c\xe1 nh\xe2n, y\xeau c\u1ea7u h\u1ea1n ch\u1ebf x\u1eed l\xfd d\u1eef li\u1ec7u c\xe1 nh\xe2n c\u1ee7a m\xecnh ho\u1eb7c y\xeau c\u1ea7u Mioto x\xf3a d\u1eef li\u1ec7u c\xe1 nh\xe2n c\u1ee7a Kh\xe1ch h\xe0ng b\u1eb1ng vi\u1ec7c g\u1eedi th\xf4ng b\xe1o b\u1eb1ng v\u0103n b\u1ea3n cho Mioto. Tuy nhi\xean, Kh\xe1ch h\xe0ng l\u01b0u \xfd r\u1eb1ng vi\u1ec7c th\u1ef1c hi\u1ec7n y\xeau c\u1ea7u c\u1ea7u r\xfat l\u1ea1i s\u1ef1 \u0111\u1ed3ng \xfd, y\xeau c\u1ea7u h\u1ea1n ch\u1ebf x\u1eed l\xfd d\u1eef li\u1ec7u kh\xf4ng \xe1p d\u1ee5ng \u0111\u1ed1i v\u1edbi ho\u1ea1t \u0111\u1ed9ng x\u1eed l\xfd d\u1eef li\u1ec7u c\u1ee7a Kh\xe1ch h\xe0ng tr\u01b0\u1edbc th\u1eddi \u0111i\u1ec3m Kh\xe1ch h\xe0ng y\xeau c\u1ea7u r\xfat l\u1ea1i s\u1ef1 \u0111\u1ed3ng \xfd ho\u1eb7c y\xeau c\u1ea7u h\u1ea1n ch\u1ebf x\u1eed l\xfd d\u1eef li\u1ec7u c\xe1 nh\xe2n, \u0111\u1ed3ng th\u1eddi d\u1eef li\u1ec7u c\xe1 nh\xe2n c\u1ee7a kh\xe1ch h\xe0ng c\xf3 th\u1ec3 v\u1eabn s\u1ebd ti\u1ebfp t\u1ee5c \u0111\u01b0\u1ee3c l\u01b0u tr\u1eef theo quy \u0111\u1ecbnh c\u1ee7a ph\xe1p lu\u1eadt hi\u1ec7n h\xe0nh."}),Object(oe.jsx)("h6",{children:"5. Chia s\u1ebb d\u1eef li\u1ec7u c\xe1 nh\xe2n c\u1ee7a Kh\xe1ch h\xe0ng"}),Object(oe.jsx)("p",{children:"Trong m\u1ed9t s\u1ed1 tr\u01b0\u1eddng h\u1ee3p, ch\xfang t\xf4i c\u1ea7n chia s\u1ebb d\u1eef li\u1ec7u c\xe1 nh\xe2n c\u1ee7a Kh\xe1ch h\xe0ng v\u1edbi c\xe1c b\xean li\xean quan nh\u1eb1m ph\u1ee5c v\u1ee5 cho vi\u1ec7c cung c\u1ea5p d\u1ecbch v\u1ee5 c\u1ee7a ch\xfang t\xf4i. Vi\u1ec7c chia s\u1ebb n\xe0y c\xf3 th\u1ec3 bao g\u1ed3m vi\u1ec7c chuy\u1ec3n giao ho\u1eb7c ti\u1ebft l\u1ed9 d\u1eef li\u1ec7u trong n\u1ed9i b\u1ed9 Mioto v\xe0 v\u1edbi c\xe1c b\xean th\u1ee9 ba:"}),Object(oe.jsx)("p",{children:"- N\u1ebfu Kh\xe1ch h\xe0ng l\xe0 ch\u1ee7 xe, ch\xfang t\xf4i c\xf3 th\u1ec3 chia s\u1ebb t\xean t\xe0i kho\u1ea3n ng\u01b0\u1eddi d\xf9ng, th\xf4ng tin s\u1ed1 \u0111i\u1ec7n tho\u1ea1i, th\xf4ng tin ph\u01b0\u01a1ng ti\u1ec7n, \u0111\u1ecba \u0111i\u1ec3m xe v\u1edbi Kh\xe1ch h\xe0ng l\xe0 kh\xe1ch thu\xea xe; ch\xfang t\xf4i c\xf3 th\u1ec3 chia s\u1ebb th\xf4ng tin ph\u01b0\u01a1ng ti\u1ec7n ho\u1eb7c c\xe1c th\xf4ng tin c\xe1 nh\xe2n kh\xe1c cho \u0111\u1ea1i l\xfd/c\xf4ng ty b\u1ea3o hi\u1ec3m v\xe0/ho\u1eb7c \u0111\u1ebfn c\xe1c kh\xe1ch thu\xea xe cho m\u1ee5c \u0111\xedch khi\u1ebfu n\u1ea1i b\u1ea3o hi\u1ec3m;"}),Object(oe.jsx)("p",{children:"- N\u1ebfu Kh\xe1ch h\xe0ng l\xe0 kh\xe1ch thu\xea xe, ch\xfang t\xf4i c\xf3 th\u1ec3 chia s\u1ebb t\xean t\xe0i kho\u1ea3n ng\u01b0\u1eddi d\xf9ng, th\xf4ng tin s\u1ed1 \u0111i\u1ec7n tho\u1ea1i, th\xf4ng tin gi\u1ea5y ph\xe9p l\xe1i xe, \u0111\u1ecba \u0111i\u1ec3m giao/nh\u1eadn xe v\u1edbi ch\u1ee7 xe, \u0111\u1ea1i l\xfd/c\xf4ng ty b\u1ea3o hi\u1ec3m;"}),Object(oe.jsx)("p",{children:"- N\u1ebfu Kh\xe1ch h\xe0ng \u0111\u1ec3 l\u1ea1i x\u1ebfp h\u1ea1ng v\xe0 \u0111\xe1nh gi\xe1 cho b\u1ea5t k\u1ef3 \u0111\u1ed1i t\xe1c ch\u1ee7 xe/kh\xe1ch thu\xea n\xe0o, \u1ea3nh h\u1ed3 s\u01a1, ph\u1ea3n h\u1ed3i, n\u1ed9i dung v\xe0 t\xean ng\u01b0\u1eddi d\xf9ng c\u1ee7a Kh\xe1ch h\xe0ng c\xf3 th\u1ec3 \u0111\u01b0\u1ee3c hi\u1ec3n th\u1ecb c\xf4ng khai cho c\u1ed9ng \u0111\u1ed3ng v\xe0 nh\u1eefng ng\u01b0\u1eddi d\xf9ng kh\xe1c;"}),Object(oe.jsx)("p",{children:"- N\u1ebfu Kh\xe1ch h\xe0ng s\u1eed d\u1ee5ng d\u1ecbch v\u1ee5 tr\xf2 chuy\u1ec7n trong \u1ee9ng d\u1ee5ng c\u1ee7a ch\xfang t\xf4i, ch\xfang t\xf4i c\xf3 th\u1ec3 chia s\u1ebb t\xean t\xe0i kho\u1ea3n v\xe0 \u1ea3nh h\u1ed3 s\u01a1 c\u1ee7a Kh\xe1ch h\xe0ng v\u1edbi c\xe1c b\xean tham gia tr\xf2 chuy\u1ec7n c\xf2n l\u1ea1i;"}),Object(oe.jsx)("p",{children:"- N\u1ebfu Kh\xe1ch h\xe0ng s\u1eed d\u1ee5ng d\u1ecbch v\u1ee5 thanh to\xe1n, ch\xfang t\xf4i c\xf3 th\u1ec3 chia s\u1ebb d\u1eef li\u1ec7u c\xe1 nh\xe2n c\u1ee7a Kh\xe1ch h\xe0ng v\u1edbi m\u1ed9t c\xe1c nh\xe2n kh\xe1c n\u1ebfu Kh\xe1ch h\xe0ng \u1ee7y quy\u1ec1n v\xe0 cho ph\xe9p k\u1ebft n\u1ed1i ph\u01b0\u01a1ng th\u1ee9c thanh to\xe1n d\u1ecbch v\u1ee5 b\xean th\u1ee9 ba v\u1edbi d\u1ecbch v\u1ee5 thanh to\xe1n c\u1ee7a ch\xfang t\xf4i nh\u1eb1m m\u1ee5c \u0111\xedch cho ph\xe9p Kh\xe1ch h\xe0ng thanh to\xe1n tr\xean Mioto;"}),Object(oe.jsx)("p",{children:"- \u0110\u1ed1i t\xe1c kinh doanh, nh\xe0 qu\u1ea3n l\xfd k\xeanh ph\xe2n ph\u1ed1i, trung gian ho\u1eb7c c\xe1c \u0111\u01a1n v\u1ecb k\u1ebft n\u1ed1i kh\xe1c tham gia ph\xe2n ph\u1ed1i d\u1ecbch v\u1ee5 c\u1ee7a ch\xfang t\xf4i, bao g\u1ed3m vi\u1ec7c k\u1ebft n\u1ed1i v\xe0 qu\u1ea3n l\xfd \u0111\u1eb7t ch\u1ed7 c\u1ee7a Kh\xe1ch h\xe0ng v\u1edbi ch\u1ee7 xe/kh\xe1ch thu\xea hay c\xe1c \u0111\u01a1n v\u1ecb d\u1ecbch v\u1ee5 kh\xe1c;"}),Object(oe.jsx)("p",{children:"- C\u01a1 quan ch\xednh ph\u1ee7 v\xe0 c\u01a1 quan gi\xe1m s\xe1t nh\u1eb1m tu\xe2n th\u1ee7 c\xe1c ngh\u0129a v\u1ee5 b\xe1o c\xe1o theo quy \u0111\u1ecbnh ph\xe1p lu\u1eadt v\xe0 c\xe1c y\xeau c\u1ea7u cung c\u1ea5p d\u1eef li\u1ec7u t\u1eeb c\xe1c c\u01a1 quan ch\u1ee9c n\u0103ng (\u1edf \u0111\u1ecba ph\u01b0\u01a1ng), bao g\u1ed3m c\u1ea3 c\u01a1 quan thu\u1ebf v\xe0 c\u01a1 quan t\u01b0 ph\xe1p/\u0111i\u1ec1u tra nh\u01b0 c\xf4ng an, vi\u1ec7n ki\u1ec3m s\xe1t, t\xf2a \xe1n v\xe0 c\xe1c t\u1ed5 ch\u1ee9c tr\u1ecdng t\xe0i/h\xf2a gi\u1ea3i. Vi\u1ec7c n\xe0y c\xf3 th\u1ec3 \u0111\u01b0\u1ee3c th\u1ef1c hi\u1ec7n \u0111\u1ec3 ho\xe0n th\xe0nh m\u1ee5c \u0111\xedch ph\xe1p l\xfd ho\u1eb7c b\u1ea5t k\xec tr\u01b0\u1eddng h\u1ee3p n\xe0o, v\xed d\u1ee5: khi \u0111i\u1ec1u n\xe0y l\xe0 c\u1ea7n thi\u1ebft \u0111\u1ec3 ph\u1ea3n \u1ee9ng v\u1edbi m\u1ed9t t\xecnh hu\u1ed1ng kh\u1ea9n c\u1ea5p \u0111e d\u1ecda t\xednh m\u1ea1ng, s\u1ee9c kh\u1ecfe ho\u1eb7c s\u1ef1 an to\xe0n c\u1ee7a m\u1ed9t th\u1ef1c th\u1ec3 ho\u1eb7c khi \u0111i\u1ec1u n\xe0y l\xe0 c\u1ea7n thi\u1ebft cho l\u1ee3i \xedch c\xf4ng c\u1ed9ng;"}),Object(oe.jsx)("p",{children:"- Nh\xe0 cung c\u1ea5p d\u1ecbch v\u1ee5 v\xe0 c\xe1c b\xean th\u1ee9 ba kh\xe1c h\u1ed7 tr\u1ee3 ch\xfang t\xf4i trong ho\u1ea1t \u0111\u1ed9ng kinh doanh h\xe0ng ng\xe0y nh\u01b0 h\u1ea1 t\u1ea7ng \u0111i\u1ec7n to\xe1n \u0111\xe1m m\xe2y, h\u1ed7 tr\u1ee3 Kh\xe1ch h\xe0ng v\xe0 li\xean l\u1ea1c, ph\xe1t hi\u1ec7n v\xe0 ph\xf2ng ch\u1ed1ng gian l\u1eadn, x\u1eed l\xfd y\xeau c\u1ea7u b\u1ea3o hi\u1ec3m, v\xe0 c\xe1c t\u1ed5 ch\u1ee9c t\xe0i ch\xednh h\u1ed7 tr\u1ee3 Kh\xe1ch h\xe0ng trong m\u1ed9t s\u1ed1 quy tr\xecnh thanh to\xe1n ho\u1eb7c cung c\u1ea5p d\u1ecbch v\u1ee5 t\xe0i ch\xednh cho ch\xfang t\xf4i;"}),Object(oe.jsx)("p",{children:"- C\xe1c b\xean chuy\xean m\xf4n kh\xe1c nh\u01b0 c\xf4ng ty lu\u1eadt ho\u1eb7c ki\u1ec3m to\xe1n vi\xean. D\u1eef li\u1ec7u c\xe1 nh\xe2n c\u1ee7a Kh\xe1ch h\xe0ng ch\u1ec9 \u0111\u01b0\u1ee3c chia s\u1ebb trong ph\u1ea1m vi c\u1ea7n thi\u1ebft v\xe0 c\xe1c b\xean th\u1ee9 ba n\xe0y s\u1ebd x\u1eed l\xfd d\u1eef li\u1ec7u c\u1ee7a Kh\xe1ch h\xe0ng theo tr\xe1ch nhi\u1ec7m chuy\xean m\xf4n c\u1ee7a h\u1ecd;"}),Object(oe.jsx)("p",{children:"- \u0110\u1ed1i t\xe1c ti\u1ebfp th\u1ecb v\xe0 qu\u1ea3ng c\xe1o \u0111\u1ec3 \u0111\u1ea3m b\u1ea3o r\u1eb1ng c\xe1c qu\u1ea3ng c\xe1o ph\xf9 h\u1ee3p s\u1ebd \u0111\u01b0\u1ee3c hi\u1ec3n th\u1ecb \u0111\xfang \u0111\u1ed1i t\u01b0\u1ee3ng;"}),Object(oe.jsx)("p",{children:"- Ban qu\u1ea3n tr\u1ecb Mioto, B\u1ed9 ph\u1eadn kinh doanh, B\u1ed9 ph\u1eadn Ch\u0103m s\xf3c kh\xe1ch h\xe0ng v\xe0 c\xe1c c\xe1 nh\xe2n \u0111\u01b0\u1ee3c ph\xe2n c\xf4ng th\u1ef1c hi\u1ec7n c\xe1c c\xf4ng vi\u1ec7c c\xf3 li\xean quan: Vi\u1ec7c ti\u1ebfp c\u1eadn th\xf4ng tin c\u1ee7a c\xe1c \u0111\u1ed1i t\u01b0\u1ee3ng n\xe0y nh\u1eb1m cung c\u1ea5p d\u1ecbch v\u1ee5 c\u0169ng nh\u01b0 h\u1ed7 tr\u1ee3 kh\xe1ch h\xe0ng trong qu\xe1 tr\xecnh s\u1eed d\u1ee5ng c\xe1c d\u1ecbch v\u1ee5 \u0111\u01b0\u1ee3c cung c\u1ea5p b\u1edfi Mioto;"}),Object(oe.jsx)("p",{children:"- Ch\xfang t\xf4i c\xf3 th\u1ec3 chia s\u1ebb d\u1eef li\u1ec7u c\xe1 nh\xe2n c\u1ee7a Kh\xe1ch h\xe0ng v\u1edbi c\xe1c b\xean kh\xe1c, li\xean quan \u0111\u1ebfn ho\u1ea1t \u0111\u1ed9ng h\u1ee3p nh\u1ea5t, mua b\xe1n, s\xe1t nh\u1eadp, h\u1ee3p t\xe1c, t\xe1i c\u1ea5u tr\xfac, t\xe0i ch\xednh ho\u1eb7c b\u1ea5t k\u1ef3 giao d\u1ecbch kinh doanh n\xe0o kh\xe1c. D\u1eef li\u1ec7u c\xe1 nh\xe2n c\u1ee7a Kh\xe1ch h\xe0ng v\u1eabn s\u1ebd ch\u1ecbu tr\xe1ch nhi\u1ec7m b\u1edfi Mioto theo Ch\xednh s\xe1ch \u0111\xe3 t\u1ed3n t\u1ea1i t\u1eeb tr\u01b0\u1edbc m\xe0 Kh\xe1ch h\xe0ng \u0111\xe3 \u0111\u1ed3ng \xfd;"}),Object(oe.jsx)("p",{children:"- C\xe1c b\xean kh\xe1c khi c\xf3 s\u1ef1 \u0111\u1ed3ng \xfd ho\u1eb7c theo h\u01b0\u1edbng d\u1eabn c\u1ee7a kh\xe1ch h\xe0ng: Ngo\xe0i c\xe1c ti\u1ebft l\u1ed9 nh\u01b0 \u0111\u01b0\u1ee3c m\xf4 t\u1ea3 trong Ch\xednh s\xe1ch th\xf4ng tin c\xe1 nh\xe2n n\xe0y, Mioto c\xf3 th\u1ec3 chia s\u1ebb th\xf4ng tin c\xe1 nh\xe2n c\u1ee7a Kh\xe1ch h\xe0ng v\u1edbi c\xe1c b\xean th\u1ee9 ba khi kh\xe1ch h\xe0ng \u0111\u1ed3ng \xfd ho\u1eb7c y\xeau c\u1ea7u vi\u1ec7c chia s\u1ebb nh\u01b0 v\u1eady."}),Object(oe.jsx)("p",{children:"T\xf9y t\u1eebng tr\u01b0\u1eddng h\u1ee3p, c\xe1c b\xean th\u1ee9 ba c\xf3 th\u1ec3 l\xe0 B\xean x\u1eed l\xfd d\u1eef li\u1ec7u c\xe1 nh\xe2n ho\u1eb7c B\xean ki\u1ec3m so\xe1t v\xe0 x\u1eed l\xfd d\u1eef li\u1ec7u c\xe1 nh\xe2n theo quy \u0111\u1ecbnh ph\xe1p lu\u1eadt v\xe0 th\u1ecfa thu\u1eadn gi\u1eefa c\xe1c b\xean."}),Object(oe.jsx)("h6",{children:"6. L\u01b0u tr\u1eef d\u1eef li\u1ec7u c\xe1 nh\xe2n c\u1ee7a Kh\xe1ch h\xe0ng"}),Object(oe.jsx)("p",{children:"Ch\xfang t\xf4i s\u1ebd l\u01b0u tr\u1eef d\u1eef li\u1ec7u c\xe1 nh\xe2n c\u1ee7a Kh\xe1ch h\xe0ng, bao g\u1ed3m c\u1ea3 d\u1eef li\u1ec7u c\xe1 nh\xe2n nh\u1ea1y c\u1ea3m, trong th\u1eddi gian c\u1ea7n thi\u1ebft ph\xf9 h\u1ee3p v\u1edbi m\u1ee5c \u0111\xedch m\xe0 d\u1eef li\u1ec7u \u0111\u01b0\u1ee3c thu th\u1eadp v\xe0 x\u1eed l\xfd, \u0111\u1ed3ng th\u1eddi tu\xe2n th\u1ee7 c\xe1c quy \u0111\u1ecbnh ph\xe1p lu\u1eadt hi\u1ec7n h\xe0nh \u0111\u1ec3 th\u1ef1c hi\u1ec7n c\xe1c quy\u1ec1n h\u1ee3p ph\xe1p, b\u1ea3o v\u1ec7 l\u1ee3i \xedch c\u1ee7a ch\xfang t\xf4i ho\u1eb7c c\u1ee7a Kh\xe1ch h\xe0ng, nh\u01b0 gi\u1ea3i quy\u1ebft c\xe1c v\u1ea5n \u0111\u1ec1 ph\xe1t sinh ho\u1eb7c b\u1ea3o v\u1ec7 tr\u01b0\u1edbc c\xe1c khi\u1ebfu n\u1ea1i, v\xe0 \u0111\u1ec3 tu\xe2n th\u1ee7 c\xe1c ngh\u0129a v\u1ee5 ph\xe1p l\xfd ho\u1eb7c quy \u0111\u1ecbnh khi c\xf3 y\xeau c\u1ea7u ph\xe1p l\xfd, thu\u1ebf, b\xe1o c\xe1o, ho\u1eb7c ki\u1ec3m to\xe1n m\xe0 ch\xfang t\xf4i ph\u1ea3i tu\xe2n th\u1ee7, v\xed d\u1ee5 nh\u01b0 quy \u0111\u1ecbnh ph\xf2ng ch\u1ed1ng r\u1eeda ti\u1ec1n y\xeau c\u1ea7u ch\xfang t\xf4i l\u01b0u tr\u1eef h\u1ed3 s\u01a1 giao d\u1ecbch c\u1ee7a Kh\xe1ch h\xe0ng trong m\u1ed9t kho\u1ea3ng th\u1eddi gian nh\u1ea5t \u0111\u1ecbnh tr\u01b0\u1edbc khi c\xf3 th\u1ec3 x\xf3a ch\xfang."}),Object(oe.jsx)("p",{children:"Khi ch\xfang t\xf4i kh\xf4ng c\xf2n c\u1ea7n s\u1eed d\u1ee5ng th\xf4ng tin c\u1ee7a Kh\xe1ch h\xe0ng n\u1eefa, ch\xfang t\xf4i s\u1ebd x\xf3a th\xf4ng tin \u0111\xf3 kh\u1ecfi h\u1ec7 th\u1ed1ng v\xe0 h\u1ed3 s\u01a1 c\u1ee7a m\xecnh n\u1ebfu c\xf3 th\u1ec3, v\xe0/ho\u1eb7c v\xf4 hi\u1ec7u h\xf3a ho\u1eb7c th\u1ef1c hi\u1ec7n c\xe1c bi\u1ec7n ph\xe1p h\u1ee3p l\xfd kh\xe1c \u0111\u1ec3 \u1ea9n danh th\xf4ng tin sao cho Kh\xe1ch h\xe0ng kh\xf4ng c\xf2n c\xf3 th\u1ec3 b\u1ecb nh\u1eadn di\u1ec7n t\u1eeb d\u1eef li\u1ec7u \u0111\xf3."}),Object(oe.jsx)("p",{children:"Th\u1eddi gian l\u01b0u tr\u1eef th\xf4ng tin: D\u1eef li\u1ec7u c\xe1 nh\xe2n c\u1ee7a Kh\xe1ch h\xe0ng s\u1ebd \u0111\u01b0\u1ee3c l\u01b0u tr\u1eef trong kho\u1ea3ng th\u1eddi gian c\u1ea7n thi\u1ebft \u0111\u1ec3 th\u1ef1c hi\u1ec7n c\xe1c M\u1ee5c \u0111\xedch \u0111\u01b0\u1ee3c n\xeau trong Ch\xednh s\xe1ch n\xe0y, tr\u1eeb khi ph\xe1p lu\u1eadt y\xeau c\u1ea7u ho\u1eb7c cho ph\xe9p m\u1ed9t kho\u1ea3ng th\u1eddi gian l\u01b0u gi\u1eef l\xe2u h\u01a1n. Th\u1eddi gian l\u01b0u tr\u1eef kh\xe1c nhau t\xf9y thu\u1ed9c v\xe0o c\xe1c y\u1ebfu t\u1ed1 nh\u01b0 b\u1ea3n ch\u1ea5t c\u1ee7a d\u1eef li\u1ec7u, l\xfd do thu th\u1eadp v\xe0 x\u1eed l\xfd, c\u0169ng nh\u01b0 c\xe1c y\xeau c\u1ea7u ph\xe1p l\xfd ho\u1eb7c kinh doanh li\xean quan. Khi d\u1eef li\u1ec7u c\xe1 nh\xe2n c\u1ee7a Kh\xe1ch h\xe0ng kh\xf4ng c\xf2n c\u1ea7n thi\u1ebft cho d\u1ecbch v\u1ee5 ho\u1eb7c c\xe1c m\u1ee5c \u0111\xedch, ch\xfang t\xf4i s\u1ebd th\u1ef1c hi\u1ec7n c\xe1c bi\u1ec7n ph\xe1p x\xf3a, h\u1ee7y, \u1ea9n danh ho\u1eb7c ng\u0103n ch\u1eb7n vi\u1ec7c truy c\u1eadp ho\u1eb7c s\u1eed d\u1ee5ng, tr\u1eeb tr\u01b0\u1eddng h\u1ee3p c\u1ea7n thi\u1ebft cho vi\u1ec7c tu\xe2n th\u1ee7 ph\xe1p lu\u1eadt, b\u1ea3o \u0111\u1ea3m an to\xe0n, an ninh, ph\xf2ng ng\u1eeba v\xe0 ph\xe1t hi\u1ec7n gian l\u1eadn, ph\xf9 h\u1ee3p v\u1edbi c\xe1c quy \u0111\u1ecbnh ph\xe1p lu\u1eadt hi\u1ec7n h\xe0nh."}),Object(oe.jsx)("p",{children:"Vui l\xf2ng l\u01b0u \xfd r\u1eb1ng nh\u1eefng th\xf4ng tin Kh\xe1ch h\xe0ng \u0111\xe3 chia s\u1ebb v\u1edbi ng\u01b0\u1eddi d\xf9ng kh\xe1c, nh\u01b0 \u0111\xe1nh gi\xe1 ho\u1eb7c n\u1ed9i dung \u0111\u01b0\u1ee3c \u0111\u0103ng t\u1ea3i, c\xf3 th\u1ec3 ti\u1ebfp t\u1ee5c hi\u1ec3n th\u1ecb c\xf4ng khai tr\xean n\u1ec1n t\u1ea3ng Mioto ngay c\u1ea3 sau khi Kh\xe1ch h\xe0ng \u0111\xe3 x\xf3a t\xe0i kho\u1ea3n."}),Object(oe.jsx)("h6",{children:"7. H\u1eadu qu\u1ea3, thi\u1ec7t h\u1ea1i kh\xf4ng mong mu\u1ed1n c\xf3 kh\u1ea3 n\u0103ng x\u1ea3y ra"}),Object(oe.jsx)("p",{children:"Mioto \xe1p d\u1ee5ng nhi\u1ec1u bi\u1ec7n ph\xe1p b\u1ea3o v\u1ec7 th\xf4ng tin, b\u1ea3o \u0111\u1ea3m an to\xe0n th\xf4ng tin c\u1ee7a Kh\xe1ch h\xe0ng, c\xf4ng ngh\u1ec7 b\u1ea3o m\u1eadt th\xf4ng tin kh\xe1c nhau nh\u1eb1m b\u1ea3o v\u1ec7 v\xe0 ng\u0103n ch\u1eb7n vi\u1ec7c d\u1eef li\u1ec7u c\xe1 nh\xe2n c\u1ee7a Kh\xe1ch h\xe0ng b\u1ecb truy c\u1eadp, s\u1eed d\u1ee5ng ho\u1eb7c chia s\u1ebb ngo\xe0i \xfd mu\u1ed1n. Tuy nhi\xean, kh\xf4ng m\u1ed9t d\u1eef li\u1ec7u n\xe0o c\xf3 th\u1ec3 \u0111\u01b0\u1ee3c b\u1ea3o m\u1eadt ho\xe0n to\xe0n. Do v\u1eady, Mioto kh\xf4ng th\u1ec3 cam k\u1ebft b\u1ea3o m\u1eadt m\u1ed9t c\xe1ch tuy\u1ec7t \u0111\u1ed1i d\u1eef li\u1ec7u c\xe1 nh\xe2n c\u1ee7a Kh\xe1ch h\xe0ng trong m\u1ed9t s\u1ed1 tr\u01b0\u1eddng h\u1ee3p nh\u01b0: (i) L\u1ed7i ph\u1ea7n c\u1ee9ng, ph\u1ea7n m\u1ec1m trong qu\xe1 tr\xecnh x\u1eed l\xfd d\u1eef li\u1ec7u l\xe0m m\u1ea5t d\u1eef li\u1ec7u c\u1ee7a Kh\xe1ch h\xe0ng; (ii) L\u1ed7 h\u1ed5ng b\u1ea3o m\u1eadt n\u1eb1m ngo\xe0i kh\u1ea3 n\u0103ng ki\u1ec3m so\xe1t c\u1ee7a Mioto, h\u1ec7 th\u1ed1ng b\u1ecb hacker t\u1ea5n c\xf4ng g\xe2y l\u1ed9 l\u1ecdt d\u1eef li\u1ec7u; (iii) Kh\xe1ch h\xe0ng t\u1ef1 l\xe0m l\u1ed9 l\u1ecdt d\u1eef li\u1ec7u c\xe1 nh\xe2n do: b\u1ea5t c\u1ea9n ho\u1eb7c b\u1ecb l\u1eeba \u0111\u1ea3o; truy c\u1eadp c\xe1c website/t\u1ea3i c\xe1c \u1ee9ng d\u1ee5ng c\xf3 ch\u1ee9a ph\u1ea7n m\u1ec1m \u0111\u1ed9c h\u1ea1i, b\u1ecb hacker chi\u1ebfm quy\u1ec1n \u0111i\u1ec1u khi\u1ec3n."}),Object(oe.jsx)("p",{children:"Mioto khuy\u1ebfn c\xe1o Kh\xe1ch h\xe0ng b\u1ea3o m\u1eadt c\xe1c th\xf4ng tin li\xean quan \u0111\u1ebfn m\u1eadt kh\u1ea9u \u0111\u0103ng nh\u1eadp v\xe0o t\xe0i kho\u1ea3n c\u1ee7a m\xecnh, m\xe3 OTP v\xe0 kh\xf4ng chia s\u1ebb n\u1ed9i dung n\xe0y v\u1edbi b\u1ea5t k\u1ef3 ng\u01b0\u1eddi n\xe0o kh\xe1c; b\u1ea3o qu\u1ea3n thi\u1ebft b\u1ecb c\xe1 nh\xe2n (m\xe1y \u0111i\u1ec7n tho\u1ea1i, m\xe1y t\xednh b\u1ea3ng, m\xe1y t\xednh c\xe1 nh\xe2n\u2026) trong qu\xe1 tr\xecnh s\u1eed d\u1ee5ng; Kh\xe1ch h\xe0ng n\xean \u0111\u0103ng xu\u1ea5t kh\u1ecfi t\xe0i kho\u1ea3n c\u1ee7a m\xecnh khi kh\xf4ng c\xf3 nhu c\u1ea7u s\u1eed d\u1ee5ng."}),Object(oe.jsx)("p",{children:"Kh\xe1ch h\xe0ng c\u1ea7n bi\u1ebft r\xf5 r\u1eb1ng b\u1ea5t k\u1ef3 th\u1eddi \u0111i\u1ec3m n\xe0o Kh\xe1ch h\xe0ng ti\u1ebft l\u1ed9 v\xe0 c\xf4ng khai d\u1eef li\u1ec7u c\xe1 nh\xe2n c\u1ee7a Kh\xe1ch h\xe0ng, d\u1eef li\u1ec7u \u0111\xf3 c\xf3 th\u1ec3 b\u1ecb ng\u01b0\u1eddi kh\xe1c thu th\u1eadp v\xe0 s\u1eed d\u1ee5ng b\u1edfi c\xe1c m\u1ee5c \u0111\xedch n\u1eb1m ngo\xe0i t\u1ea7m ki\u1ec3m so\xe1t c\u1ee7a Kh\xe1ch h\xe0ng v\xe0 Mioto."}),Object(oe.jsx)("p",{children:"Trong tr\u01b0\u1eddng h\u1ee3p m\xe1y ch\u1ee7 l\u01b0u tr\u1eef d\u1eef li\u1ec7u b\u1ecb t\u1ea5n c\xf4ng d\u1eabn \u0111\u1ebfn b\u1ecb m\u1ea5t, l\u1ed9, l\u1ecdt d\u1eef li\u1ec7u c\xe1 nh\xe2n c\u1ee7a Kh\xe1ch h\xe0ng, Mioto s\u1ebd c\xf3 tr\xe1ch nhi\u1ec7m th\xf4ng b\xe1o v\u1ee5 vi\u1ec7c cho c\u01a1 quan ch\u1ee9c n\u0103ng \u0111i\u1ec1u tra x\u1eed l\xfd k\u1ecbp th\u1eddi v\xe0 th\xf4ng b\xe1o cho Kh\xe1ch h\xe0ng \u0111\u01b0\u1ee3c bi\u1ebft theo quy \u0111\u1ecbnh ph\xe1p lu\u1eadt."}),Object(oe.jsx)("p",{children:"Kh\xf4ng gian m\u1ea1ng kh\xf4ng ph\u1ea3i l\xe0 m\u1ed9t m\xf4i tr\u01b0\u1eddng an to\xe0n tuy\u1ec7t \u0111\u1ed1i. Khi Kh\xe1ch h\xe0ng truy\u1ec1n t\u1ea3i d\u1eef li\u1ec7u c\xe1 nh\xe2n qua kh\xf4ng gian m\u1ea1ng, Kh\xe1ch h\xe0ng ch\u1ec9 n\xean s\u1eed d\u1ee5ng c\xe1c h\u1ec7 th\u1ed1ng an to\xe0n \u0111\u1ec3 truy c\u1eadp trang th\xf4ng tin \u0111i\u1ec7n t\u1eed, \u1ee9ng d\u1ee5ng ho\u1eb7c thi\u1ebft b\u1ecb. Kh\xe1ch h\xe0ng c\xf3 tr\xe1ch nhi\u1ec7m gi\u1eef th\xf4ng tin x\xe1c th\u1ef1c truy c\u1eadp c\u1ee7a m\xecnh cho t\u1eebng trang th\xf4ng tin \u0111i\u1ec7n t\u1eed, \u1ee9ng d\u1ee5ng ho\u1eb7c thi\u1ebft b\u1ecb an to\xe0n v\xe0 b\xed m\u1eadt."}),Object(oe.jsx)("h6",{children:"8. Ph\u01b0\u01a1ng ti\u1ec7n v\xe0 c\xf4ng c\u1ee5 \u0111\u1ec3 ng\u01b0\u1eddi d\xf9ng ti\u1ebfp c\u1eadn, ch\u1ec9nh s\u1eeda v\xe0 h\u1ee7y b\u1ecf d\u1eef li\u1ec7u c\xe1 nh\xe2n c\u1ee7a m\xecnh"}),Object(oe.jsx)("p",{children:"Kh\xe1ch h\xe0ng c\xf3 quy\u1ec1n t\u1ef1 ki\u1ec3m tra, c\u1eadp nh\u1eadt, \u0111i\u1ec1u ch\u1ec9nh ho\u1eb7c h\u1ee7y b\u1ecf th\xf4ng tin c\xe1 nh\xe2n c\u1ee7a m\xecnh b\u1eb1ng c\xe1ch \u0111\u0103ng nh\u1eadp v\xe0o t\xe0i kho\u1ea3n v\xe0 ch\u1ec9nh s\u1eeda th\xf4ng tin c\xe1 nh\xe2n ho\u1eb7c y\xeau c\u1ea7u Mioto th\u1ef1c hi\u1ec7n vi\u1ec7c n\xe0y."}),Object(oe.jsx)("p",{children:"Kh\xe1ch h\xe0ng c\xf3 quy\u1ec1n g\u1eedi khi\u1ebfu n\u1ea1i v\u1ec1 vi\u1ec7c l\u1ed9 th\xf4ng tin c\xe1c nh\xe2n cho b\xean th\u1ee9 ba \u0111\u1ebfn Mioto. Khi ti\u1ebfp nh\u1eadn nh\u1eefng ph\u1ea3n h\u1ed3i n\xe0y, Mioto s\u1ebd x\xe1c nh\u1eadn l\u1ea1i th\xf4ng tin, tr\u1ea3 l\u1eddi l\xfd do v\xe0 h\u01b0\u1edbng d\u1eabn Kh\xe1ch h\xe0ng kh\xf4i ph\u1ee5c v\xe0 b\u1ea3o m\u1eadt l\u1ea1i th\xf4ng tin."}),Object(oe.jsxs)("p",{children:["Email: ",re.h]}),Object(oe.jsx)("h6",{children:"9. Thu th\u1eadp c\xe1c d\u1eef li\u1ec7u kh\xe1c"}),Object(oe.jsx)("p",{children:'Nh\u01b0 v\u1edbi h\u1ea7u h\u1ebft c\xe1c trang web v\xe0 c\xe1c \u1ee9ng d\u1ee5ng di \u0111\u1ed9ng kh\xe1c, thi\u1ebft b\u1ecb c\u1ee7a Kh\xe1ch h\xe0ng g\u1eedi th\xf4ng tin c\xf3 th\u1ec3 g\u1ed3m c\xf3 d\u1eef li\u1ec7u v\u1ec1 Kh\xe1ch h\xe0ng, \u0111\u01b0\u1ee3c m\u1ed9t m\xe1y ch\u1ee7 web ghi l\u1ea1i khi Kh\xe1ch h\xe0ng s\u1eed d\u1ee5ng n\u1ec1n t\u1ea3ng c\u1ee7a ch\xfang t\xf4i. Th\xf4ng tin n\xe0y th\xf4ng th\u01b0\u1eddng bao g\u1ed3m nh\u01b0ng kh\xf4ng gi\u1edbi h\u1ea1n \u0111\u1ecba ch\u1ec9 IP, h\u1ec7 \u0111i\u1ec1u h\xe0nh c\u1ee7a m\xe1y t\xednh/thi\u1ebft b\u1ecb di \u0111\u1ed9ng, lo\u1ea1i tr\xecnh duy\u1ec7t, lo\u1ea1i thi\u1ebft b\u1ecb di \u0111\u1ed9ng, c\xe1c \u0111\u1eb7c \u0111i\u1ec3m c\u1ee7a thi\u1ebft b\u1ecb di \u0111\u1ed9ng, m\xe3 \u0111\u1ecbnh danh thi\u1ebft b\u1ecb th\u1ed1ng nh\u1ea5t (UDID) ho\u1eb7c m\xe3 \u0111\u1ecbnh danh thi\u1ebft b\u1ecb di \u0111\u1ed9ng (MEID) c\u1ee7a thi\u1ebft b\u1ecb di \u0111\u1ed9ng c\u1ee7a Kh\xe1ch h\xe0ng, \u0111\u1ecba ch\u1ec9 tham chi\u1ebfu c\u1ee7a trang web (n\u1ebfu c\xf3), c\xe1c trang m\xe0 Kh\xe1ch h\xe0ng \u0111\xe3 truy c\u1eadp \u0111\u1ebfn tr\xean trang web ho\u1eb7c \u1ee9ng d\u1ee5ng di \u0111\u1ed9ng c\u1ee7a ch\xfang t\xf4i v\xe0 th\u1eddi gian truy c\u1eadp v\xe0 \u0111\xf4i khi l\xe0 "cookie" (c\xf3 th\u1ec3 v\xf4 hi\u1ec7u h\xf3a b\u1eb1ng c\xe1ch s\u1eed d\u1ee5ng t\xf9y ch\u1ecdn tr\xecnh duy\u1ec7t c\u1ee7a Kh\xe1ch h\xe0ng) \u0111\u1ec3 gi\xfap trang web ghi nh\u1edb l\u1ea7n truy c\u1eadp cu\u1ed1i c\xf9ng c\u1ee7a Kh\xe1ch h\xe0ng. N\u1ebfu Kh\xe1ch h\xe0ng \u0111\u0103ng nh\u1eadp, th\xf4ng tin n\xe0y \u0111\u01b0\u1ee3c li\xean k\u1ebft v\u1edbi t\xe0i kho\u1ea3n c\xe1 nh\xe2n c\u1ee7a Kh\xe1ch h\xe0ng. Th\xf4ng tin n\xe0y c\u0169ng \u0111\u01b0\u1ee3c \u0111\u01b0a v\xe0o c\xe1c s\u1ed1 li\u1ec7u th\u1ed1ng k\xea \u1ea9n danh \u0111\u1ec3 gi\xfap ch\xfang t\xf4i hi\u1ec3u \u0111\u01b0\u1ee3c kh\xe1ch truy c\u1eadp s\u1eed d\u1ee5ng trang web c\u1ee7a ch\xfang t\xf4i nh\u01b0 th\u1ebf n\xe0o.'}),Object(oe.jsx)("p",{children:"C\xe1c \u1ee9ng d\u1ee5ng di \u0111\u1ed9ng c\u1ee7a ch\xfang t\xf4i c\xf3 th\u1ec3 thu th\u1eadp th\xf4ng tin ch\xednh x\xe1c v\u1ec1 \u0111\u1ecba ch\u1ec9 c\u1ee7a thi\u1ebft b\u1ecb di \u0111\u1ed9ng c\u1ee7a Kh\xe1ch h\xe0ng s\u1eed d\u1ee5ng c\xe1c c\xf4ng ngh\u1ec7 nh\u01b0 GPS, Wi-Fi,\u2026. Ch\xfang t\xf4i thu th\u1eadp, s\u1eed d\u1ee5ng, c\xf4ng b\u1ed1 v\xe0/ho\u1eb7c x\u1eed l\xfd c\xe1c th\xf4ng tin n\xe0y cho m\u1ed9t ho\u1eb7c nhi\u1ec1u m\u1ee5c \u0111\xedch bao g\u1ed3m nh\u01b0ng kh\xf4ng gi\u1edbi h\u1ea1n c\xe1c d\u1ecbch v\u1ee5 \u0111\u01b0\u1ee3c cung c\u1ea5p d\u1ef1a tr\xean v\u1ecb tr\xed m\xe0 Kh\xe1ch h\xe0ng y\xeau c\u1ea7u ho\u1eb7c chuy\u1ec3n c\xe1c n\u1ed9i dung c\xf3 li\xean quan \u0111\u1ebfn Kh\xe1ch h\xe0ng d\u1ef1a tr\xean v\u1ecb tr\xed c\u1ee7a Kh\xe1ch h\xe0ng ho\u1eb7c cho ph\xe9p Kh\xe1ch h\xe0ng chia s\u1ebb v\u1ecb tr\xed c\u1ee7a Kh\xe1ch h\xe0ng cho c\xe1c Ng\u01b0\u1eddi s\u1eed d\u1ee5ng kh\xe1c nh\u01b0 l\xe0 m\u1ed9t ph\u1ea7n c\u1ee7a c\xe1c D\u1ecbch v\u1ee5 \u0111\u01b0\u1ee3c cung c\u1ea5p b\u1edfi c\xe1c \u1ee9ng d\u1ee5ng di \u0111\u1ed9ng c\u1ee7a ch\xfang t\xf4i. \u0110\u1ed1i v\u1edbi ph\u1ea7n l\u1edbn c\xe1c thi\u1ebft b\u1ecb di \u0111\u1ed9ng, Kh\xe1ch h\xe0ng c\xf3 th\u1ec3 r\xfat l\u1ea1i s\u1ef1 cho ph\xe9p \u0111\u1ec3 ch\xfang t\xf4i \u0111\u01b0\u1ee3c thu th\u1eadp c\xe1c th\xf4ng tin n\xe0y d\u1ef1a tr\xean v\u1ecb tr\xed c\u1ee7a Kh\xe1ch h\xe0ng th\xf4ng qua c\xe1c c\xe0i \u0111\u1eb7t tr\xean thi\u1ebft b\u1ecb. N\u1ebfu Kh\xe1ch h\xe0ng c\xf3 c\xe2u h\u1ecfi n\xe0o v\u1ec1 c\xe1ch th\u1ee9c v\xf4 hi\u1ec7u h\xf3a c\xe1c d\u1ecbch v\u1ee5 v\u1ecb tr\xed tr\xean thi\u1ebft b\u1ecb di \u0111\u1ed9ng c\u1ee7a Kh\xe1ch h\xe0ng, vui l\xf2ng li\xean h\u1ec7 v\u1edbi c\xe1c nh\xe0 cung c\u1ea5p d\u1ecbch v\u1ee5 thi\u1ebft b\u1ecb di \u0111\u1ed9ng ho\u1eb7c nh\xe0 s\u1ea3n xu\u1ea5t thi\u1ebft b\u1ecb c\u1ee7a Kh\xe1ch h\xe0ng."}),Object(oe.jsx)("p",{children:"Nh\u01b0 khi Kh\xe1ch h\xe0ng xem c\xe1c trang tr\xean trang web ho\u1eb7c \u1ee9ng d\u1ee5ng di \u0111\u1ed9ng c\u1ee7a ch\xfang t\xf4i, khi Kh\xe1ch h\xe0ng xem c\xe1c n\u1ed9i dung v\xe0 qu\u1ea3ng c\xe1o v\xe0 truy c\u1eadp v\xe0o ph\u1ea7n m\u1ec1m kh\xe1c tr\xean N\u1ec1n t\u1ea3ng c\u1ee7a ch\xfang t\xf4i ho\u1eb7c th\xf4ng qua D\u1ecbch v\u1ee5, ph\u1ea7n l\u1edbn c\xe1c th\xf4ng tin t\u01b0\u01a1ng t\u1ef1 \u0111\u01b0\u1ee3c g\u1eedi \u0111\u1ebfn cho ch\xfang t\xf4i (bao g\u1ed3m nh\u01b0ng kh\xf4ng gi\u1edbi h\u1ea1n, \u0111\u1ecba ch\u1ec9 IP, h\u1ec7 \u0111i\u1ec1u h\xe0nh, v.v..); nh\u01b0ng, thay v\xec c\xe1c s\u1ed1 l\u01b0\u1ee3t xem trang, thi\u1ebft b\u1ecb c\u1ee7a Kh\xe1ch h\xe0ng g\u1eedi \u0111\u1ebfn ch\xfang t\xf4i c\xe1c th\xf4ng tin v\u1ec1 n\u1ed9i dung, qu\u1ea3ng c\xe1o \u0111\u01b0\u1ee3c xem v\xe0/ho\u1eb7c ph\u1ea7n m\u1ec1m \u0111\u01b0\u1ee3c c\xe0i \u0111\u1eb7t b\u1edfi c\xe1c d\u1ecbch v\u1ee5 v\xe0 n\u1ec1n t\u1ea3ng v\xe0 th\u1eddi \u0111i\u1ec3m."}),Object(oe.jsx)("h6",{children:"10. Cookies"}),Object(oe.jsx)("p",{children:"\u0110\xf4i khi ch\xfang t\xf4i ho\u1eb7c c\xe1c nh\xe0 cung c\u1ea5p d\u1ecbch v\u1ee5 \u0111\u01b0\u1ee3c cho ph\xe9p v\xe0 c\xe1c \u0111\u1ed1i t\xe1c qu\u1ea3ng c\xe1o c\u1ee7a ch\xfang t\xf4i c\xf3 th\u1ec3 s\u1eed d\u1ee5ng \u201ccookies\u201d ho\u1eb7c c\xe1c t\xednh n\u0103ng kh\xe1c \u0111\u1ec3 cho ph\xe9p ch\xfang t\xf4i ho\u1eb7c c\xe1c b\xean th\u1ee9 ba thu th\u1eadp ho\u1eb7c chia s\u1ebb th\xf4ng tin li\xean quan \u0111\u1ebfn vi\u1ec7c s\u1eed d\u1ee5ng c\u1ee7a Kh\xe1ch h\xe0ng \u0111\u1ed1i v\u1edbi d\u1ecbch v\u1ee5 ho\u1eb7c n\u1ec1n t\u1ea3ng c\u1ee7a ch\xfang t\xf4i. C\xe1c t\xednh n\u0103ng n\xe0y s\u1ebd gi\xfap ch\xfang t\xf4i c\u1ea3i thi\u1ec7n n\u1ec1n t\u1ea3ng v\xe0 c\xe1c d\u1ecbch v\u1ee5 ch\xfang t\xf4i cung c\u1ea5p, gi\xfap ch\xfang t\xf4i \u0111\u1ec1 xu\u1ea5t c\xe1c d\u1ecbch v\u1ee5 v\xe0 t\xednh n\u0103ng m\u1edbi, v\xe0/ho\u1eb7c cho ph\xe9p ch\xfang t\xf4i v\xe0 c\xe1c \u0111\u1ed1i t\xe1c qu\u1ea3ng c\xe1o c\u1ee7a ch\xfang t\xf4i cung c\u1ea5p c\xe1c n\u1ed9i dung c\xf3 li\xean quan h\u01a1n \u0111\u1ebfn Kh\xe1ch h\xe0ng. \u201cCookies\u201d l\xe0 c\xe1c m\xe3 danh \u0111\u1ecbnh \u0111\u01b0\u1ee3c l\u01b0u tr\u1eef tr\xean m\xe1y t\xednh ho\u1eb7c thi\u1ebft b\u1ecb di \u0111\u1ed9ng c\u1ee7a Kh\xe1ch h\xe0ng l\u01b0u tr\u1eef c\xe1c d\u1eef li\u1ec7u v\u1ec1 m\xe1y t\xednh ho\u1eb7c thi\u1ebft b\u1ecb, b\u1eb1ng c\xe1ch n\xe0o v\xe0 khi n\xe0o c\xe1c d\u1ecbch v\u1ee5 ho\u1eb7c n\u1ec1n t\u1ea3ng \u0111\u01b0\u1ee3c s\u1eed d\u1ee5ng hay truy c\u1eadp, b\u1edfi bao nhi\xeau ng\u01b0\u1eddi v\xe0 \u0111\u1ec3 theo d\xf5i nh\u1eefng ho\u1ea1t \u0111\u1ed9ng trong c\xe1c n\u1ec1n t\u1ea3ng c\u1ee7a ch\xfang t\xf4i. Ch\xfang t\xf4i c\xf3 th\u1ec3 li\xean k\u1ebft th\xf4ng tin cookies v\u1edbi d\u1eef li\u1ec7u c\xe1 nh\xe2n. Cookies c\u0169ng li\xean k\u1ebft v\u1edbi th\xf4ng tin v\u1ec1 nh\u1eefng n\u1ed9i dung Kh\xe1ch h\xe0ng \u0111\xe3 ch\u1ecdn v\xe0 c\xe1c trang web m\xe0 Kh\xe1ch h\xe0ng \u0111\xe3 xem. Th\xf4ng tin n\xe0y \u0111\u01b0\u1ee3c s\u1eed d\u1ee5ng \u0111\u1ec3 theo d\xf5i nhu c\u1ea7u, \u0111\u1ec3 chuy\u1ec3n t\u1ea3i n\u1ed9i dung ph\xf9 h\u1ee3p v\u1edbi s\u1edf th\xedch c\u1ee7a Kh\xe1ch h\xe0ng, \u0111\u1ec3 cho ph\xe9p c\xe1c \u0111\u1ed1i t\xe1c cung c\u1ea5p d\u1ecbch v\u1ee5 qu\u1ea3ng c\xe1o cung c\u1ea5p d\u1ecbch v\u1ee5 qu\u1ea3ng c\xe1o tr\xean c\xe1c trang th\xf4ng qua m\u1ea1ng Internet v\xe0 \u0111\u1ec3 th\u1ef1c hi\u1ec7n ph\xe2n t\xedch d\u1eef li\u1ec7u v\xe0 ho\u1eb7c theo d\xf5i vi\u1ec7c s\u1eed d\u1ee5ng D\u1ecbch v\u1ee5."}),Object(oe.jsx)("p",{children:"Kh\xe1ch h\xe0ng c\xf3 th\u1ec3 t\u1eeb ch\u1ed1i s\u1eed d\u1ee5ng cookies b\u1eb1ng c\xe1ch ch\u1ecdn c\xe1c thi\u1ebft l\u1eadp th\xedch h\u1ee3p tr\xean tr\xecnh duy\u1ec7t ho\u1eb7c thi\u1ebft b\u1ecb c\u1ee7a Kh\xe1ch h\xe0ng. Tuy nhi\xean, vui l\xf2ng l\u01b0u \xfd r\u1eb1ng n\u1ebfu Kh\xe1ch h\xe0ng th\u1ef1c hi\u1ec7n thao t\xe1c n\xe0y Kh\xe1ch h\xe0ng c\xf3 th\u1ec3 kh\xf4ng s\u1eed d\u1ee5ng \u0111\u01b0\u1ee3c c\xe1c ch\u1ee9c n\u0103ng \u0111\u1ea7y \u0111\u1ee7 c\u1ee7a n\u1ec1n t\u1ea3ng ho\u1eb7c c\xe1c d\u1ecbch v\u1ee5 c\u1ee7a ch\xfang t\xf4i."}),Object(oe.jsx)("h6",{children:"11. Th\xf4ng tin v\u1ec1 tr\u1ebb em"}),Object(oe.jsx)("p",{children:"C\xe1c d\u1ecbch v\u1ee5 n\xe0y kh\xf4ng d\xe0nh cho tr\u1ebb em d\u01b0\u1edbi 18 tu\u1ed5i. Ch\xfang t\xf4i kh\xf4ng c\u1ed1 t\xecnh thu th\u1eadp hay l\u01b0u gi\u1eef b\u1ea5t k\u1ef3 d\u1eef li\u1ec7u c\xe1 nh\xe2n hay th\xf4ng tin kh\xf4ng nh\u1eadn d\u1ea1ng c\xe1 nh\xe2n n\xe0o c\u1ee7a b\u1ea5t k\u1ef3 ai d\u01b0\u1edbi 18 tu\u1ed5i, b\u1ea5t k\u1ef3 ph\u1ea7n n\xe0o c\u1ee7a n\u1ec1n t\u1ea3ng c\u1ee7a ch\xfang t\xf4i ho\u1eb7c c\xe1c d\u1ecbch v\u1ee5 kh\xe1c c\u0169ng kh\xf4ng d\xe0nh cho tr\u1ebb em d\u01b0\u1edbi 18 tu\u1ed5i. B\u1ed1/m\u1eb9 ho\u1eb7c ng\u01b0\u1eddi gi\xe1m h\u1ed9 c\u1ee7a tr\u1ebb em d\u01b0\u1edbi 18 tu\u1ed5i vui l\xf2ng gi\xe1m s\xe1t v\xe0 \u0111\u1ea3m b\u1ea3o th\xf4ng tin c\xe1 nh\xe2n c\u1ee7a tr\u1ebb d\u01b0\u1edbi 18 tu\u1ed5i m\xe0 m\xecnh \u0111ang gi\xe1m h\u1ed9 kh\xf4ng \u0111\u0103ng t\u1ea3i th\xf4ng tin c\xe1 nh\xe2n cho Mioto. Trong tr\u01b0\u1eddng h\u1ee3p th\xf4ng tin c\xe1 nh\xe2n c\u1ee7a c\u1ee7a tr\u1ebb em d\u01b0\u1edbi 18 tu\u1ed5i do qu\xfd ph\u1ee5 huynh gi\xe1m h\u1ed9 \u0111\u01b0\u1ee3c cung c\u1ea5p cho Mioto, B\u1ed1/m\u1eb9 ho\u1eb7c ng\u01b0\u1eddi gi\xe1m h\u1ed9 theo \u0111\u1ed3ng \xfd v\u1edbi vi\u1ec7c x\u1eed l\xfd th\xf4ng tin c\u1ee7a tr\u1ebb em d\u01b0\u1edbi 18 tu\u1ed5i c\xf3 li\xean quan, v\xe0 \u0111\u1ed3ng \xfd ch\u1ecbu s\u1ef1 \u0111i\u1ec1u ch\u1ec9nh c\u1ee7a Ch\xednh s\xe1ch n\xe0y thay m\u1eb7t cho ng\u01b0\u1eddi \u0111\u01b0\u1ee3c gi\xe1m h\u1ed9. Ch\xfang t\xf4i s\u1ebd kh\xf3a b\u1ea5t k\u1ef3 t\xe0i kho\u1ea3n n\xe0o \u0111\u01b0\u1ee3c s\u1eed d\u1ee5ng b\u1edfi \u0111\u1ed1i t\u01b0\u1ee3ng tr\u1ebb em nh\u01b0 v\u1eady v\xe0 s\u1ebd g\u1ee1 v\xe0/ho\u1eb7c x\xf3a b\u1ea5t k\u1ef3 d\u1eef li\u1ec7u c\xe1 nh\xe2n n\xe0o m\xe0 ch\xfang t\xf4i cho l\xe0 \u0111\xe3 \u0111\u01b0\u1ee3c g\u1eedi b\u1edfi b\u1ea5t k\u1ef3 tr\u1ebb em n\xe0o d\u01b0\u1edbi 18 tu\u1ed5i."}),Object(oe.jsx)("h6",{children:"12. Li\xean k\u1ebft \u0111\u1ebfn c\xe1c trang web kh\xe1c"}),Object(oe.jsx)("p",{children:"Kh\xe1ch h\xe0ng c\xf3 th\u1ec3 li\xean k\u1ebft t\xe0i kho\u1ea3n Mioto c\u1ee7a m\xecnh v\u1edbi c\xe1c d\u1ecbch v\u1ee5 b\xean th\u1ee9 ba, v\xe0 m\u1ed9t s\u1ed1 ph\u1ea7n c\u1ee7a n\u1ec1n t\u1ea3ng Mioto c\xf3 th\u1ec3 ch\u1ee9a li\xean k\u1ebft \u0111\u1ebfn c\xe1c trang web thu\u1ed9c s\u1edf h\u1eefu c\u1ee7a b\xean th\u1ee9 ba. Ch\xfang t\xf4i kh\xf4ng s\u1edf h\u1eefu ho\u1eb7c ki\u1ec3m so\xe1t c\xe1c trang web \u0111\xf3. Khi Kh\xe1ch h\xe0ng t\u01b0\u01a1ng t\xe1c v\u1edbi c\xe1c b\xean th\u1ee9 ba n\xe0y, ch\xfang t\xf4i kh\xf4ng ch\u1ecbu tr\xe1ch nhi\u1ec7m \u0111\u1ed1i v\u1edbi c\xe1c ho\u1ea1t \u0111\u1ed9ng x\u1eed l\xfd d\u1eef li\u1ec7u c\u1ee7a h\u1ecd v\xe0 khuy\u1ebfn ngh\u1ecb Kh\xe1ch h\xe0ng n\xean \u0111\u1ecdc k\u1ef9 ch\xednh s\xe1ch quy\u1ec1n ri\xeang t\u01b0 c\u1ee7a t\u1eebng trang web Kh\xe1ch h\xe0ng truy c\u1eadp c\xf3 thu th\u1eadp d\u1eef li\u1ec7u c\xe1 nh\xe2n c\u1ee7a Kh\xe1ch h\xe0ng."}),Object(oe.jsx)("h6",{children:"13. Ngh\u0129a v\u1ee5 c\u1ee7a Kh\xe1ch h\xe0ng"}),Object(oe.jsx)("p",{children:"- Tu\xe2n th\u1ee7 c\xe1c quy \u0111\u1ecbnh ph\xe1p lu\u1eadt, quy \u0111\u1ecbnh c\u1ee7a Mioto li\xean quan \u0111\u1ebfn x\u1eed l\xfd d\u1eef li\u1ec7u c\xe1 nh\xe2n c\u1ee7a Kh\xe1ch h\xe0ng;"}),Object(oe.jsx)("p",{children:"- Cung c\u1ea5p c\u0169ng nh\u01b0 \u0111\u1ea3m b\u1ea3o c\xf3 quy\u1ec1n cung c\u1ea5p h\u1ee3p ph\xe1p m\u1ed9t c\xe1ch \u0111\u1ea7y \u0111\u1ee7, trung th\u1ef1c, ch\xednh x\xe1c d\u1eef li\u1ec7u c\xe1 nh\xe2n, c\xe1c th\xf4ng tin kh\xe1c theo y\xeau c\u1ea7u c\u1ee7a Mioto khi t\xecm ki\u1ebfm, ti\u1ebfp c\u1eadn, mua, \u0111\u0103ng k\xfd s\u1eed d\u1ee5ng v\xe0 s\u1eed d\u1ee5ng s\u1ea3n ph\u1ea9m, d\u1ecbch v\u1ee5 v\xe0 khi c\xf3 thay \u0111\u1ed5i v\u1ec1 c\xe1c th\xf4ng tin n\xe0y. Ch\xfang t\xf4i s\u1ebd ti\u1ebfn h\xe0nh b\u1ea3o m\u1eadt d\u1eef li\u1ec7u c\xe1 nh\xe2n c\u1ee7a Kh\xe1ch h\xe0ng c\u0103n c\u1ee9 tr\xean th\xf4ng tin Kh\xe1ch h\xe0ng \u0111\xe3 cung c\u1ea5pc\u0103n c\u1ee9 tr\xean th\xf4ng tin Kh\xe1ch h\xe0ng \u0111\xe3 cung c\u1ea5p. Do \u0111\xf3, n\u1ebfu c\xf3 b\u1ea5t k\u1ef3 th\xf4ng tin sai l\u1ec7ch n\xe0o, ch\xfang t\xf4i s\u1ebd kh\xf4ng ch\u1ecbu tr\xe1ch nhi\u1ec7m trong tr\u01b0\u1eddng h\u1ee3p th\xf4ng tin \u0111\xf3 l\xe0m \u1ea3nh h\u01b0\u1edfng ho\u1eb7c h\u1ea1n ch\u1ebf quy\u1ec1n l\u1ee3i c\u1ee7a Kh\xe1ch h\xe0ng. Tr\u01b0\u1eddng h\u1ee3p kh\xf4ng th\xf4ng b\xe1o, n\u1ebfu c\xf3 ph\xe1t sinh r\u1ee7i ro, t\u1ed5n th\u1ea5t th\xec Kh\xe1ch h\xe0ng ch\u1ecbu tr\xe1ch nhi\u1ec7m v\u1ec1 nh\u1eefng sai s\xf3t hay h\xe0nh vi l\u1ee3i d\u1ee5ng, l\u1eeba \u0111\u1ea3o khi s\u1eed d\u1ee5ng s\u1ea3n ph\u1ea9m, d\u1ecbch v\u1ee5 do l\u1ed7i c\u1ee7a Kh\xe1ch h\xe0ng ho\u1eb7c do kh\xf4ng cung c\u1ea5p \u0111\xfang, \u0111\u1ea7y \u0111\u1ee7, ch\xednh x\xe1c, k\u1ecbp th\u1eddi s\u1ef1 thay \u0111\u1ed5i th\xf4ng tin; bao g\u1ed3m c\u1ea3 thi\u1ec7t h\u1ea1i v\u1ec1 t\xe0i ch\xednh, chi ph\xed ph\xe1t sinh do th\xf4ng tin cung c\u1ea5p sai ho\u1eb7c kh\xf4ng th\u1ed1ng nh\u1ea5t."}),Object(oe.jsx)("p",{children:"- Ph\u1ed1i h\u1ee3p v\u1edbi ch\xfang t\xf4i, c\u01a1 quan nh\xe0 n\u01b0\u1edbc c\xf3 th\u1ea9m quy\u1ec1n ho\u1eb7c b\xean th\u1ee9 ba trong tr\u01b0\u1eddng h\u1ee3p ph\xe1t sinh c\xe1c v\u1ea5n \u0111\u1ec1 \u1ea3nh h\u01b0\u1edfng \u0111\u1ebfn t\xednh b\u1ea3o m\u1eadt d\u1eef li\u1ec7u c\xe1 nh\xe2n c\u1ee7a Kh\xe1ch h\xe0ng."}),Object(oe.jsx)("p",{children:"- T\u1ef1 b\u1ea3o v\u1ec7 d\u1eef li\u1ec7u c\xe1 nh\xe2n c\u1ee7a m\xecnh; y\xeau c\u1ea7u c\xe1c t\u1ed5 ch\u1ee9c, c\xe1 nh\xe2n kh\xe1c c\xf3 li\xean quan b\u1ea3o v\u1ec7 d\u1eef li\u1ec7u c\xe1 nh\xe2n c\u1ee7a m\xecnh; ch\u1ee7 \u0111\u1ed9ng \xe1p d\u1ee5ng c\xe1c bi\u1ec7n ph\xe1p nh\u1eb1m b\u1ea3o v\u1ec7 d\u1eef li\u1ec7u c\xe1 nh\xe2n c\u1ee7a Kh\xe1ch h\xe0ng trong qu\xe1 tr\xecnh s\u1eed d\u1ee5ng s\u1ea3n ph\u1ea9m, d\u1ecbch v\u1ee5 c\u1ee7a Mioto; th\xf4ng b\xe1o k\u1ecbp th\u1eddi cho ch\xfang t\xf4i khi ph\xe1t hi\u1ec7n th\u1ea5y c\xf3 sai s\xf3t, nh\u1ea7m l\u1eabn v\u1ec1 d\u1eef li\u1ec7u c\xe1 nh\xe2n ho\u1eb7c nghi ng\u1edd d\u1eef li\u1ec7u c\xe1 nh\xe2n \u0111ang b\u1ecb x\xe2m ph\u1ea1m."}),Object(oe.jsx)("p",{children:"- T\xf4n tr\u1ecdng, b\u1ea3o v\u1ec7 d\u1eef li\u1ec7u c\xe1 nh\xe2n c\u1ee7a ng\u01b0\u1eddi kh\xe1c."}),Object(oe.jsx)("p",{children:"- T\u1ef1 ch\u1ecbu tr\xe1ch nhi\u1ec7m \u0111\u1ed1i v\u1edbi nh\u1eefng th\xf4ng tin, d\u1eef li\u1ec7u m\xe0 Kh\xe1ch h\xe0ng t\u1ea1o l\u1eadp, cung c\u1ea5p tr\xean kh\xf4ng gian m\u1ea1ng; t\u1ef1 ch\u1ecbu tr\xe1ch nhi\u1ec7m trong tr\u01b0\u1eddng h\u1ee3p d\u1eef li\u1ec7u c\xe1 nh\xe2n b\u1ecb r\xf2 r\u1ec9, x\xe2m ph\u1ea1m do l\u1ed7i c\u1ee7a m\xecnh."}),Object(oe.jsx)("p",{children:"- Th\u01b0\u1eddng xuy\xean c\u1eadp nh\u1eadt c\xe1c quy \u0111\u1ecbnh, ch\xednh s\xe1ch li\xean quan \u0111\u1ebfn vi\u1ec7c b\u1ea3o v\u1ec7 v\xe0 x\u1eed l\xfd d\u1eef li\u1ec7u c\xe1 nh\xe2n c\u1ee7a Mioto trong t\u1eebng th\u1eddi k\u1ef3 \u0111\u01b0\u1ee3c th\xf4ng b\xe1o t\u1edbi Kh\xe1ch h\xe0ng qua n\u1ec1n t\u1ea3ng."}),Object(oe.jsx)("p",{children:"- Th\u1ef1c hi\u1ec7n quy \u0111\u1ecbnh ph\xe1p lu\u1eadt v\u1ec1 b\u1ea3o v\u1ec7 d\u1eef li\u1ec7u c\xe1 nh\xe2n v\xe0 tham gia ph\xf2ng, ch\u1ed1ng c\xe1c h\xe0nh vi vi ph\u1ea1m quy \u0111\u1ecbnh v\u1ec1 b\u1ea3o v\u1ec7 d\u1eef li\u1ec7u c\xe1 nh\xe2n."}),Object(oe.jsx)("p",{children:"- C\xe1c ngh\u0129a v\u1ee5 kh\xe1c theo quy \u0111\u1ecbnh ph\xe1p lu\u1eadt."}),Object(oe.jsx)("h6",{children:"14. C\u01a1 ch\u1ebf ti\u1ebfp nh\u1eadn v\xe0 gi\u1ea3i quy\u1ebft khi\u1ebfu n\u1ea1i li\xean quan \u0111\u1ebfn vi\u1ec7c d\u1eef c\xe1 nh\xe2n kh\xe1ch h\xe0ng b\u1ecb s\u1eed d\u1ee5ng sai m\u1ee5c \u0111\xedch ho\u1eb7c ph\u1ea1m vi \u0111\xe3 th\xf4ng b\xe1o"}),Object(oe.jsx)("p",{children:"Kh\xe1ch h\xe0ng c\xf3 quy\u1ec1n g\u1eedi khi\u1ebfu n\u1ea1i li\xean quan \u0111\u1ebfn vi\u1ec7c th\u1ef1c hi\u1ec7n Ch\xednh s\xe1ch b\u1ea3o v\u1ec7 d\u1eef li\u1ec7u c\xe1 nh\xe2n \u0111\u1ebfn Mioto. Khi ti\u1ebfp nh\u1eadn, Mioto s\u1ebd x\xe1c nh\u1eadn l\u1ea1i th\xf4ng tin, ph\u1ea3n h\u1ed3i l\xfd do v\xe0 h\u01b0\u1edbng d\u1eabn Kh\xe1ch h\xe0ng kh\xf4i ph\u1ee5c v\xe0 b\u1ea3o m\u1eadt l\u1ea1i th\xf4ng tin. C\xe1c b\u01b0\u1edbc th\u1ef1c hi\u1ec7n nh\u01b0 sau:"}),Object(oe.jsx)("p",{children:"B\u01b0\u1edbc 1: Ti\u1ebfp nh\u1eadn khi\u1ebfu n\u1ea1i"}),Object(oe.jsx)("p",{children:"Kh\xe1ch h\xe0ng g\u1eedi khi\u1ebfu n\u1ea1i cho Mioto theo c\xe1c k\xeanh nh\u01b0 email, \u0111i\u1ec7n tho\u1ea1i ho\u1eb7c g\u1eedi v\u0103n b\u1ea3n tr\u1ef1c ti\u1ebfp \u0111\u1ebfn \u0111\u1ecba ch\u1ec9 c\u1ee7a Mioto. B\u1ed9 ph\u1eadn CSKH c\u1ee7a Mioto c\xf3 tr\xe1ch nhi\u1ec7m ti\u1ebfp nh\u1eadn v\xe0 y\xeau c\u1ea7u kh\xe1ch h\xe0ng n\xeau r\xf5 n\u1ed9i dung khi\u1ebfu n\u1ea1i v\xe0 cung c\u1ea5p c\xe1c th\xf4ng tin, t\xe0i li\u1ec7u c\xf3 li\xea