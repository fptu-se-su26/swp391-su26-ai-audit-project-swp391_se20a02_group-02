en:"6. Ph\u01b0\u01a1ng ti\u1ec7n v\xe0 c\xf4ng c\u1ee5 \u0111\u1ec3 ng\u01b0\u1eddi d\xf9ng ti\u1ebfp c\u1eadn v\xe0 ch\u1ec9nh s\u1eeda d\u1eef li\u1ec7u c\xe1 nh\xe2n c\u1ee7a m\xecnh"}),Object(oe.jsx)("p",{children:"Kh\xe1ch h\xe0ng c\xf3 quy\u1ec1n t\u1ef1 ki\u1ec3m tra, c\u1eadp nh\u1eadt, \u0111i\u1ec1u ch\u1ec9nh ho\u1eb7c h\u1ee7y b\u1ecf th\xf4ng tin c\xe1 nh\xe2n c\u1ee7a m\xecnh b\u1eb1ng c\xe1ch \u0111\u0103ng nh\u1eadp v\xe0o t\xe0i kho\u1ea3n v\xe0 ch\u1ec9nh s\u1eeda th\xf4ng tin c\xe1 nh\xe2n ho\u1eb7c y\xeau c\u1ea7u Mioto.vn th\u1ef1c hi\u1ec7n vi\u1ec7c n\xe0y."}),Object(oe.jsx)("p",{children:"Kh\xe1ch h\xe0ng c\xf3 quy\u1ec1n g\u1eedi khi\u1ebfu n\u1ea1i v\u1ec1 vi\u1ec7c l\u1ed9 th\xf4ng tin c\xe1 nh\xe2n cho b\xean th\u1ee9 3 \u0111\u1ebfn Ban qu\u1ea3n tr\u1ecb c\u1ee7a S\xe0n giao d\u1ecbch TM\u0110T Mioto.vn. Khi ti\u1ebfp nh\u1eadn nh\u1eefng ph\u1ea3n h\u1ed3i n\xe0y, Mioto.vn s\u1ebd x\xe1c nh\u1eadn l\u1ea1i th\xf4ng tin, c\xf3 tr\xe1ch nhi\u1ec7m tr\u1ea3 l\u1eddi l\xfd do v\xe0 h\u01b0\u1edbng d\u1eabn kh\xe1ch h\xe0ng kh\xf4i ph\u1ee5c v\xe0 b\u1ea3o m\u1eadt th\xf4ng tin."}),Object(oe.jsx)("p",{className:"subtitle",children:"7. Cam k\u1ebft b\u1ea3o m\u1eadt th\xf4ng tin c\xe1 nh\xe2n"}),Object(oe.jsx)("p",{children:"Th\xf4ng tin c\xe1 nh\xe2n c\u1ee7a th\xe0nh vi\xean tr\xean S\xe0n giao d\u1ecbch TM\u0110T Mioto.vn \u0111\u01b0\u1ee3c cam k\u1ebft b\u1ea3o m\u1eadt tuy\u1ec7t \u0111\u1ed1i theo ch\xednh s\xe1ch b\u1ea3o v\u1ec7 th\xf4ng tin c\xe1 nh\xe2n c\u1ee7a Mioto.vn. Vi\u1ec7c thu th\u1eadp v\xe0 s\u1eed d\u1ee5ng th\xf4ng tin c\u1ee7a m\u1ed7i th\xe0nh vi\xean ch\u1ec9 \u0111\u01b0\u1ee3c th\u1ef1c hi\u1ec7n khi c\xf3 s\u1ef1 \u0111\u1ed3ng \xfd c\u1ee7a kh\xe1ch h\xe0ng \u0111\xf3 tr\u1eeb nh\u1eefng tr\u01b0\u1eddng h\u1ee3p ph\xe1p lu\u1eadt c\xf3 quy \u0111\u1ecbnh kh\xe1c."}),Object(oe.jsx)("p",{children:"Kh\xf4ng s\u1eed d\u1ee5ng, kh\xf4ng chuy\u1ec3n giao, cung c\u1ea5p hay ti\u1ebft l\u1ed9 cho b\xean th\u1ee9 ba n