b.png";const Fp=[{id:"micarro-sale-1",title:"Nh\xe2n Vi\xean Kinh Doanh",summary:{salary:"10 - 15 tri\u1ec7u",location:"TP. H\u1ed3 Ch\xed Minh",formOfEmp:"Full time",experience:"Kh\xf4ng y\xeau c\u1ea7u kinh nghi\u1ec7m"},details:{general:{salary:"10 - 15 tri\u1ec7u",experience:"Kh\xf4ng y\xeau c\u1ea7u",formOfEmp:"Full time",diploma:"T\u1ed1t nghi\u1ec7p C\u0110/\u0110H",sex:"N\u1eef",number:"3 ng\u01b0\u1eddi",location:"Y\xean Th\u1ebf, P. T\xe2n S\u01a1n Ho\xe0, TP. HCM."},jobDescription:["G\u1ecdi \u0111i\u1ec7n t\u01b0 v\u1ea5n, gi\u1edbi thi\u1ec7u d\u1ecbch v\u1ee5 cho thu\xea xe theo th\xe1ng cho kh\xe1ch h\xe0ng..","Gi\u1ea3i \u0111\xe1p th\u1eafc m\u1eafc, ch\u1ed1t h\u1ee3p \u0111\u1ed3ng & ch\u0103m s\xf3c kh\xe1ch h\xe0ng sau b\xe1n.","C\u1eadp nh\u1eadt th\xf4ng tin kh\xe1ch h\xe0ng l\xean h\u1ec7 th\u1ed1ng CRM.","Ph\u1ed1i h\u1ee3p v\u1edbi c\xe1c b\u1ed9 ph\u1eadn li\xean quan \u0111\u1ec3 \u0111\u1ea1t ch\u1ec9 ti\xeau.","B\xe1o c\xe1o k\u1ebft qu\u1ea3 c\xf4ng vi\u1ec7c \u0111\u1ecbnh k\u1ef3 cho Qu\u1ea3n l\xfd Kinh doanh."],jobRequirements:["N\u1eef: sinh n\u0103m 2003 - 1997.","T\u1ed1t nghi\u1ec7p Cao \u0111\u1eb3ng/\u0110\u1ea1i h\u1ecdc (\u01b0u ti\xean QTKD, Marketing, Kinh t\u1ebf\u2026).","Kh\xf4ng y\xeau c\u1ea7u kinh nghi\u1ec7m, \u0111\u01b0\u1ee3c \u0111\xe0o t\u1ea1o t\u1eeb \u0111\u1ea7u.","K\u1ef9 n\u0103ng giao ti\u1ebfp, t\u01b0 v\u1ea5n v\xe0 thuy\u1ebft ph\u1ee5c t\u1ed1t.","C\xf3 kh\u1ea3 n\u0103ng l\xe0m vi\u1ec7c \u0111\u1ed9c l\u1eadp v\xe0 theo nh\xf3m.","Bi\u1ebft s\u1eed d\u1ee5ng CRM, Excel l\xe0 l\u1ee3i th\u1ebf.","Ch\u1ecbu \u0111\u01b0\u1ee3c \xe1p l\u1ef1c c\xf4ng vi\u1ec7c, c\u1ea9n th\u1eadn & c\xf3 tinh th\u1ea7n tr\xe1ch nhi\u1ec7m.","C\xf3 laptop c\xe1 nh\xe2n ph\u1ee5c v\u1ee5 c\xf4ng vi\u1ec7c.","Th\u1eddi gian l\xe0m vi\u1ec7c: 8:30 - 17:30 t\u1eeb Th\u1ee9 2 - Th\u1ee9 6 & 8:30 - 12:00 Th\u1ee9 7.","\u0110\u1ecba \u0111i\u1ec3m: Y\xean Th\u1ebf, P. T\xe2n S\u01a1n Ho\xe0, TP. HCM."],benefit:["M\u1ee9c l\u01b0\u01a1ng: t\u1eeb 10 - 15 tri\u1ec7u/th\xe1ng, l\u01b0\u01a1ng c\u1ee9ng 7 - 9  tri\u1ec7u & th\u01b0\u1edfng theo hi\u1ec7u su\u1ea5t.","Th\u1eed vi\u1ec7c 2 th\xe1ng: 100% l\u01b0\u01a1ng.","H\u1ed7 tr\u1ee3 c\u01b0\u1edbc \u0111i\u1ec7n tho\u1ea1i.","\u0110\u01b0\u1ee3c tham gia BHXH, BHYT v\xe0 c\xe1c ch\u1ebf \u0111\u1ed9 theo quy \u0111\u1ecbnh c\u1ee7a ph\xe1p lu\u1eadt.","Th\u01b0\u1edfng l\u01b0\u01a1ng th\xe1ng 13, th\u01b0\u1edfng T\u1ebft theo ch\xednh s\xe1ch c\xf4ng ty.","X\xe9t t\u0103ng l\u01b0\u01a1ng \u0111\u1ecbnh k\u1ef3 h\xe0ng n\u0103m.","H\u01b0\u1edfng c\xe1c ch\u1ebf \u0111\u1ed9 ph\xfac l\u1ee3i, tr\u1ee3 c\u1ea5p theo quy \u0111\u1ecbnh c\xf4ng ty.","Tr\xe0, c\xe0 ph\xea, tr\xe1i c\xe2y t\u1ea1i v\u0103n ph\xf2ng.","M\xf4i tr\u01b0\u1eddng l\xe0m vi\u1ec7c tr\u1ebb trung, n\u0103ng \u0111\u1ed9ng, th\xe2n thi\u1ec7n."]}},{id:"op-1",title:"Nh\xe2n Vi\xean Ch\u0103m S\xf3c Kh\xe1ch H\xe0ng",summary:{salary:"8 - 9 tri\u1ec7u",location:"TP. H\u1ed3 Ch\xed Minh",formOfEmp:"Full time",experience:"Kh\xf4ng y\xeau c\u1ea7u kinh nghi\u1ec7m"},details:{general:{salary:"8 - 9 tri\u1ec7u",experience:"Kh\xf4ng y\xeau c\u1ea7u",formOfEmp:"Full time",diploma:"T\u1ed1t nghi\u1ec7p C\u0110/\u0110H",sex:"N\u1eef",number:"3 ng\u01b0\u1eddi",location:"Y\xean Th\u1ebf, P. T\xe2n S\u01a1n Ho\xe0, TP. HCM."},jobDescription:["H\u1ed7 tr\u1ee3 t\u01b0 v\u1ea5n & ch\u0103m s\xf3c kh\xe1ch h\xe0ng xuy\xean su\u1ed1t qu\xe1 tr\xecnh \u0111\u1eb7t xe \u0111\u1ebfn khi k\u1ebft th\xfac chuy\u1ebfn \u0111i.","Gi\u1ea3i \u0111\xe1p c\xe1c th\u1eafc m\u1eafc & \u0111\u1ea3m b\u1ea3o tr\u1ea3i nghi\u1ec7m d\u1ecbch v\u1ee5 \u0111\u01b0\u1ee3c t\u1ed1t nh\u1ea5t.","Ph\u1ed1i h\u1ee3p x\u1eed l\xfd s\u1ef1 c\u1ed1: L\xe0m vi\u1ec7c c\xe1c ph\xf2ng ban li\xean quan \u0111\u1ec3 x\u1eed l\xfd c\xe1c v\u1ea5n \u0111\u1ec1 ph\xe1t sinh trong qu\xe1 tr\xecnh kh\xe1ch thu\xea xe.","Ki\u1ec3m tra & x\xe1c th\u1ef1c th\xf4ng tin h\u1ed3 s\u01a1 c\u1ee7a kh\xe1ch h\xe0ng, \u0111\u1ea3m b\u1ea3o t\xednh ch\xednh x\xe1c, an to\xe0n trong qu\xe1 tr\xecnh giao d\u1ecbch qua app.","Tham gia c\u1ea3i ti\u1ebfn s\u1ea3n ph\u1ea9m: tr\u1ea3i nghi\u1ec7m, test c\xe1c t\xednh n\u0103ng m\u1edbi tr\xean app/website, ghi nh\u1eadn ph\u1ea3n h\u1ed3i t\u1eeb kh\xe1ch h\xe0ng \u0111\u1ec3 c\u1ea3i thi\u1ec7n s\u1ea3n ph\u1ea9m.","B\xe1o c\xe1o k\u1ebft qu\u1ea3 c\xf4ng vi\u1ec7c \u0111\u1ecbnh k\u1ef3 cho Team Leader/Qu\u1ea3n l\xfd.","Th\u1ef1c hi\u1ec7n theo ph\xe2n c\xf4ng c\u1ee7a Team Leader/Qu\u1ea3n l\xfd."],jobRequirements:["N\u1eef: sinh n\u0103m 2003 - 1999.","T\u1ed1t nghi\u1ec7p Cao \u0111\u1eb3ng/\u0110\u1ea1i h\u1ecdc (kh\xf4ng y\xeau c\u1ea7u chuy\xean ng\xe0nh).","Kh\xf4ng y\xeau c\u1ea7u kinh nghi\u1ec7m - \u0111\u01b0\u1ee3c \u0111\xe0o t\u1ea1o t\u1eeb \u0111\u1ea7u.","Giao ti\u1ebfp t\u1ed1t, c\xf3 t\u01b0 duy d\u1ecbch v\u1ee5 kh\xe1ch h\xe0ng.","\u0110i\u1ec1m t\u0129nh, c\u1ea9n th\u1eadn, c\xf3 tr\xe1ch nhi\u1ec7m.","Ch\u1ee7 \u0111\u1ed9ng, c\u1ea7u ti\u1ebfn, ch\u1ecbu \u0111\u01b0\u1ee3c \xe1p l\u1ef1c.","C\xf3 kh\u1ea3 n\u0103ng l\xe0m vi\u1ec7c \u0111\u1ed9c l\u1eadp v\xe0 theo nh\xf3m.","C\xf3 laptop c\xe1 nh\xe2n ph\u1ee5c v\u1ee5 c\xf4ng vi\u1ec7c.","\u0110\u1ecba \u0111i\u1ec3m: Y\xean Th\u1ebf, P. T\xe2n S\u01a1n Ho\xe0, TP. HCM.","Th\u1eddi gian l\xe0m vi\u1ec7c: Xoay ca S\xe1ng & T\u1ed1i linh ho\u1ea1t (07:00 - 22:00).","C\xf3 xoay ca linh ho\u1ea1t theo s\u1eafp x\u1ebfp c\u1ee7a Team.","C\xf3 th\u1ec3 t\u0103ng ca (OT) v\xe0o bu\u1ed5i t\u1ed1i, cu\u1ed1i tu\u1ea7n, l\u1ec5/T\u1ebft khi c\u1ea7n."],benefit:["M\u1ee9c l\u01b0\u01a1ng: t\u1eeb 8 - 9 tri\u1ec7u/th\xe1ng & ph\u1ee5 c\u1ea5p tr\u1ef1c bu\u1ed5i t\u1ed1i, cu\u1ed1i tu\u1ea7n, l\u1ec5 T\u1ebft.","Th\u1eed vi\u1ec7c 2 th\xe1ng: 100% l\u01b0\u01a1ng.","H\u1ed7 tr\u1ee3 c\u01b0\u1edbc \u0111i\u1ec7n tho\u1ea1i.","\u0110\u01b0\u1ee3c tham gia BHXH, BHYT v\xe0 c\xe1c ch\u1ebf \u0111\u1ed9 theo quy \u0111\u1ecbnh c\u1ee7a ph\xe1p lu\u1eadt.","Th\u01b0\u1edfng l\u01b0\u01a1ng th\xe1ng 13, th\u01b0\u1edfng T\u1ebft theo ch\xednh s\xe1ch c\xf4ng ty.","X\xe9t t\u0103ng l\u01b0\u01a1ng \u0111\u1ecbnh k\u1ef3 h\xe0ng n\u0103m.","H\u01b0\u1edfng c\xe1c ch\u1ebf \u0111\u1ed9 ph\xfac l\u1ee3i, tr\u1ee3 c\u1ea5p theo quy \u0111\u1ecbnh c\xf4ng ty.","Tr\xe0, c\xe0 ph\xea, tr\xe1i c\xe2y t\u1ea1i v\u0103n ph\xf2ng.","M\xf4i tr\u01b0\u1eddng l\xe0m vi\u1ec7c tr\u1ebb trung, n\u0103ng \u0111\u1ed9ng, th\xe2n thi\u1ec7n."]}},{id:"bd-1",title:"Nh\xe2n Vi\xean Ph\xe1t Tri\u1ec3n \u0110\u1ed1i T\xe1c (Ch\u1ee7 xe)",summary:{salary:"8.5 - 9.5 tri\u1ec7u",location:"TP. H\u1ed3 Ch\xed Minh",formOfEmp:"Full time",experience:"Kh\xf4ng y\xeau c\u1ea7u kinh nghi\u1ec7m"},details:{general:{salary:"8.5 - 9.5 tri\u1ec7u",experience:"Kh\xf4ng y\xeau c\u1ea7u",formOfEmp:"Full time",diploma:"T\u1ed1t nghi\u1ec7p C\u0110/\u0110H",sex:"N\u1eef",number:"2 ng\u01b0\u1eddi",location:"Y\xean Th\u1ebf, P. T\xe2n S\u01a1n Ho\xe0, TP. HCM."},jobDescription:["T\u01b0 v\u1ea5n & onboarding ch\u1ee7 xe m\u1edbi.","\u0110\u1ed3ng h\xe0nh & h\u1ed7 tr\u1ee3 ch\u1ee7 xe v\u1eadn h\xe0nh cho thu\xea hi\u1ec7u qu\u1ea3.","Ph\u1ed1i h\u1ee3p x\u1eed l\xfd s\u1ef1 c\u1ed1: L\xe0m vi\u1ec7c c\xe1c ph\xf2ng ban li\xean quan \u0111\u1ec3 x\u1eed l\xfd c\xe1c v\u1ea5n \u0111\u1ec1 ph\xe1t sinh trong qu\xe1 tr\xecnh ch\u1ee7 xe cho thu\xea.","Tham gia c\u1ea3i ti\u1ebfn s\u1ea3n ph\u1ea9m: tr\u1ea3i nghi\u1ec7m, test c\xe1c t\xednh n\u0103ng m\u1edbi tr\xean app/website, ghi nh\u1eadn ph\u1ea3n h\u1ed3i t\u1eeb ch\u1ee7 xe \u0111\u1ec3 c\u1ea3i thi\u1ec7n s\u1ea3n ph\u1ea9m.","B\xe1o c\xe1o k\u1ebft qu\u1ea3 c\xf4ng vi\u1ec7c \u0111\u1ecbnh k\u1ef3 cho Team Leader/Qu\u1ea3n l\xfd.","Th\u1ef1c hi\u1ec7n theo ph\xe2n c\xf4ng c\u1ee7a Team Leader/Qu\u1ea3n l\xfd."],jobRequirements:["N\u1eef: sinh n\u0103m 2003 - 1999.","T\u1ed1t nghi\u1ec7p Cao \u0111\u1eb3ng/\u0110\u1ea1i h\u1ecdc (kh\xf4ng y\xeau c\u1ea7u chuy\xean ng\xe0nh).","Kh\xf4ng y\xeau c\u1ea7u kinh nghi\u1ec7m - \u0111\u01b0\u1ee3c \u0111\xe0o t\u1ea1o t\u1eeb \u0111\u1ea7u.","Giao ti\u1ebfp t\u1ed1t, c\xf3 t\u01b0 duy d\u1ecbch v\u1ee5 kh\xe1ch h\xe0ng.","\u0110i\u1ec1m t\u0129nh, c\u1ea9n th\u1eadn, c\xf3 tr\xe1ch nhi\u1ec7m.","Ch\u1ee7 \u0111\u1ed9ng, c\u1ea7u ti\u1ebfn, ch\u1ecbu \u0111\u01b0\u1ee3c \xe1p l\u1ef1c.","C\xf3 kh\u1ea3 n\u0103ng l\xe0m vi\u1ec7c \u0111\u1ed9c l\u1eadp v\xe0 theo nh\xf3m.","C\xf3 laptop c\xe1 nh\xe2n ph\u1ee5c v\u1ee5 c\xf4ng vi\u1ec7c.","Th\u1eddi gian l\xe0m vi\u1ec7c: 8:30 - 17:30 t\u1eeb Th\u1ee9 2 - Th\u1ee9 6 & 8:30 - 12:00 Th\u1ee9 7.","\u0110\u1ecba \u0111i\u1ec3m: Y\xean Th\u1ebf, P. T\xe2n S\u01a1n Ho\xe0, TP. HCM."],benefit:["M\u1ee9c l\u01b0\u01a1ng: t\u1eeb 8.5 - 9.5 tri\u1ec7u/th\xe1ng & ph\u1ee5 c\u1ea5p tr\u1ef1c cu\u1ed1i tu\u1ea7n, l\u1ec5 T\u1ebft.","Th\u1eed vi\u1ec7c 2 th\xe1ng: 100% l\u01b0\u01a1ng.","H\u1ed7 tr\u1ee3 c\u01b0\u1edbc \u0111i\u1ec7n tho\u1ea1i.","\u0110\u01b0\u1ee3c tham gia BHXH, BHYT v\xe0 c\xe1c ch\u1ebf \u0111\u1ed9 theo quy \u0111\u1ecbnh c\u1ee7a ph\xe1p lu\u1eadt.","Th\u01b0\u1edfng l\u01b0\u01a1ng th\xe1ng 13, th\u01b0\u1edfng T\u1ebft theo ch\xednh s\xe1ch c\xf4ng ty.","X\xe9t t\u0103ng l\u01b0\u01a1ng \u0111\u1ecbnh k\u1ef3 h\xe0ng n\u0103m.","H\u01b0\u1edfng c\xe1c ch\u1ebf \u0111\u1ed9 ph\xfac l\u1ee3i, tr\u1ee3 c\u1ea5p theo quy \u0111\u1ecbnh c\xf4ng ty.","Tr\xe0, c\xe0 ph\xea, tr\xe1i c\xe2y t\u1ea1i v\u0103n ph\xf2ng.","M\xf4i tr\u01b0\u1eddng l\xe0m vi\u1ec7c tr\u1ebb trung, n\u0103ng \u0111\u1ed9ng, th\xe2n thi\u1ec7n."]}},{id:"marketing-1",title:"Nh\xe2n Vi\xean Digital Marketing",summary:{salary:"8.5 - 10 tri\u1ec7u",location:"TP. H\u1ed3 Ch\xed Minh",formOfEmp:"Full time",experience:"T\u1ed1i thi\u1ec3u 6 th\xe1ng kinh nghi\u1ec7m"},details:{general:{salary:"8.5 - 10 tri\u1ec7u",experience:"T\u1ed1i thi\u1ec3u 6 th\xe1ng",formOfEmp:"Full time",diploma:"T\u1ed1t nghi\u1ec7p C\u0110/\u0110H",sex:"N\u1eef",number:"1 ng\u01b0\u1eddi",location:"Y\xean Th\u1ebf, P. T\xe2n S\u01a1n Ho\xe0, TP. HCM."},jobDescription:[{headline:!0,content:"Digital / Performance Marketing"},"Ph\u1ed1i h\u1ee3p c\xf9ng Team Leader x\xe2y d\u1ef1ng & tri\u1ec3n khai k\u1ebf ho\u1ea1ch Digital Marketing theo t\u1eebng giai \u0111o\u1ea1n kinh doanh.","Tri\u1ec3n khai, qu\u1ea3n l\xfd & t\u1ed1i \u01b0u c\xe1c chi\u1ebfn d\u1ecbch qu\u1ea3ng c\xe1o tr\xean c\xe1c k\xeanh online nh\u01b0 Google, Facebook, TikTok, ZNS, \u2026","Theo d\xf5i ng\xe2n s\xe1ch & hi\u1ec7u qu\u1ea3 chi\u1ebfn d\u1ecbch, \u0111\u1ea3m b\u1ea3o \u0111\u1ea1t m\u1ee5c ti\xeau \u0111\u1ec1 ra.","Ph\xe2n t\xedch d\u1eef li\u1ec7u & \u0111\u1ec1 xu\u1ea5t ph\u01b0\u01a1ng \xe1n t\u1ed1i \u01b0u ng\xe2n s\xe1ch, hi\u1ec7u su\u1ea5t qu\u1ea3ng c\xe1o.","Theo d\xf5i c\xe1c ch\u1ec9 s\u1ed1 \u0111o l\u01b0\u1eddng hi\u1ec7u qu\u1ea3 (KPIs) c\u1ee7a t\u1eebng chi\u1ebfn d\u1ecbch.","\u0110\xe1nh gi\xe1 hi\u1ec7u qu\u1ea3 theo t\u1eebng nh\xf3m s\u1ea3n ph\u1ea9m / d\u1ecbch v\u1ee5 kinh doanh.","T\u1ed5ng h\u1ee3p key learnings sau m\u1ed7i chi\u1ebfn d\u1ecbch \u0111\u1ec3 c\u1ea3i thi\u1ec7n hi\u1ec7u qu\u1ea3 cho c\xe1c ho\u1ea1t \u0111\u1ed9ng ti\u1ebfp theo.",{headline:!0,content:"Content & Creative Support"},"Ph\u1ed1i h\u1ee3p l\xean \xfd t\u01b0\u1edfng n\u1ed9i dung cho ads (angle, hook, insight kh\xe1ch h\xe0ng).","Vi\u1ebft/\u0111i\u1ec1u ch\u1ec9nh n\u1ed9i dung ads: headline, caption,\u2026","H\u1ed7 tr\u1ee3 Team Leader l\xe0m vi\u1ec7c v\u1edbi KOL/KOC & agency."],jobRequirements:["N\u1eef: \u0111\u1ed9 tu\u1ed5i 2003 - 2000.","T\u1ed1t nghi\u1ec7p Cao \u0111\u1eb3ng / \u0110\u1ea1i h\u1ecdc (\u01b0u ti\xean QTKD, Marketing, Th\u01b0\u01a1ng m\u1ea1i \u0111i\u1ec7n t\u1eed\u2026).","C\xf3 t\u1ed1i thi\u1ec3u 6 th\xe1ng kinh nghi\u1ec7m trong l\u0129nh v\u1ef1c Marketing.","Y\xeau th\xedch s\u1ea3n ph\u1ea9m c\xf4ng ngh\u1ec7, n\u1ec1n t\u1ea3ng s\u1ed1 ho\u1eb7c ph\u1ea7n m\u1ec1m.","C\xf3 ki\u1ebfn th\u1ee9c c\u01a1 b\u1ea3n v\u1ec1 Marketing & Digital Marketing.","C\xf3 kh\u1ea3 n\u0103ng ph\xe2n t\xedch s\u1ed1 li\u1ec7u & \u0111\xe1nh gi\xe1 hi\u1ec7u qu\u1ea3 chi\u1ebfn d\u1ecbch.","C\xf3 tinh th\u1ea7n s\xe1ng t\u1ea1o, ch\u1ee7 \u0111\u1ed9ng h\u1ecdc h\u1ecfi trong c\xf4ng vi\u1ec7c.","Bi\u1ebft thi\u1ebft k\u1ebf ho\u1eb7c ch\u1ec9nh s\u1eeda video c\u01a1 b\u1ea3n l\xe0 m\u1ed9t l\u1ee3i th\u1ebf.","T\xe1c phong l\xe0m vi\u1ec7c: ch\u0103m ch\u1ec9 \u2013 trung th\u1ef1c \u2013 tr\xe1ch nhi\u1ec7m \u2013 tinh th\u1ea7n h\u1ee3p t\xe1c t\u1ed1t.","C\xf3 laptop c\xe1 nh\xe2n ph\u1ee5c v\u1ee5 c\xf4ng vi\u1ec7c.","Th\u1eddi gian l\xe0m vi\u1ec7c: 8:30 - 17:30 t\u1eeb Th\u1ee9 2 - Th\u1ee9 6 & 8:30 - 12:00 Th\u1ee9 7.","\u0110\u1ecba \u0111i\u1ec3m: Y\xean Th\u1ebf, P. T\xe2n S\u01a1n Ho\xe0, TP. HCM."],benefit:["M\u1ee9c l\u01b0\u01a1ng c\u1ea1nh tranh: t\u1eeb 8.5 -10tr t\xf9y n\u0103ng l\u1ef1c.","Th\u1eed vi\u1ec7c 2 th\xe1ng: 100% l\u01b0\u01a1ng.","\u0110\u01b0\u1ee3c tham gia BHXH, BHYT v\xe0 c\xe1c ch\u1ebf \u0111\u1ed9 theo quy \u0111\u1ecbnh c\u1ee7a ph\xe1p lu\u1eadt.","Th\u01b0\u1edfng l\u01b0\u01a1ng th\xe1ng 13, th\u01b0\u1edfng T\u1ebft theo ch\xednh s\xe1ch c\xf4ng ty.","X\xe9t t\u0103ng l\u01b0\u01a1ng \u0111\u1ecbnh k\u1ef3 h\xe0ng n\u0103m.","H\u01b0\u1edfng c\xe1c ch\u1ebf \u0111\u1ed9 ph\xfac l\u1ee3i, tr\u1ee3 c\u1ea5p theo quy \u0111\u1ecbnh c\xf4ng ty.","Tr\xe0, c\xe0 ph\xea, tr\xe1i c\xe2y t\u1ea1i v\u0103n ph\xf2ng.","M\xf4i tr\u01b0\u1eddng l\xe0m vi\u1ec7c tr\u1ebb trung, n\u0103ng \u0111\u1ed9ng, th\xe2n thi\u1ec7n."]}},{id:"legal-1",title:"Tr\u1ee3 L\xfd Ph\xe1p Ch\u1ebf",summary:{salary:"8.5 - 9.5 tri\u1ec7u",location:"TP. H\u1ed3 Ch\xed Minh",formOfEmp:"Full time",experience:"Kh\xf4ng y\xeau c\u1ea7u kinh nghi\u1ec7m"},details:{general:{salary:"8.5 - 9.5 tri\u1ec7u",experience:"Kh\xf4ng y\xeau c\u1ea7u",formOfEmp:"Full time",diploma:"T\u1ed1t nghi\u1ec7p C\u0110/\u0110H",sex:"N\u1eef",number:"1 ng\u01b0\u1eddi",location:"Y\xean Th\u1ebf, P. T\xe2n S\u01a1n Ho\xe0, TP. HCM."},jobDescription:[{headline:!0,content:"X\u1eed l\xfd s\u1ef1 c\u1ed1 & h\u1ed7 tr\u1ee3 kh\xe1ch h\xe0ng"},"Ti\u1ebfp nh\u1eadn v\xe0 x\u1eed l\xfd c\xe1c v\u1ea5n \u0111\u1ec1 ph\xe1t sinh gi\u1eefa kh\xe1ch thu\xea xe v\xe0 ch\u1ee7 xe.","Ph\u1ed1i h\u1ee3p gi\u1ea3i quy\u1ebft c\xe1c t\xecnh hu\u1ed1ng li\xean quan \u0111\u1ebfn b\u1ea3o hi\u1ec3m, b\u1ed3i th\u01b0\u1eddng, tranh ch\u1ea5p.","\u0110\u1ea3m b\u1ea3o quy\u1ec1n l\u1ee3i h\xe0i h\xf2a gi\u1eefa c\xe1c b\xean v\xe0 tr\u1ea3i nghi\u1ec7m kh\xe1ch h\xe0ng.",{headline:!0,content:"Ph\u1ed1i h\u1ee3p n\u1ed9i b\u1ed9"},"L\xe0m vi\u1ec7c c\xf9ng Chuy\xean vi\xean Ph\xe1p ch\u1ebf \u0111\u1ec3 \u0111\u01b0a ra h\u01b0\u1edbng x\u1eed l\xfd ph\xf9 h\u1ee3p.","Ph\u1ed1i h\u1ee3p v\u1edbi c\xe1c b\u1ed9 ph\u1eadn li\xean quan khi c\u1ea7n thi\u1ebft.",{headline:!0,content:"Theo d\xf5i & c\u1eadp nh\u1eadt"},"Theo d\xf5i ti\u1ebfn \u0111\u1ed9 x\u1eed l\xfd t\u1eebng tr\u01b0\u1eddng h\u1ee3p.","C\u1eadp nh\u1eadt th\xf4ng tin k\u1ecbp th\u1eddi, r\xf5 r\xe0ng \u0111\u1ebfn kh\xe1ch h\xe0ng.",{headline:!0,content:"C\u1ea3i ti\u1ebfn & ph\xe1t tri\u1ec3n"},"\u0110\xf3ng g\xf3p \xfd ki\u1ebfn c\u1ea3i thi\u1ec7n quy tr\xecnh x\u1eed l\xfd s\u1ef1 c\u1ed1.","Tham gia x\xe2y d\u1ef1ng quy tr\xecnh, h\u1ec7 th\u1ed1ng ph\xe1p l\xfd n\u1ed9i b\u1ed9.","C\xf3 c\u01a1 h\u1ed9i tham gia th\xeam c\xe1c ho\u1ea1t \u0111\u1ed9ng ph\xe1t tri\u1ec3n \u0111\u1ed1i t\xe1c (n\u1ebfu ph\xf9 h\u1ee3p).",{headline:!0,content:"C\xf4ng vi\u1ec7c kh\xe1c"},"Th\u1ef1c hi\u1ec7n c\xe1c nhi\u1ec7m v\u1ee5 theo ph\xe2n c\xf4ng c\u1ee7a qu\u1ea3n l\xfd."],jobRequirements:["N\u1eef: sinh n\u0103m 2003 - 2000.","T\u1ed1t nghi\u1ec7p \u0110\u1ea1i h\u1ecdc ho\u1eb7c sinh vi\xean n\u0103m cu\u1ed1i ng\xe0nh Lu\u1eadt ho\u1eb7c li\xean quan.","Kh\xf4ng y\xeau c\u1ea7u kinh nghi\u1ec7m - \u0111\u01b0\u1ee3c \u0111\xe0o t\u1ea1o t\u1eeb \u0111\u1ea7u.","\u0110i\u1ec1m t\u0129nh, c\u1ea9n th\u1eadn, x\u1eed l\xfd t\xecnh hu\u1ed1ng kh\xe9o l\xe9o.","Giao ti\u1ebfp t\u1ed1t, bi\u1ebft l\u1eafng nghe, ch\u1ecbu kh\xf3.","K\u1ef9 n\u0103ng giao ti\u1ebfp t\u1ed1t, c\xf3 kh\u1ea3 n\u0103ng l\xe0m vi\u1ec7c \u0111\u1ed9c l\u1eadp v\xe0 ph\u1ed1i h\u1ee3p nh\xf3m.","C\xf3 laptop c\xe1 nh\xe2n ph\u1ee5c v\u1ee5 c\xf4ng vi\u1ec7c.","S\u1eed d\u1ee5ng t\u1ed1t tin h\u1ecdc v\u0103n ph\xf2ng.","Th\u1eddi gian l\xe0m vi\u1ec7c: 8:30 -17:30 t\u1eeb Th\u1ee9 2 - Th\u1ee9 6 & 8:30 -12:00 Th\u1ee9 7.","\u0110\u1ecba \u0111i\u1ec3m: Y\xean Th\u1ebf, P. T\xe2n S\u01a1n Ho\xe0, TP. HCM."],benefit:["M\u1ee9c l\u01b0\u01a1ng: t\u1eeb 8.5 - 9.5 tri\u1ec7u/th\xe1ng.","Th\u1eed vi\u1ec7c 2 th\xe1ng: 100% l\u01b0\u01a1ng.","H\u1ed7 tr\u1ee3 c\u01b0\u1edbc \u0111i\u1ec7n tho\u1ea1i & c\xf4ng vi\u1ec7c.","\u0110\u01b0\u1ee3c tham gia BHXH, BHYT v\xe0 c\xe1c ch\u1ebf \u0111\u1ed9 theo quy \u0111\u1ecbnh c\u1ee7a ph\xe1p lu\u1eadt.","Th\u01b0\u1edfng l\u01b0\u01a1ng th\xe1ng 13, th\u01b0\u1edfng T\u1ebft theo ch\xednh s\xe1ch c\xf4ng ty.","X\xe9t t\u0103ng l\u01b0\u01a1ng \u0111\u1ecbnh k\u1ef3 h\xe0ng n\u0103m.","H\u01b0\u1edfng c\xe1c ch\u1ebf \u0111\u1ed9 ph\xfac l\u1ee3i, tr\u1ee3 c\u1ea5p theo quy \u0111\u1ecbnh c\xf4ng ty.","Tr\xe0, c\xe0 ph\xea, tr\xe1i c\xe2y t\u1ea1i v\u0103n ph\xf2ng.","M\xf4i tr\u01b0\u1eddng l\xe0m vi\u1ec7c tr\u1ebb trung, n\u0103ng \u0111\u1ed9ng, th\xe2n thi\u1ec7n."]}},{id:"accounting-1",title:"Nh\xe2n Vi\xean K\u1ebf To\xe1n T\u1ed5ng H\u1ee3p",summary:{salary:"15 - 20 tri\u1ec7u",location:"TP. H\u1ed3 Ch\xed Minh",formOfEmp:"Full time",experience:"5 n\u0103m kinh nghi\u1ec7m K\u1ebf to\xe1n & 1 n\u0103m K\u1ebf to\xe1n t\u1ed5ng h\u1ee3p"},details:{general:{salary:"15 - 20 tri\u1ec7u",experience:"5 n\u0103m kinh nghi\u1ec7m K\u1ebf to\xe1n & 1 n\u0103m K\u1ebf to\xe1n t\u1ed5ng h\u1ee3p",formOfEmp:"Full time",diploma:"T\u1ed1t nghi\u1ec7p C\u0110/\u0110H",sex:"N\u1eef",number:"1 ng\u01b0\u1eddi",location:"Y\xean Th\u1ebf, P. T\xe2n S\u01a1n Ho\xe0, TP. HCM."},jobDescription:["H\u1ea1ch to\xe1n & Ki\u1ec3m so\xe1t: Th\u1ef1c hi\u1ec7n h\u1ea1ch to\xe1n to\xe0n b\u1ed9 c\xe1c nghi\u1ec7p v\u1ee5 kinh t\u1ebf ph\xe1t sinh (thu/chi, doanh thu, chi ph\xed, ng\xe2n h\xe0ng...). Ki\u1ec3m so\xe1t t\xednh h\u1ee3p l\xfd, h\u1ee3p l\u1ec7 c\u1ee7a ch\u1ee9ng t\u1eeb \u0111\u1ea7u v\xe0o.","B\xe1o c\xe1o thu\u1ebf: L\u1eadp t\u1edd khai thu\u1ebf GTGT, TNCN, TNDN h\xe0ng th\xe1ng/qu\xfd v\xe0 quy\u1ebft to\xe1n thu\u1ebf n\u0103m. Theo d\xf5i t\xecnh h\xecnh s\u1eed d\u1ee5ng h\xf3a \u0111\u01a1n.","B\xe1o c\xe1o t\xe0i ch\xednh & qu\u1ea3n tr\u1ecb: L\u1eadp b\xe1o c\xe1o t\xe0i ch\xednh h\xe0ng th\xe1ng/n\u0103m, cung c\u1ea5p c\xe1c b\xe1o c\xe1o qu\u1ea3n tr\u1ecb v\u1ec1 d\xf2ng ti\u1ec1n, chi ph\xed v\u1eadn h\xe0nh v\xe0 hi\u1ec7u qu\u1ea3 kinh doanh theo y\xeau c\u1ea7u c\u1ee7a Ban Gi\xe1m \u0111\u1ed1c.","Qu\u1ea3n l\xfd doanh thu & H\xf3a \u0111\u01a1n: Th\u1ef1c hi\u1ec7n xu\u1ea5t h\xf3a \u0111\u01a1n GTGT \u0111\u1ea7u ra cho kh\xe1ch h\xe0ng thu\xea xe. Theo d\xf5i l\u1ecbch thanh to\xe1n \u0111\u1ec3 \u0111\u1ea3m b\u1ea3o ghi nh\u1eadn doanh thu \u0111\xfang k\u1ef3.","L\u01b0u tr\u1eef ch\u1ee9ng t\u1eeb: S\u1eafp x\u1ebfp, l\u01b0u tr\u1eef h\u1ed3 s\u01a1, h\u1ee3p \u0111\u1ed3ng v\xe0 ch\u1ee9ng t\u1eeb k\u1ebf to\xe1n khoa h\u1ecdc, ph\u1ee5c v\u1ee5 vi\u1ec7c gi\u1ea3i tr\xecnh quy\u1ebft to\xe1n thu\u1ebf.","Ki\u1ec3m tra, \u0111\u1ed1i chi\u1ebfu giao d\u1ecbch.","T\u01b0 v\u1ea5n cho Ban Gi\xe1m \u0111\u1ed1c v\u1ec1 c\xe1c v\u1ea5n \u0111\u1ec1 li\xean quan \u0111\u1ebfn thu\u1ebf v\xe0 k\u1ebf to\xe1n.","Ph\u1ed1i h\u1ee3p v\u1edbi c\xe1c ph\xf2ng ban kh\xe1c: kinh doanh, v\u1eadn h\xe0nh.","Ph\u1ed1i h\u1ee3p v\u1edbi ki\u1ec3m to\xe1n (n\u1ebfu c\xf3) \u0111\u1ec3 cung c\u1ea5p s\u1ed1 li\u1ec7u v\xe0 gi\u1ea3i tr\xecnh c\xe1c b\xfat to\xe1n.","Th\u1ef1c hi\u1ec7n c\xe1c nhi\u1ec7m v\u1ee5 kh\xe1c theo s\u1ef1 ph\xe2n c\xf4ng c\u1ee7a Ban Gi\xe1m \u0111\u1ed1c."],jobRequirements:["\u01afu ti\xean N\u1eef.","T\u1ed1t nghi\u1ec7p Cao \u0111\u1eb3ng/\u0110\u1ea1i h\u1ecdc (y\xeau c\u1ea7u ng\xe0nh T\xe0i ch\xednh, K\u1ebf to\xe1n).","T\u1ed1i thi\u1ec3u 01 n\u0103m kinh nghi\u1ec7m v\u1ecb tr\xed K\u1ebf to\xe1n t\u1ed5ng h\u1ee3p ho\u1eb7c 05 n\u0103m kinh nghi\u1ec7m trong l\u0129nh v\u1ef1c K\u1ebf to\xe1n.","Am hi\u1ec3u chu\u1ea9n m\u1ef1c k\u1ebf to\xe1n Vi\u1ec7t Nam (VAS) v\xe0 c\xe1c quy \u0111\u1ecbnh ph\xe1p lu\u1eadt v\u1ec1 thu\u1ebf (GTGT, TNCN, TNDN).","Th\xe0nh th\u1ea1o Microsoft Excel v\xe0 h\u1ec7 th\u1ed1ng eTax.","K\u1ef9 n\u0103ng \u0111\u1ed1i chi\u1ebfu, ki\u1ec3m tra s\u1ed1 li\u1ec7u t\u1ed1t, c\u1ea9n th\u1eadn, t\u1ec9 m\u1ec9 v\xe0 c\xf3 tr\xe1ch nhi\u1ec7m cao.","\u01afu ti\xean \u1ee9ng vi\xean t\u1eebng l\xe0m vi\u1ec7c trong c\xe1c c\xf4ng ty kh\u1edfi nghi\u1ec7p ho\u1eb7c l\u0129nh v\u1ef1c cho thu\xea xe/d\u1ecbch v\u1ee5.","K\u1ef9 n\u0103ng giao ti\u1ebfp t\u1ed1t, c\xf3 kh\u1ea3 n\u0103ng l\xe0m vi\u1ec7c \u0111\u1ed9c l\u1eadp v\xe0 ph\u1ed1i h\u1ee3p nh\xf3m.","C\xf3 laptop c\xe1 nh\xe2n ph\u1ee5c v\u1ee5 c\xf4ng vi\u1ec7c.","Th\u1eddi gian l\xe0m vi\u1ec7c: 8:30 -17:30 t\u1eeb Th\u1ee9 2 - Th\u1ee9 6 & 8:30 -12:00 Th\u1ee9 7.","\u0110\u1ecba \u0111i\u1ec3m: Y\xean Th\u1ebf, P. T\xe2n S\u01a1n Ho\xe0, TP. HCM."],benefit:["M\u1ee9c l\u01b0\u01a1ng: t\u1eeb 15 - 20 tri\u1ec7u/th\xe1ng.","Th\u1eed vi\u1ec7c 2 th\xe1ng: 100% l\u01b0\u01a1ng.","H\u1ed7 tr\u1ee3 c\u01b0\u1edbc \u0111i\u1ec7n tho\u1ea1i & c\xf4ng vi\u1ec7c.","\u0110\u01b0\u1ee3c tham gia BHXH, BHYT v\xe0 c\xe1c ch\u1ebf \u0111\u1ed9 theo quy \u0111\u1ecbnh c\u1ee7a ph\xe1p lu\u1eadt.","Th\u01b0\u1edfng l\u01b0\u01a1ng th\xe1ng 13, th\u01b0\u1edfng T\u1ebft theo ch\xednh s\xe1ch c\xf4ng ty.","X\xe9t t\u0103ng l\u01b0\u01a1ng \u0111\u1ecbnh k\u1ef3 h\xe0ng n\u0103m.","H\u01b0\u1edfng c\xe1c ch\u1ebf \u0111\u1ed9 ph\xfac l\u1ee3i, tr\u1ee3 c\u1ea5p theo quy \u0111\u1ecbnh c\xf4ng ty.","Tr\xe0, c\xe0 ph\xea, tr\xe1i c\xe2y t\u1ea1i v\u0103n ph\xf2ng.","M\xf4i tr\u01b0\u1eddng l\xe0m vi\u1ec7c tr\u1ebb trung, n\u0103ng \u0111\u1ed9ng, th\xe2n thi\u1ec7n."]}}],