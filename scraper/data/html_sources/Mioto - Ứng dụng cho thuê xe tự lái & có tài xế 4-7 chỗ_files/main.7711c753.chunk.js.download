t-primary":""),onClick:()=>n(1),children:[Object(oe.jsx)("h6",{children:"II. Quy \u0111\u1ecbnh chung"}),Object(oe.jsx)("div",{className:"wrap-svg",children:t[1]?Object(oe.jsx)(ee.Hd,{}):Object(oe.jsx)(ee.Xd,{})})]}),t[1]&&Object(oe.jsxs)(oe.Fragment,{children:[Object(oe.jsx)("p",{className:"subtitle",children:"1. \u0110\u1ecbnh ngh\u0129a chung"}),Object(oe.jsxs)("p",{children:["T\xean mi\u1ec1n S\xe0n Giao d\u1ecbch TM\u0110T Mioto.vn: do ",re.k," ph\xe1t tri\u1ec3n v\u1edbi t\xean mi\u1ec1n c\u1ee7a S\xe0n giao d\u1ecbch l\xe0 Mioto.vn.",Object(oe.jsx)("br",{}),"Ng\u01b0\u1eddi b\xe1n (Ch\u1ee7 xe/\u0110\u1ed1i t\xe1c): l\xe0 th\u01b0\u01a1ng nh\xe2n, t\u1ed5 ch\u1ee9c, c\xe1 nh\xe2n c\xf3 nhu c\u1ea7u s\u1eed d\u1ee5ng d\u1ecbch v\u1ee5 c\u1ee7a S\xe0n giao d\u1ecbch \u0111\u1ec3: gi\u1edbi thi\u1ec7u xe cho thu\xea, d\u1ecbch v\u1ee5 cho thu\xea xe\u2026",Object(oe.jsx)("br",{}),"Ng\u01b0\u1eddi mua (Kh\xe1ch thu\xea xe/Kh\xe1ch h\xe0ng): l\xe0 th\u01b0\u01a1ng nh\xe2n, t\u1ed5 ch\u1ee9c, c\xe1 nh\xe2n c\xf3 nhu c\u1ea7u t\xecm hi\u1ec3u th\xf4ng tin v\xe0 s\u1eed d\u1ee5ng d\u1ecbch v\u1ee5 \u0111\u01b0\u1ee3c \u0111\u0103ng b\xe1n tr\xean S\xe0n giao d\u1ecbch. Ng\u01b0\u1eddi mua c\xf3 quy\u1ec1n \u0111\u0103ng k\xfd t\xe0i kho\u1ea3n ho\u1eb7c kh\xf4ng c\u1ea7n \u0111\u0103ng k\xfd.",Object(oe.jsx)("br",{}),"Th\xe0nh vi\xean: l\xe0 bao g\u1ed3m c\u1ea3 Ng\u01b0\u1eddi b\xe1n (Ch\u1ee7 xe) l\u1eabn Ng\u01b0\u1eddi mua (Kh\xe1ch h\xe0ng). Th\xe0nh vi\xean tham gia giao d\u1ecbch tr\xean S\xe0n giao d\u1ecbch l\xe0 th\u01b0\u01a1ng nh\xe2n, t\u1ed5 ch\u1ee9c, c\xe1 nh\xe2n c\xf3 nhu c\u1ea7u thu\xea v\xe0 cho thu\xea tr\xean website Mioto.vn. Th\xe0nh vi\xean ph\u1ea3i \u0111\u0103ng k\xfd k\xea khai ban \u0111\u1ea7u c\xe1c th\xf4ng tin c\xe1 nh\xe2n c\xf3 li\xean quan, \u0111\u01b0\u1ee3c Ban Qu\u1ea3n l\xed S\xe0n giao d\u1ecbch ch\xednh th\u1ee9c c\xf4ng nh\u1eadn v\xe0 \u0111\u01b0\u1ee3c ph\xe9p s\u1eed d\u1ee5ng d\u1ecbch v\u1ee5 do S\xe0n giao d\u1ecbch cung c\u1ea5p.",Object(oe.jsx)("br",{}),"S\u1ea3n ph\u1ea9m/D\u1ecbch v\u1ee5: l\xe0 d\u1ecbch v\u1ee5 cho thu\xea xe \xf4 t\xf4 \u0111\u01b0\u1ee3c giao d\u1ecbch tr\xean S\xe0n giao d\u1ecbch.",Object(oe.jsx)("br",{}),"TM\u0110T: Th\u01b0\u01a1ng m\u1ea1i \u0111i\u1ec7n t\u1eed",Object(oe.jsx)("br",{}),"S\u1edf h\u1eefu tr\xed tu\u1ec7: l\xe0 b\u1ea5t k\u1ef3 b\u1eb1ng s\xe1ng ch\u1ebf, b\u1ea3n quy\u1ec1n, thi\u1ebft k\u1ebf \u0111\u01b0\u1ee3c \u0111\u0103ng k\xfd ho\u1eb7c ch\u01b0a \u0111\u0103ng k\xfd, quy\u1ec1n \u0111\u1ed1i v\u1edbi thi\u1ebft k\u1ebf, nh\xe3n hi\u1ec7u \u0111\u01b0\u1ee3c \u0111\u0103ng k\xfd ho\u1eb7c ch\u01b0a \u0111\u0103ng k\xfd, nh\xe3n hi\u1ec7u d\u1ecbch v\u1ee5 ho\u1eb7c quy\u1ec1n s\u1edf h\u1eefu c\xf4ng nghi\u1ec7p ho\u1eb7c s\u1edf h\u1eefu tr\xed tu\u1ec7 kh\xe1c v\xe0 bao g\u1ed3m c\xe1c \u1ee9ng d\u1ee5ng cho b\u1ea5t k\u1ef3 m\u1ee5c n\xe0o trong nh\u1eefng m\u1ee5c tr\xean S\xe0n giao d\u1ecbch",Object(oe.jsx)("br",{}),"N\u1ed9i dung b\u1ea3n Quy ch\u1ebf n\xe0y tu\xe2n th\u1ee7 theo c\xe1c quy \u0111\u1ecbnh hi\u1ec7n h\xe0nh c\u1ee7a Ph\xe1p lu\u1eadt Vi\u1ec7t Nam. Th\xe0nh vi\xean khi tham gia giao d\u1ecbch tr\xean S\xe0n giao d\u1ecbch ph\u1ea3i t\u1ef1 t\xecm hi\u1ec3u tr\xe1ch nhi\u1ec7m ph\xe1p l\xfd c\u1ee7a m\xecnh \u0111\u1ed1i v\u1edbi Ph\xe1p lu\u1eadt hi\u1ec7n h\xe0nh c\u1ee7a Vi\u1ec7t Nam v\xe0 cam k\u1ebft th\u1ef1c hi\u1ec7n \u0111\xfang nh\u1eefng N\u1ed9i dung trong Quy ch\u1ebf c\u1ee7a S\xe0n giao d\u1ecbch."]}),Object(oe.jsx)("p",{className:"subtitle",children:"2. H\u01b0\u1edbng d\u1eabn s\u1eed d\u1ee5ng chung"}),Object(oe.jsxs)("p",{children:["C\xf4ng ty s\u1ebd c\u1ea5p m\u1ed9t t\xe0i kho\u1ea3n (Account) \u0111\u1ec3 Th\xe0nh vi\xean c\xf3 th\u1ec3 s\u1eed d\u1ee5ng d\u1ecbch tr\xean S\xe0n giao d\u1ecbch trong khu\xf4n kh\u1ed5 \u0110i\u1ec1u kho\u1ea3n s\u1eed d\u1ee5ng \u0111\xe3 \u0111\u1ec1 ra. Th\xe0nh vi\xean s\u1ebd ph\u1ea3i \u0111\u0103ng k\xfd t\xe0i kho\u1ea3n v\u1edbi th\xf4ng tin x\xe1c th\u1ef1c v\u1ec1 b\u1ea3n th\xe2n v\xe0 ph\u1ea3i c\u1eadp nh\u1eadt n\u1ebfu c\xf3 b\u1ea5t k\u1ef3 thay \u0111\u1ed5i n\xe0o. Th\xe0nh vi\xean x\xe1c nh\u1eadn r\u1eb1ng nh\u1eefng th\xf4ng tin cung c\u1ea5p l\xe0 s\u1ef1 th\u1eadt v\xe0 ch\xednh x\xe1c. M\u1ed7i Th\xe0nh vi\xean truy c\u1eadp ph\u1ea3i c\xf3 tr\xe1ch nhi\u1ec7m v\u1edbi m\u1eadt kh\u1ea9u, t\xe0i kho\u1ea3n, ho\u1ea1t \u0111\u1ed9ng c\u1ee7a m\xecnh tr\xean website v\xe0 ph\u1ea3i th\xf4ng b\xe1o cho Ban Qu\u1ea3n l\xed bi\u1ebft khi t\xe0i kho\u1ea3n b\u1ecb truy c\u1eadp tr\xe1i ph\xe9p.",Object(oe.jsx)("br",{}),"C\xf4ng ty kh\xf4ng ch\u1ecbu b\u1ea5t k\u1ef3 tr\xe1ch nhi\u1ec7m n\xe0o, d\xf9 tr\u1ef1c ti\u1ebfp hay gi\xe1n ti\u1ebfp, \u0111\u1ed1i v\u1edbi nh\u1eefng thi\u1ec7t h\u1ea1i ho\u1eb7c m\u1ea5t m\xe1t g\xe2y ra do Th\xe0nh vi\xean kh\xf4ng tu\xe2n th\u1ee7 quy \u0111\u1ecbnh. Th\xe0nh vi\xean s\u1eed d\u1ee5ng d\u1ecbch v\u1ee5 c\u1ee7a S\xe0n giao d\u1ecbch v\u1edbi m\u1ee5c \u0111\xedch duy nh\u1ea5t l\xe0 d\xe0nh cho c\xe1 nh\xe2n m\xecnh. Th\xe0nh vi\xean kh\xf4ng th\u1ec3 \u1ee7y quy\u1ec1n cho ng\u01b0\u1eddi kh\xe1c s\u1eed d\u1ee5ng tr\u1ea1ng th\xe1i kh\xe1ch h\xe0ng c\u1ee7a m\xecnh, v\xe0 kh\xf4ng th\u1ec3 \u1ea5n \u0111\u1ecbnh hay chuy\u1ec3n giao t\xe0i kho\u1ea3n c\u1ee7a m\xecnh cho b\u1ea5t k\u1ef3 ai ho\u1eb7c m\u1ed9t th\u1ef1c th\u1ec3 n\xe0o kh\xe1c. B\xean c\u1ea1nh \u0111\xf3, Th\xe0nh vi\xean \u0111\u1ed3ng \xfd tu\xe2n th\u1ee7 t\u1ea5t c\u1ea3 c\xe1c quy \u0111\u1ecbnh Ph\xe1p lu\u1eadt li\xean quan \u0111\u01b0\u1ee3c \xe1p d\u1ee5ng t\u1ea1i qu\u1ed1c gia c\u1ee7a m\xecnh, t\u1ea1i \u0111\u1ea5t n\u01b0\u1edbc, th\xe0nh ph\u1ed1 m\xe0 Th\xe0nh vi\xean \u0111ang sinh s\u1ed1ng c\xf3 s\u1eed d\u1ee5ng d\u1ecbch v\u1ee5 c\u1ee7a S\xe0n giao d\u1ecbch. Th\xe0nh vi\xean ch\u1ec9 c\xf3 th\u1ec3 truy c\u1eadp v\xe0o website c\u1ee7a S\xe0n giao d\u1ecbch b\u1eb1ng c\xe1ch s\u1eed d\u1ee5ng c\xe1c c\xe1ch th\u1ee9c \u0111\u01b0\u1ee3c cho ph\xe9p.",Object(oe.jsx)("br",{}),"Th\xe0nh vi\xean c\xf3 tr\xe1ch nhi\u1ec7m ph\u1ea3i ki\u1ec3m tra \u0111\u1ec3 \u0111\u1ea3m b\u1ea3o r\u1eb1ng Th\xe0nh vi\xean \u0111\xe3 truy c\u1eadp \u0111\xfang website d\xe0nh cho thi\u1ebft b\u1ecb c\u1ee7a m\xecnh. C\xf4ng ty kh\xf4ng ch\u1ecbu tr\xe1ch nhi\u1ec7m n\u1ebfu Th\xe0nh vi\xean kh\xf4ng c\xf3 m\u1ed9t thi\u1ebft b\u1ecb t\u01b0\u01a1ng th\xedch \u0111\u1ec3 truy c\u1eadp website c\u1ee7a S\xe0n giao d\u1ecbch. C\xf4ng ty gi\u1eef quy\u1ec1n ch\u1ea5m d\u1ee9t th\u1ecfa thu\u1eadn n\xe0y n\u1ebfu Th\xe0nh vi\xean s\u1eed d\u1ee5ng website v\u1edbi m\u1ed9t thi\u1ebft b\u1ecb kh\xf4ng t\u01b0\u01a1ng th\xedch hay kh\xf4ng \u0111\u01b0\u1ee3c cho ph\xe9p.",Object(oe.jsx)("br",{}),"Th\xe0nh vi\xean s\u1ebd ch\u1ec9 s\u1eed d\u1ee5ng website cho c\xe1c m\u1ee5c \u0111\xedch h\u1ee3p ph\xe1p; tuy\u1ec7t \u0111\u1ed1i s\u1ebd kh\xf4ng s\u1eed d\u1ee5ng website \u0111\u1ec3 g\u1eedi v\xe0 l\u01b0u tr\u1eef b\u1ea5t k\u1ef3 d\u1eef li\u1ec7u tr\xe1i ph\xe9p n\xe0o ho\u1eb7c ph\u1ee5c v\u1ee5 c\xe1c m\u1ee5c \u0111\xedch l\u1eeba \u0111\u1ea3o. Th\xe0nh vi\xean s\u1ebd kh\xf4ng s\u1eed d\u1ee5ng website c\u1ee7a S\xe0n giao d\u1ecbch \u0111\u1ec3 g\xe2y phi\u1ec1n to\xe1i, kh\xf3 ch\u1ecbu, b\u1ea5t ti\u1ec7n ho\u1eb7c l\xe0m gi\u1ea3 y\xeau c\u1ea7u \u0111\u1eb7t xe. Th\xe0nh vi\xean s\u1ebd kh\xf4ng g\xe2y \u1ea3nh h\u01b0\u1edfng \u0111\u1ebfn ho\u1ea1t \u0111\u1ed9ng b\xecnh th\u01b0\u1eddng c\u1ee7a S\xe0n giao d\u1ecbch. Th\xe0nh vi\xean s\u1ebd kh\xf4ng c\u1ed1 g\u1eafng g\xe2y t\u1ed5n h\u1ea1i cho S\xe0n giao d\u1ecbch b\u1eb1ng b\u1ea5t k\u1ef3 c\xe1ch n\xe0o. Th\xe0nh vi\xean s\u1ebd kh\xf4ng sao ch\xe9p, ho\u1eb7c ph\xe2n ph\u1ed1i c\xe1c n\u1ed9i dung thu\u1ed9c v\u1ec1 S\xe0n giao d\u1ecbch m\xe0 kh\xf4ng c\xf3 s\u1ef1 cho ph\xe9p b\u1eb1ng v\u0103n b\u1ea3n c\u1ee7a C\xf4ng ty. Th\xe0nh vi\xean \u0111\u1ed3ng \xfd r\u1eb1ng vi\u1ec7c s\u1eed d\u1ee5ng d\u1ecbch v\u1ee5 tr\xean S\xe0n giao d\u1ecbch c\u1ee7a Th\xe0nh vi\xean s\u1ebd t\xf9y thu\u1ed9c v\xe0o Ch\xednh s\xe1ch b\u1ea3o m\u1eadt c\u1ee7a C\xf4ng ty c\xf3 th\u1ec3 \u0111\u01b0\u1ee3c s\u1eeda \u0111\u1ed5i theo th\u1eddi gian.",Object(oe.jsx)("br",{}),"C\xf4ng ty nghi\xeam c\u1ea5m s\u1eed d\u1ee5ng b\u1ea5t k\u1ef3 ph\u1ea7n n\xe0o c\u1ee7a trang web n\xe0y v\u1edbi m\u1ee5c \u0111\xedch th\u01b0\u01a1ng m\u1ea1i ho\u1eb7c nh\xe2n danh b\u1ea5t k\u1ef3 \u0111\u1ed1i t\xe1c th\u1ee9 ba n\xe0o n\u1ebfu kh\xf4ng \u0111\u01b0\u1ee3c C\xf4ng ty cho ph\xe9p b\u1eb1ng v\u0103n b\u1ea3n. N\u1ebfu vi ph\u1ea1m b\u1ea5t c\u1ee9 \u0111i\u1ec1u n\xe0o trong \u0111\xe2y, C\xf4ng ty s\u1ebd h\u1ee7y t\xe0i kho\u1ea3n c\u1ee7a Th\xe0nh vi\xean m\xe0 kh\xf4ng c\u1ea7n b\xe1o tr\u01b0\u1edbc.",Object(oe.jsx)("br",{}),"Trong su\u1ed1t qu\xe1 tr\xecnh \u0111\u0103ng k\xfd, Th\xe0nh vi\xean \u0111\u1ed3ng \xfd nh\u1eadn th\xf4ng tin ti\u1ebfp th\u1ecb t\u1eeb S\xe0n giao d\u1ecbch. N\u1ebfu kh\xf4ng mu\u1ed1n ti\u1ebfp t\u1ee5c nh\u1eadn th\xf4ng tin ti\u1ebfp th\u1ecb, Th\xe0nh vi\xean c\xf3 th\u1ec3 t\u1eeb ch\u1ed1i b\u1eb1ng c\xe1ch g\u1ecdi \u0111i\u1ec7n cho C\xf4ng ty theo s\u1ed1 \u0111i\u1ec7n tho\u1ea1i ",re.p," ho\u1eb7c g\u1eedi email cho B\u1ed9 ph\u1eadn Ch\u0103m s\xf3c Kh\xe1ch h\xe0ng c\u1ee7a C\xf4ng ty t\u1ea1i ",re.s]}),Object(oe.jsx)("p",{className:"subtitle",children:"3. \u0110i\u1ec1u kho\u1ea3n s\u1eed d\u1ee5ng"}),Object(oe.jsxs)("p",{children:["Khi tham gia ho\u1ea1t \u0111\u1ed9ng tr\xean S\xe0n giao d\u1ecbch TM\u0110T Mioto.vn c\xf3 ngh\u0129a l\xe0 Th\xe0nh vi\xean \u0111\u1ed3ng \xfd v\u1edbi c\xe1c \u0111i\u1ec1u kho\u1ea3n d\u01b0\u1edbi \u0111\xe2y.",Object(oe.jsx)("br",{}),"C\xe1c \u0111i\u1ec1u ki\u1ec7n, \u0111i\u1ec1u kho\u1ea3n v\xe0 n\u1ed9i dung t\u1ea1i S\xe0n giao d\u1ecbch v\xe0 h\u1ee3p \u0111\u1ed3ng ph\xe1t sinh b\u1ecb chi ph\u1ed1i v\xe0 \u0111\u01b0\u1ee3c hi\u1ec3u theo Lu\u1eadt ph\xe1p c\u1ee7a Vi\u1ec7t Nam. To\xe0n b\u1ed9 tranh ch\u1ea5p ph\xe1t sinh b\u1edfi \u0110i\u1ec1u kho\u1ea3n s\u1eed d\u1ee5ng n\xe0y s\u1ebd \u0111\u01b0\u1ee3c gi\u1ea3i quy\u1ebft b\u1edfi T\xf2a \xe1n c\xf3 th\u1ea9m quy\u1ec1n t\u1ea1i Vi\u1ec7t Nam."]}),Object(oe.jsx)("p",{className:"subtitle",children:"4. Th\u01b0\u01a1ng hi\u1ec7u v\xe0 b\u1ea3n quy\u1ec1n"}),Object(oe.jsxs)("p",{children:["M\u1ecdi quy\u1ec1n s\u1edf h\u1eefu tr\xed tu\u1ec7 (\u0111\xe3 \u0111\u0103ng k\xfd ho\u1eb7c ch\u01b0a \u0111\u0103ng k\xfd), n\u1ed9i dung th\xf4ng tin v\xe0 t\u1ea5t c\u1ea3 c\xe1c thi\u1ebft k\u1ebf, v\u0103n b\u1ea3n, \u0111\u1ed3 h\u1ecda, ph\u1ea7n m\u1ec1m, h\xecnh \u1ea3nh, video, \xe2m nh\u1ea1c, \xe2m thanh, bi\xean d\u1ecbch ph\u1ea7n m\u1ec1m, m\xe3 ngu\u1ed3n v\xe0 ph\u1ea7n m\u1ec1m c\u01a1 b\u1ea3n \u0111\u1ec1u l\xe0 t\xe0i s\u1ea3n c\u1ee7a ",re.k,". V\u1edbi b\u1ea3n quy\u1ec1n \u0111\xe3 \u0111\u01b0\u1ee3c b\u1ea3o l\u01b0u, to\xe0n b\u1ed9 n\u1ed9i dung c\u1ee7a website Mioto.vn \u0111\u01b0\u1ee3c b\u1ea3o v\u1ec7 b\u1edfi Lu\u1eadt b\u1ea3n quy\u1ec1n c\u1ee7a Vi\u1ec7t Nam v\xe0 c\xe1c C\xf4ng \u01b0\u1edbc Qu\u1ed1c t\u1ebf.",Object(oe.jsx)("br",{}),"Th\u1ecfa thu\u1eadn n\xe0y kh\xf4ng ph\u1ea3i l\xe0 m\u1ed9t th\u01b0\u01a1ng v\u1ee5 mua b\xe1n v\xe0 kh\xf4ng chuy\u1ec3n nh\u01b0\u1ee3ng cho kh\xe1ch h\xe0ng b\u1ea5t k\u1ef3 quy\u1ec1n s\u1edf h\u1eefu n\xe0o c\xf3 li\xean quan \u0111\u1ebfn website Mioto.vn, ho\u1eb7c b\u1ea5t k\u1ef3 quy\u1ec3n s\u1edf h\u1eefu t\xe0i s\u1ea3n tr\xed tu\u1ec7 n\xe0o thu\u1ed9c s\u1edf h\u1eefu c\u1ee7a C\xf4ng ty: t\xean C\xf4ng ty, logo C\xf4ng ty, logo c\u1ee7a d\u1ecbch v\u1ee5, t\xean s\u1ea3n ph\u1ea9m li\xean quan \u0111\u1ebfn d\u1ecbch v\u1ee5. B\u1ea5t k\u1ef3 tranh ch\u1ea5p n\xe0o ph\xe1t sinh t\u1eeb vi\u1ec7c s\u1eed d\u1ee5ng tr\xe1i ph\xe9p website Mioto.vn"]}),Object(oe.jsx)("p",{className:"subtitle",children:"5. Ch\u1ea5p nh\u1eadn \u0111\u01a1n h\xe0ng v\xe0 gi\xe1 c\u1ea3"}),Object(oe.jsxs)("p",{children:["Gi\xe1 c\u1ea3 d\u1ecbch v\u1ee5 t\u1ea1i S\xe0n giao d\u1ecbch l\xe0 gi\xe1 \u0111\xe3 bao g\u1ed3m thu\u1ebf Gi\xe1 tr\u1ecb gia t\u0103ng (VAT). Gi\xe1 c\u1ea3 c\u1ee7a d\u1ecbch v\u1ee5 c\xf3 th\u1ec3 thay \u0111\u1ed5i t\xf9y th\u1eddi \u0111i\u1ec3m v\xe0 ch\u01b0\u01a1ng tr\xecnh khuy\u1ebfn m\xe3i k\xe8m theo.",Object(oe.jsx)("br",{}),"C\xf4ng ty c\xf3 quy\u1ec1n t\u1eeb ch\u1ed1i ho\u1eb7c h\u1ee7y h\u1ee3p \u0111\u1ed3ng c\u1ee7a Kh\xe1ch h\xe0ng v\xec b\u1ea5t k\u1ef3 l\xfd do g\xec li\xean quan \u0111\u1ebfn l\u1ed7i k\u1ef9 thu\u1eadt, h\u1ec7 th\u1ed1ng m\u1ed9t c\xe1ch kh\xe1ch quan v\xe0o b\u1ea5t k\u1ef3 l\xfac n\xe0o.",Object(oe.jsx)("br",{}),"C\xf4ng ty cam k\u1ebft s\u1ebd cung c\u1ea5p th\xf4ng tin gi\xe1 c\u1ea3 ch\xednh x\xe1c nh\u1ea5t cho Kh\xe1ch h\xe0ng. M\u1eb7c d\xf9 C\xf4ng ty c\u1ed1 g\u1eafng t\u1ed1t nh\u1ea5t \u0111\u1ec3 b\u1ea3o \u0111\u1ea3m r\u1eb1ng t\u1ea5t c\u1ea3 c\xe1c th\xf4ng tin v\xe0 gi\xe1 hi\u1ec3n th\u1ecb l\xe0 ch\xednh x\xe1c, tuy nhi\xean, \u0111\xf4i l\xfac v\u1eabn c\xf3 sai s\xf3t x\u1ea3y ra, t\xf9y theo t\u1eebng tr\u01b0\u1eddng h\u1ee3p C\xf4ng ty s\u1ebd li\xean h\u1ec7 h\u01b0\u1edbng d\u1eabn ho\u1eb7c th\xf4ng b\xe1o h\u1ee7y h\u1ee3p \u0111\u1ed3ng \u0111\xf3 v\xe0 ho\xe0n ti\u1ec1n cho Kh\xe1ch h\xe0ng.",Object(oe.jsx)("br",{}),"Kh\xe1c bi\u1ec7t gi\xe1: C\xe1c xe th\xe0nh vi\xean ho\u1ea1t \u0111\u1ed9ng t\u1ea1i S\xe0n giao d\u1ecbch c\xf3 th\u1ec3 c\xf9ng cung c\u1ea5p m\u1ed9t (1) s\u1ea3n ph\u1ea9m gi\u1ed1ng nhau v\u1edbi ch\xednh s\xe1ch gi\xe1 kh\xe1c nhau, Kh\xe1ch h\xe0ng c\xf3 quy\u1ec1n l\u1ef1a ch\u1ecdn v\xe0 so s\xe1nh gi\xe1 c\u1ea3 gi\u1eefa c\xe1c xe th\xe0nh vi\xean \u0111\u1ec3 c\xf3 \u0111\u01b0\u1ee3c m\u1ee9c gi\xe1 h\u1ee3p l\xfd nh\u1ea5t cho y\xeau c\u1ea7u \u0111\u1eb7t xe c\u1ee7a m\xecnh. C\xf4ng ty kh\xf4ng can thi\u1ec7p v\u1ec1 ch\xednh s\xe1ch gi\xe1 c\u1ee7a t\u1eebng xe th\xe0nh vi\xean n\u1ebfu c\xf3 ph\xe1t sinh tranh ch\u1ea5p.",Object(oe.jsx)("br",{}),"C\xf4ng ty c\u0169ng c\xf3 quy\u1ec1n t\u1eeb ch\u1ed1i ho\u1eb7c h\u1ee7y b\u1ecf b\u1ea5t k\u1ef3 h\u1ee3p \u0111\u1ed3ng n\xe0o d\xf9 h\u1ee3p \u0111\u1ed3ng \u0111\xf3 \u0111\xe3 hay ch\u01b0a \u0111\u01b0\u1ee3c x\xe1c nh\u1eadn ho\u1eb7c \u0111\xe3 thanh to\xe1n"]})]}),Object(oe.jsxs)("div",{className:"main-place pointer ".concat(t[2]?"text-primary":""),onClick:()=>n(2),children:[Object(oe.jsx)("h6",{children:"III. Quy tr\xecnh giao d\u1ecbch"}),Object(oe.jsx)("div",{className:"wrap-svg",children:t[2]?Object(oe.jsx)(ee.Hd,{}):Object(oe.jsx)(ee.Xd,{})})]}),t[2]&&Object(oe.jsxs)(oe.Fragment,{children:[Object(oe.jsx)("p",{className:"subtitle",children:"1. Quy tr\xecnh d\xe0nh cho ng\u01b0\u1eddi mua (kh\xe1ch h\xe0ng)"}),Object(oe.jsx)("p",{children:"\u0110\u1ec3 thu\xea xe tr\xean S\xe0n giao d\u1ecbch, Kh\xe1ch h\xe0ng v\xe0o website Mioto.vn v\xe0 th\u1ef1c hi\u1ec7n c\xe1c b\u01b0\u1edbc sau:"}),Object(oe.jsx)("p",{children:"B\u01b0\u1edbc 1: Kh\xe1ch h\xe0ng truy c\u1eadp v\xe0o website Mioto.vn v\xe0 \u0111\u0103ng nh\u1eadp v\xe0o t\xe0i kho\u1ea3n c\u1ee7a m\xecnh, n\u1ebfu Kh\xe1ch h\xe0ng ch\u01b0a c\xf3 t\xe0i kho\u1ea3n th\xec c\xf3 th\u1ec3 \u0111\u0103ng k\xfd t\u1ea1o t\xe0i kho\u1ea3n b\u1eb1ng Email, Facebook ho\u1eb7c t\xe0i kho\u1ea3n Google."}),Object(oe.jsx)("p",{children:"B\u01b0\u1edbc 2: T\xecm ki\u1ebfm \u2013 Nh\u1eadp \u0111\u1ecba \u0111i\u1ec3m v\xe0 kho\u1ea3ng th\u1eddi gian Kh\xe1ch h\xe0ng mu\u1ed1n thu\xea xe, sau \u0111\xf3 ch\u1ecdn t\xecm ki\u1ebfm."}),Object(oe.jsx)("p",{children:"B\u01b0\u1edbc 3: Ch\u1ecdn xe \u2013 Sau khi ch\u1ecdn t\xecm ki\u1ebfm, tr\xean website s\u1ebd hi\u1ec3n th\u1ecb c\xe1c k\u1ebft qu\u1ea3 t\xecm ki\u1ebfm, Kh\xe1ch h\xe0ng s\u1ebd th\u1ea5y \u0111\u01b0\u1ee3c danh s\xe1ch xe ph\xf9 h\u1ee3p ti\xeau ch\xed t\xecm ki\u1ebfm c\xf9ng v\u1edbi h\xecnh \u1ea3nh xe, gi\xe1 thu\xea, \u0111i\u1ec3m rating c\u1ee7a c\xe1c kh\xe1ch thu\xea xe tr\u01b0\u1edbc \u0111\xf3. Kh\xe1ch h\xe0ng c\xf3 th\u1ec3 \u0111i\u1ec1u ch\u1ec9nh th\u1eddi gian thu\xea v\xe0 l\u1ecdc k\u1ebft qu\u1ea3 t\xecm ki\u1ebfm theo c\xe1c ti\xeau ch\xed kh\xe1c nhau \u0111\u1ec3 c\xf3 \u0111\u01b0\u1ee3c danh s\xe1ch xe ph\xf9 h\u1ee3p theo \xfd Kh\xe1ch h\xe0ng. Sau \u0111\xf3 Kh\xe1ch h\xe0ng l\u1ef1a ch\u1ecdn xe \u01b0ng \xfd \u0111\u1ec3 xem chi ti\u1ebft h\u01a1n h\xecnh \u1ea3nh xe, m\xf4 t\u1ea3 xe, gi\xe1 thu\xea xe, khuy\u1ebfn m\xe3i, h\xecnh th\u1ee9c giao nh\u1eadn xe, th\xf4ng tin Ng\u01b0\u1eddi b\xe1n (Ch\u1ee7 xe), \u0111i\u1ec3m rating c\u1ee7a xe v\xe0 Ch\u1ee7 xe..."}),Object(oe.jsx)("p",{children:"B\u01b0\u1edbc 4: \u0110\u1eb7t xe \u2013 Sau khi xem th\xf4ng tin chi ti\u1ebft xe v\xe0 x\xe1c \u0111\u1ecbnh \u0111\u01b0\u1ee3c xe ph\xf9 h\u1ee3p, Kh\xe1ch h\xe0ng c\xf3 th\u1ec3 l\u1ef1a ch\u1ecdn ph\u01b0\u01a1ng th\u1ee9c giao nh\u1eadn v\xe0 ti\u1ebfn h\xe0nh Y\xeau c\u1ea7u thu\xea xe. Khi \u0111\xf3, tr\xean website s\u1ebd hi\u1ec3n th\u1ecb Th\xf4ng tin chuy\u1ebfn \u0111i (Trip Summary), bao g\u1ed3m chi ti\u1ebft h\xe0nh tr\xecnh, th\xf4ng tin xe, gi\xe1 thu\xea c\u01a1 b\u1ea3n, khuy\u1ebfn m\xe3i, chi ph\xed giao nh\u1eadn xe v\xe0 t\u1ed5ng s\u1ed1 ti\u1ec1n. B\xean d\u01b0\u1edbi B\u1ea3ng b\xe1o gi\xe1 s\u1ebd c\xf3 m\u1ee5c tr\u1ed1ng \u0111\u1ec3 Kh\xe1ch h\xe0ng c\xf3 th\u1ec3 g\u1eedi l\u1eddi nh\u1eafn \u0111\u1ebfn Ch\u1ee7 xe. Ch\u1ee7 xe sau khi nh\u1eadn \u0111\u01b0\u1ee3c Y\xeau c\u1ea7u thu\xea xe t\u1eeb ph\xeda Kh\xe1ch h\xe0ng s\u1ebd xem x\xe9t v\xe0 duy\u1ec7t Y\xeau c\u1ea7u thu\xea xe."}),Object(oe.jsx)("p",{children:"Sau khi Y\xeau c\u1ea7u thu\xea xe \u0111\u01b0\u1ee3c duy\u1ec7t, kh\xe1ch h\xe0ng th\u1ef1c hi\u1ec7n thanh to\xe1n ti\u1ec1n c\u1ecdc 40% t\u1ed5ng s\u1ed1 ti\u1ec1n hi\u1ec3n th\u1ecb tr\xean Th\xf4ng tin chuy\u1ebfn \u0111i. Sau khi \u0111\xe3 \u0111\u1eb7t xe th\xe0nh c\xf4ng, Mioto s\u1ebd g\u1eedi bi\xean nh\u1eadn \u0111i\u1ec7n t\u1eed (E-receipt) (x\xe1c nh\u1eadn l\u1ea1i c\xe1c th\u1eddi gian h\xe0nh tr\xecnh, th\xf4ng tin xe, gi\xe1 thu\xea, s\u1ed1 ti\u1ec1n \u0111\xe3 \u0111\u1eb7t c\u1ecdc, s\u1ed1 ti\u1ec1n c\xf2n l\u1ea1i c\u1ea7n thanh to\xe1n tr\u1ef1c ti\u1ebfp cho Ch\u1ee7 xe) c\xf9ng v\u1edbi M\xe3 chuy\u1ebfn \u0111i qua \u0111\u1ecba ch\u1ec9 email c\u1ee7a Kh\xe1ch h\xe0ng. Ch\u1ee7 xe c\u0169ng s\u1ebd nh\u1eadn \u0111\u01b0\u1ee3c bi\xean nh\u1eadn \u0111i\u1ec7n t\u1eed \u0111\u1ec3 b\u1ea3o \u0111\u1ea3m s\u1ebd th\u1ef1c hi\u1ec7n \u0111\u1ea7y \u0111\u1ee7 c\xe1c th\u1ecfa thu\u1eadn \u0111\xe3 cam k\u1ebft v\u1edbi Kh\xe1ch h\xe0ng."}),Object(oe.jsx)("p",{children:"Tr\u01b0\u1edbc th\u1eddi \u0111i\u1ec3m thu\xea xe 1-2 ng\xe0y, Mioto s\u1ebd li\xean h\u1ec7 v\u1edbi Kh\xe1ch h\xe0ng v\xe0 Ch\u1ee7 xe \u0111\u1ec3 x\xe1c nh\u1eadn l\u1ea1i c\xe1c n\u1ed9i dung trong bi\xean nh\u1eadn \u0111i\u1ec7n t\u1eed \u0111\u1ec3 \u0111\u1ea3m b\u1ea3o vi\u1ec7c thu\xea xe s\u1ebd di\u1ec5n ra nh\u01b0 k\u1ebf ho\u1ea1ch. Khi \u0111\u1ebfn th\u1eddi \u0111i\u1ec3m thu\xea xe, Kh\xe1ch h\xe0ng s\u1ebd \u0111\u1ebfn \u0111\u1ecba \u0111i\u1ec3m c\u1ee7a Ch\u1ee7 xe \u0111\u1ec3 nh\u1eadn xe ho\u1eb7c Ch\u1ee7 xe s\u1ebd \u0111\u01b0a xe \u0111\u1ebfn tr\u1ef1c ti\u1ebfp \u0111\u1ecba ch\u1ec9 c\u1ee7a Kh\xe1ch h\xe0ng t\xf9y theo ph\u01b0\u01a1ng ph\u1ee9c giao nh\u1eadn Kh\xe1ch h\xe0ng \u0111\xe3 l\u1ef1a ch\u1ecdn khi \u0111\u1eb7t xe."}),Object(oe.jsx)("p",{children:'Tr\u01b0\u1edbc khi giao xe, Kh\xe1ch h\xe0ng v\xe0 Ch\u1ee7 xe s\u1ebd k\xed H\u1ee3p \u0111\u1ed3ng thu\xea xe v\xe0 Bi\xean b\u1ea3n b\xe0n giao xe, Kh\xe1ch h\xe0ng c\u1ea7n ki\u1ec3m tra k\u0129 t\xecnh tr\u1ea1ng xe (b\xean ngo\xe0i v\xe0 n\u1ed9i th\u1ea5t) tr\u01b0\u1edbc khi k\xed Bi\xean b\u1ea3n b\xe0n giao xe (\u1edf m\u1ee5c "T\xecnh tr\u1ea1ng xe khi nh\u1eadn"). H\u1ee3p \u0111\u1ed3ng thu\xea xe v\xe0 Bi\xean b\u1ea3n b\xe0n giao xe \u0111\u01b0\u1ee3c l\u1eadp th\xe0nh 2 b\u1ea3n, Ch\u1ee7 xe v\xe0 Kh\xe1ch h\xe0ng m\u1ed7i b\xean gi\u1eef 1 b\u1ea3n. Sau khi th\u1ef1c hi\u1ec7n xong H\u1ee3p \u0111\u1ed3ng, Kh\xe1ch h\xe0ng c\xf9ng Ch\u1ee7 xe s\u1ebd x\xe1c nh\u1eadn l\u1ea1i t\xecnh tr\u1ea1ng xe. Kh\xe1ch h\xe0ng \u0111\u1ec1 ngh\u1ecb Ch\u1ee7 xe k\xed v\xe0o Bi\xean b\u1ea3n b\xe0n giao xe (\u1edf m\u1ee5c "T\xecnh tr\u1ea1ng xe khi ho\xe0n tr\u1ea3") \u0111\u1ec3 l\xe0m b\u1eb1ng ch\u1ee9ng \u0111\xe3 ho\xe0n tr\u1ea3 xe \u0111\xfang nguy\xean tr\u1ea1ng, d\u01b0 ph\xf2ng trong tr\u01b0\u1eddng h\u1ee3p c\xf3 tranh ch\u1ea5p. Kh\xe1ch h\xe0ng sau \u0111\xf3 s\u1ebd thanh to\xe1n s\u1ed1 ti\u1ec1n c\xf2n l\u1ea1i v\u1edbi Ch\u1ee7 xe k\u1ec3 c\u1ea3 ph\u1ea7n ph\xe1t sinh.'}),Object(oe.jsx)("p",{className:"subtitle",children:"2. Quy tr\xecnh d\xe0nh cho ng\u01b0\u1eddi b\xe1n (ch\u1ee7 xe)"}),Object(oe.jsx)("p",{children:"C\xe1c th\xf4ng tin \u0111\u0103ng k\xfd \u0111\u01b0\u1ee3c y\xeau c\u1ea7u ph\u1ea3i \u0111\u1ea7y \u0111\u1ee7, \u0111\xfang ch\xednh t\u1ea3, th\u1ed1ng nh\u1ea5t v\u1edbi nhau, kh\xf4ng vi ph\u1ea1m v\u1ec1 \u0111\u0103ng tin n\xf3i chung. Th\xf4ng tin \u0111\u0103ng k\xfd ph\u1ea3i trung th\u1ef1c, r\xf5 r\xe0ng, kh\xf4ng g\xe2y nh\u1ea7m l\u1eabn ho\u1eb7c hi\u1ec3u l\u1ea7m \u0111\u1ed1i v\u1edbi ng\u01b0\u1eddi xem v\u1ec1 uy t\xedn cho thu\xea xe c\u0169ng nh\u01b0 c\xe1c th\xf4ng tin nh\u1eadn bi\u1ebft kh\xe1c. \u0110\u1ec3 \u0111\u0103ng k\xfd th\xf4ng tin xe l\xean S\xe0n giao d\u1ecbch, Ng\u01b0\u1eddi b\xe1n (Ch\u1ee7 xe) th\u1ef1c hi\u1ec7n theo h\u01b0\u1edbng d\u1eabn d\u01b0\u1edbi \u0111\xe2y:"}),Object(oe.jsx)("p",{children:"B\u01b0\u1edbc 1: Tr\u01b0\u1edbc ti\xean ng\u01b0\u1eddi b\xe1n truy c\u1eadp v\xe0o website https://www.mioto.vn, click chu\u1ed9t v\xe0o n\xfat \u201c\u0110\u0103ng k\xed\u201d. Ho\u1eb7c c\xf3 th\u1ec3 d\xf9ng c\xe1c t\xe0i kho\u1ea3n Facebook, Google \u0111\u1ec3 \u0111\u0103ng k\xfd."}),Object(oe.jsx)("p",{children:"B\u01b0\u1edbc 2: Ti\u1ebfn h\xe0nh khai th\xf4ng tin c\xe1 nh\xe2n theo m\u1eabu h\u01b0\u1edbng d\u1eabn."}),Object(oe.jsx)("p",{children:"B\u01b0\u1edbc 3: \u0110\u0103ng t\u1ea3i th\xf4ng tin xe cho thu\xea"}),Object(oe.jsx)("p",{children:"Ch\u1ee7 xe g\u1eedi th\xf4ng tin xe cho thu\xea \u0111\u1ebfn b\u1ed9 ph\u1eadn ki\u1ec3m duy\u1ec7t n\u1ed9i dung \u0111\u1ec3 b\u1ed9 ph\u1eadn n\xe0y ti\u1ebfn h\xe0nh \u0111\u0103ng t\u1ea3i th\xf4ng tin h\u1ed9 th\xec b\u1ed9 ph\u1eadn ki\u1ec3m duy\u1ec7t th\xf4ng tin s\u1ebd ti\u1ebfn h\xe0nh x\xe1c minh, x\xe1c th\u1ef1c l\u1ea1i n\u1ed9i dung s\u1ebd \u0111\u0103ng. Nh\u1eefng n\u1ed9i dung vi ph\u1ea1m b\u1ed9 ph\u1eadn ki\u1ec3m duy\u1ec7t s\u1ebd t\u1eeb ch\u1ed1i kh\xf4ng \u0111\u0103ng t\u1ea3i l\xean website."}),Object(oe.jsx)("p",{className:"subtitle",children:"3. Quy tr\xecnh nh\u1eadn d\u1ecbch v\u1ee5"}),Object(oe.jsx)("p",{children:"Khi \u0111\u1ebfn th\u1eddi \u0111i\u1ec3m thu\xea xe, Kh\xe1ch h\xe0ng s\u1ebd \u0111\u1ebfn \u0111\u1ecba \u0111i\u1ec3m c\u1ee7a Ch\u1ee7 xe \u0111\u1ec3 nh\u1eadn xe ho\u1eb7c Ch\u1ee7 xe s\u1ebd \u0111\u01b0a xe \u0111\u1ebfn tr\u1ef1c ti\u1ebfp \u0111\u1ecba ch\u1ec9 c\u1ee7a Kh\xe1ch h\xe0ng t\xf9y theo ph\u01b0\u01a1ng ph\u1ee9c giao nh\u1eadn Kh\xe1ch h\xe0ng \u0111\xe3 l\u1ef1a ch\u1ecdn khi \u0111\u1eb7t xe."}),Object(oe.jsx)("p",{children:"Tr\u01b0\u1edbc khi giao xe, Kh\xe1ch h\xe0ng v\xe0 Ch\u1ee7 xe s\u1ebd k\xed H\u1ee3p \u0111\u1ed3ng thu\xea xe v\xe0 Bi\xean b\u1ea3n b\xe0n giao xe, Kh\xe1ch h\xe0ng c\u1ea7n ki\u1ec3m tra k\u0129 t\xecnh tr\u1ea1ng xe (b\xean ngo\xe0i v\xe0 n\u1ed9i th\u1ea5t) tr\u01b0\u1edbc khi k\xed Bi\xean b\u1ea3n b\xe0n giao xe."}),Object(oe.jsx)("p",{children:"Trong qu\xe1 tr\xecnh th\u1ef1c hi\u1ec7n n\u1ebfu x\u1ea3y ra tranh ch\u1ea5p th\xec Kh\xe1ch h\xe0ng v\xe0 Ch\u1ee7 xe ch\u1ee7 \u0111\u1ed9ng li\xean h\u1ec7 v\u1edbi nhau \u0111\u1ec3 gi\u1ea3i quy\u1ebft c\xe1c v\u1ea5n \u0111\u1ec1 d\u1ef1a tr\xean c\xe1c \u0111i\u1ec1u kho\u1ea3n c\u1ee7a H\u1ee3p \u0111\u1ed3ng thu\xea xe \u0111\xe3 k\xfd. C\xf4ng ty s\u1ebd h\u1ed7 tr\u1ee3 2 b\xean trong kh\u1ea3 n\u0103ng c\u1ee7a m\xecnh. C\xf4ng ty \u0111\u1ec1 ngh\u1ecb c\xe1c b\xean tham gia S\xe0n giao d\u1ecbch khi ti\u1ebfn h\xe0nh giao d\u1ecbch ph\u1ea3i c\xf3 k\xfd k\u1ebft H\u1ee3p \u0111\u1ed3ng thu\xea xe v\xe0 Bi\xean b\u1ea3n b\xe0n giao xe."}),Object(oe.jsx)("p",{children:'Sau khi th\u1ef1c hi\u1ec7n xong H\u1ee3p \u0111\u1ed3ng thu\xea xe, Kh\xe1ch h\xe0ng c\xf9ng Ch\u1ee7 xe x\xe1c nh\u1eadn l\u1ea1i t\xecnh tr\u1ea1ng xe, c\u1ea3 2 b\xean c\xf9ng k\xed v\xe0o Bi\xean b\u1ea3n b\xe0n giao xe (\u1edf m\u1ee5c "T\xecnh tr\u1ea1ng xe khi ho\xe0n tr\u1ea3") v\xe0 m\u1ed7i b\xean gi\u1eef l\u1ea1i 1 b\u1ea3n \u0111\u1ec3 l\xe0m b\u1eb1ng ch\u1ee9ng \u0111\xe3 ho\xe0n tr\u1ea3 xe \u0111\xfang nguy\xean tr\u1ea1ng, d\u01b0 ph\xf2ng trong tr\u01b0\u1eddng h\u1ee3p c\xf3 tranh ch\u1ea5p.'}),Object(oe.jsx)("p",{className:"subtitle",children:"4. Quy tr\xecnh thay \u0111\u1ed5i d\u1ecbch v\u1ee5"}),Object(oe.jsx)("p",{children:"H\u1ec7 th\u1ed1ng C\xf4ng ty kh\xf4ng h\u1ed7 tr\u1ee3 t\xednh n\u0103ng thay \u0111\u1ed5i l\u1ecbch tr\xecnh, v\xec th\u1ebf trong tr\u01b0\u1eddng h\u1ee3p kh\xe1ch h\xe0ng sau khi \u0111\xe3 \u0111\u1eb7t c\u1ecdc v\xe0 mu\u1ed1n thay \u0111\u1ed5i th\u1eddi gian chuy\u1ebfn \u0111i hay lo\u1ea1i xe th\xec c\u1ea7n ti\u1ebfn h\xe0nh h\u1ee7y chuy\u1ebfn v\xe0 \u0111\u1eb7t l\u1ea1i chuy\u1ebfn m\u1edbi."}),Object(oe.jsx)("p",{className:"subtitle",children:"5. Quy tr\xecnh h\u1ee7y d\u1ecbch v\u1ee5"}),Object(oe.jsx)("p",{children:"Khi mu\u1ed1n h\u1ee7y chuy\u1ebfn \u0111i \u0111\xe3 \u0111\u1eb7t c\u1ecdc, Kh\xe1ch h\xe0ng th\u1ef1c hi\u1ec7n theo c\xe1c b\u01b0\u1edbc sau \u0111\xe2y:"}),Object(oe.jsx)("p",{children:"B\u01b0\u1edbc 1: Th\xf4ng b\xe1o t\u1edbi S\xe0n giao d\u1ecbch v\u1ec1 vi\u1ec7c thay \u0111\u1ed5i chuy\u1ebfn \u0111i b\u1eb1ng c\xe1c c\xe1ch:"}),Object(oe.jsx)("p",{children:'1.a Truy c\u1eadp v\xe0o website Mioto.vn, \u0111\u0103ng nh\u1eadp v\xe0o t\xe0i kho\u1ea3n c\u1ee7a Kh\xe1ch h\xe0ng, v\xe0o m\u1ee5c "Th\xf4ng b\xe1o", ch\u1ecdn "S\u1eafp t\u1edbi", Kh\xe1ch h\xe0ng s\u1ebd th\u1ea5y danh s\xe1ch c\xe1c chuy\u1ebfn \u0111i s\u1eafp t\u1edbi \u0111\xe3 \u0111\xe3 \u0111\u1eb7t c\u1ecdc, ch\u1ecdn chuy\u1ebfn \u0111i c\u1ea7n h\u1ee7y, ch\u1ecdn H\u1ee7y v\xe0 x\xe1c nh\u1eadn \u0111\u1ec3 g\u1eedi "Y\xeau c\u1ea7u h\u1ee7y chuy\u1ebfn" \u0111\u1ebfn ch\u1ee7 xe.'}),Object(oe.jsxs)("p",{children:["1.b G\u1ecdi \u0111i\u1ec7n \u0111\u1ebfn B\u1ed9 ph\u1eadn Ch\u0103m s\xf3c Kh\xe1ch h\xe0ng t\u1ea1i s\u1ed1 \u0111i\u1ec7n tho\u1ea1i ",re.p," \u0111\u1ec3 \u0111\u01b0\u1ee3c h\u1ed7 tr\u1ee3."]}),Object(oe.jsx)("p",{children:"B\u01b0\u1edbc 2: B\u1ed9 ph\u1eadn Ch\u0103m s\xf3c Kh\xe1ch h\xe0ng s\u1ebd li\xean h\u1ec7 v\u1edbi ph\xeda Ch\u1ee7 xe, x\xe1c nh\u1eadn th\xf4ng tin h\u1ee7y chuy\u1ebfn v\xe0 t\xednh ph\xed vi ph\u1ea1m (n\u1ebfu c\xf3), g\u1eedi th\xf4ng tin qua mail cho Kh\xe1ch h\xe0ng \u0111\u1ed3ng th\u1eddi g\u1eedi th\xf4ng tin t\u1edbi Ch\u1ee7 xe."}),Object(oe.jsx)("p",{children:"B\u01b0\u1edbc 3: Ho\xe0n tr\u1ea3 ti\u1ec1n cho Kh\xe1ch h\xe0ng sau khi c\u1ea5n tr\u1eeb ti\u1ec1n \u0111\u1eb7t c\u1ecdc v\u1edbi ph\xed h\u1ee7y chuy\u1ebfn v\xe0 ph\xed chuy\u1ec3n kho\u1ea3n."}),Object(oe.jsx)("p",{className:"subtitle",children:"6. Quy tr\xecnh gi\u1ea3i quy\u1ebft khi\u1ebfu n\u1ea1i"}),Object(oe.jsx)("p",{children:"C\xf4ng ty v\xe0 Ch\u1ee7 xe c\xf3 tr\xe1ch nhi\u1ec7m ti\u1ebfp nh\u1eadn c\xe1c khi\u1ebfu n\u1ea1i v\xe0 h\u1ed7 tr\u1ee3 Kh\xe1ch h\xe0ng li\xean quan \u0111\u1ebfn c\xe1c giao d\u1ecbch \u0111\u01b0\u1ee3c k\u1ebft n\u1ed1i th\xf4ng qua S\xe0n giao d\u1ecbch. C\xe1c khi\u1ebfu n\u1ea1i li\xean quan \u0111\u1ebfn vi\u1ec7c cung c\u1ea5p, s\u1eed d\u1ee5ng d\u1ecbch v\u1ee5 thu\xea xe tr\xean S\xe0n giao d\u1ecbch do C\xf4ng ty ch\u1ecbu tr\xe1ch nhi\u1ec7m \u0111\u1ed9c l\u1eadp gi\u1ea3i quy\u1ebft tr\xean c\u01a1 s\u1edf quy \u0111\u1ecbnh c\u1ee7a ph\xe1p lu\u1eadt, \u0110i\u1ec1u kho\u1ea3n v\xe0 \u0110i\u1ec1u ki\u1ec7n s\u1eed d\u1ee5ng d\u1ecbch v\u1ee5, c\xe1c th\xf4ng b\xe1o, quy ch\u1ebf \u0111\xe3 c\xf4ng b\u1ed1 v\u1edbi Th\xe0nh vi\xean (Kh\xe1ch h\xe0ng v\xe0 Ch\u1ee7 xe). Khi ph\xe1t sinh tranh ch\u1ea5p, C\xf4ng ty \u0111\u1ec1 cao gi\u1ea3i ph\xe1p th\u01b0\u01a1ng l\u01b0\u1ee3ng, h\xf2a gi\u1ea3i gi\u1eefa c\xe1c b\xean nh\u1eb1m duy tr\xec s\u1ef1 tin c\u1eady c\u1ee7a Th\xe0nh vi\xean v\xe0o ch\u1ea5t l\u01b0\u1ee3ng d\u1ecbch v\u1ee5 c\u1ee7a S\xe0n giao d\u1ecbch. Kh\xe1ch h\xe0ng c\xf3 th\u1ec3 th\u1ef1c hi\u1ec7n theo c\xe1c b\u01b0\u1edbc sau:"}),Object(oe.jsxs)("p",{children:["B\u01b0\u1edbc 1: Kh\xe1ch h\xe0ng khi\u1ebfu n\u1ea1i v\u1ec1 d\u1ecbch v\u1ee5 qua s\u1ed1 \u0111i\u1ec7n tho\u1ea1i ",re.p," ho\u1eb7c g\u1eedi mail cho B\u1ed9 ph\u1eadn Ch\u0103m s\xf3c Kh\xe1ch h\xe0ng t\u1ea1i \u0111\u1ecba ch\u1ec9 ",re.s,". Th\u1eddi gian \u0111\u1ec3 C\xf4ng ty ti\u1ebfp nh\u1eadn khi\u1ebfu n\u1ea1i l\xe0 3 ng\xe0y k\u1ec3 t\u1eeb ng\xe0y s\u1eed d\u1ee5ng d\u1ecbch v\u1ee5 ho\u1eb7c t\u1eeb ng\xe0y ph\xe1t sinh s\u1ef1 vi\u1ec7c."]}),Object(oe.jsx)("p",{children:"B\u01b0\u1edbc 2: Trong th\u1eddi h\u1ea1n (3) ng\xe0y l\xe0m vi\u1ec7c k\u1ec3 t\u1eeb khi ti\u1ebfp nh\u1eadn th\xf4ng tin khi\u1ebfu n\u1ea1i c\u1ee7a Kh\xe1ch h\xe0ng, B\u1ed9 ph\u1eadn Ch\u0103m s\xf3c Kh\xe1ch h\xe0ng x\xe1c nh\u1eadn th\xf4ng tin khi\u1ebfu n\u1ea1i, ti\u1ebfn h\xe0nh ph\xe2n lo\u1ea1i th\xf4ng tin v\xe0 th\xf4ng b\xe1o cho Kh\xe1ch h\xe0ng:"}),Object(oe.jsx)("p",{children:"2a. Ghi nh\u1eadn c\xe1c y\xeau c\u1ea7u v\xe0 c\xe1c khi\u1ebfu n\u1ea1i c\xf3 li\xean quan \u0111\u1ebfn C\xf4ng ty v\xe0 trong th\u1eddi h\u1ea1n khi\u1ebfu n\u1ea1i."}),Object(oe.jsx)("p",{children:"2b. T\u1eeb ch\u1ed1i c\xe1c y\xeau c\u1ea7u, c\xe1c khi\u1ebfu n\u1ea1i kh\xf4ng c\xf3 li\xean quan \u0111\u1ebfn C\xf4ng ty v\xe0 h\u1ebft th\u1eddi h\u1ea1n khi\u1ebfu n\u1ea1i."}),Object(oe.jsx)("p",{children:"B\u01b0\u1edbc 3: Gi\u1ea3i quy\u1ebft v\u1ea5n \u0111\u1ec1"}),Object(oe.jsx)("p",{children:"B\u1ed9 ph\u1eadn Ch\u0103m s\xf3c Kh\xe1ch h\xe0ng s\u1ebd ti\u1ebfn h\xe0nh x\xe1c minh, ki\u1ec3m ch\u1ee9ng v\xe0 ph\xe2n t\xedch t\xednh ch\u1ea5t v\xe0 m\u1ee9c \u0111\u1ed9 c\u1ee7a n\u1ed9i dung khi\u1ebfu n\u1ea1i, ph\u1ea1m vi khi\u1ebfu n\u1ea1i v\xe0 tr\xe1ch nhi\u1ec7m x\u1eed l\xfd \u0111\u1ec3 ph\u1ed1i h\u1ee3p v\u1edbi Ch\u1ee7 xe v\xe0 B\xean cung c\u1ea5p d\u1ecbch v\u1ee5 th\u1ee9 3 \u0111\u01b0a ra bi\u1ec7n ph\xe1p c\u1ee5 th\u1ec3 \u0111\u1ec3 h\u1ed7 tr\u1ee3 Kh\xe1ch h\xe0ng gi\u1ea3i quy\u1ebft tranh ch\u1ea5p \u0111\xf3."}),Object(oe.jsx)("p",{children:"3a. Chuy\u1ec3n c\xe1c v\u1ea5n \u0111\u1ec1 c\xf3 li\xean quan tr\u1ef1c ti\u1ebfp \u0111\u1ebfn C\xf4ng ty cho c\xe1c B\u1ed9 ph\u1eadn c\xf3 li\xean quan ki\u1ec3m tra v\xe0 \u0111\u1ed1i chi\u1ebfu."}),Object(oe.jsx)("p",{children:"3b. Chuy\u1ec3n c\xe1c v\u1ea5n \u0111\u1ec1 c\xf3 li\xean quan cho Ch\u1ee7 xe gi\u1ea3i quy\u1ebft."}),Object(oe.jsx)("p",{children:"Trong th\u1eddi h\u1ea1n ba (3) ng\xe0y l\xe0m vi\u1ec7c k\u1ec3 t\u1eeb khi ti\u1ebfp nh\u1eadn th\xf4ng b\xe1o v\u1ec1 khi\u1ebfu n\u1ea1i, Ch\u1ee7 xe c\xf3 tr\xe1ch nhi\u1ec7m ph\u1ed1i h\u1ee3p v\u1edbi Mioto \u0111\u1ec3 gi\u1ea3i quy\u1ebft, x\u1eed l\xfd khi\u1ebfu n\u1ea1i. Ch\u1ee7 xe s\u1ebd th\xf4ng b\xe1o cho Kh\xe1ch h\xe0ng bi\u1ec7n ph\xe1p x\u1eed l\xfd ho\u1eb7c \u1ee7y quy\u1ec1n th\xf4ng b\xe1o cho C\xf4ng ty."}),Object(oe.jsx)("p",{children:"B\u01b0\u1edbc 4: \u0110\xf3ng khi\u1ebfu n\u1ea1i"}),Object(oe.jsxs)("p",{children:["4a. Kh\xe1ch h\xe0ng \u0111\u1ed3ng \xfd v\u1edbi c\xe1c ph\u1ea3n h\u1ed3i c\u1ee7a B\u1ed9 ph\u1eadn Ch\u0103m s\xf3c Kh\xe1ch h\xe0ng -",">"," K\u1ebft th\xfac khi\u1ebfu n\u1ea1i. Kh\xe1ch h\xe0ng kh\xf4ng \u0111\u1ed3ng \xfd -",">"," Quay l\u1ea1i b\u01b0\u1edbc 3"]}),Object(oe.jsxs)("p",{children:["4b. Theo d\xf5i c\xe1c gi\u1ea3i quy\u1ebft khi\u1ebfu n\u1ea1i c\u1ee7a Ch\u1ee7 xe -",">"," K\u1ebft th\xfac khi\u1ebfu n\u1ea1i khi Kh\xe1ch h\xe0ng v\xe0 Ch\u1ee7 xe \u0111\xe3 th\u1ecfa thu\u1eadn xong."]}),Object(oe.jsx)("p",{children:"Khi nh\u1eadn \u0111\u01b0\u1ee3c th\xf4ng b\xe1o v\u1ec1 bi\u1ec7n ph\xe1p x\u1eed l\xfd t\u1eeb Ch\u1ee7 xe nh\u01b0ng Kh\xe1ch h\xe0ng kh\xf4ng \u0111\u1ed3ng \xfd th\xec C\xf4ng ty s\u1ebd ch\u1ee7 tr\xec vi\u1ec7c th\u01b0\u01a1ng l\u01b0\u1ee3ng, h\xf2a gi\u1ea3i gi\u1eefa Kh\xe1ch h\xe0ng v\xe0 Ch\u1ee7 xe \u0111\u1ec3 \u0111i \u0111\u1ebfn k\u1ebft qu\u1ea3 gi\u1ea3i quy\u1ebft ph\xf9 h\u1ee3p v\u1edbi c\u1ea3 hai b\xean. Trong tr\u01b0\u1eddng h\u1ee3p Kh\xe1ch h\xe0ng v\xe0 Ch\u1ee7 xe kh\xf4ng \u0111i \u0111\u1ebfn th\u1ecfa thu\u1eadn chung ho\u1eb7c Kh\xe1ch h\xe0ng kh\xf4ng \u0111\u1ed3ng \xfd v\u1edbi nh\u1eefng bi\u1ec7n ph\xe1p gi\u1ea3i quy\u1ebft cu\u1ed1i c\xf9ng c\u1ee7a Ch\u1ee7 xe v\xe0/ho\u1eb7c n\u1eb1m ngo\xe0i kh\u1ea3 n\u0103ng v\xe0 th\u1ea9m quy\u1ec1n c\u1ee7a C\xf4ng ty th\xec Kh\xe1ch h\xe0ng ho\u1eb7c Ch\u1ee7 xe c\xf3 th\u1ec3 nh\u1edd \u0111\u1ebfn C\u01a1 quan Nh\xe0 n\u01b0\u1edbc c\xf3 th\u1ea9m quy\u1ec1n can thi\u1ec7p v\xe0 gi\u1ea3i quy\u1ebft theo Ph\xe1p lu\u1eadt nh\u1eb1m \u0111\u1ea3m b\u1ea3o l\u1ee3i \xedch h\u1ee3p ph\xe1p c\u1ee7a c\xe1c b\xean."}),Object(oe.jsx)("p",{children:"C\xf4ng ty t\xf4n tr\u1ecdng v\xe0 nghi\xeam t\xfac th\u1ef1c hi\u1ec7n c\xe1c quy \u0111\u1ecbnh c\u1ee7a Ph\xe1p lu\u1eadt v\u1ec1 B\u1ea3o v\u1ec7 quy\u1ec1n l\u1ee3i c\u1ee7a ng\u01b0\u1eddi d\xf9ng. C\xf4ng ty khuy\u1ebfn ngh\u1ecb Kh\xe1ch h\xe0ng v\xe0 Ch\u1ee7 xe cung c\u1ea5p ch\xednh x\xe1c, trung th\u1ef1c, chi ti\u1ebft c\xe1c th\xf4ng tin c\xe1 nh\xe2n v\xe0 n\u1ed9i dung \u0111\u0103ng tin li\xean quan \u0111\u1ebfn d\u1ecbch v\u1ee5. Ch\xfang t\xf4i c\u0169ng \u0111\u1ec1 ngh\u1ecb Ch\u1ee7 xe c\u1ea7n nghi\xeam t\xfac tu\xe2n th\u1ee7 c\xe1c quy \u0111\u1ecbnh c\u1ee7a Ph\xe1p lu\u1eadt, c\u0169ng nh\u01b0 c\xf3 nh\u1eefng h\xe0nh vi ph\xf9 h\u1ee3p \u0111\u1ed1i v\u1edbi Kh\xe1ch h\xe0ng. M\u1ecdi h\xe0nh vi l\u1eeba \u0111\u1ea3o, gian l\u1eadn trong kinh doanh, g\xe2y t\u1ed5n h\u1ea1i \u0111\u1ebfn ng\u01b0\u1eddi kh\xe1c \u0111\u1ec1u b\u1ecb l\xean \xe1n v\xe0 ph\u1ea3i ch\u1ecbu ho\xe0n to\xe0n tr\xe1ch nhi\u1ec7m tr\u01b0\u1edbc Ph\xe1p lu\u1eadt. C\xe1c b\xean bao g\u1ed3m Kh\xe1ch h\xe0ng v\xe0 Ch\u1ee7 xe s\u1ebd ph\u1ea3i c\xf3 tr\xe1ch nhi\u1ec7m t\xedch c\u1ef1c trong vi\u1ec7c gi\u1ea3i quy\u1ebft khi\u1ebfu n\u1ea1i. Ch\u1ee7 xe c\u1ea7n c\xf3 tr\xe1ch nhi\u1ec7m ch\u1ee7 \u0111\u1ed9ng x\u1eed l\xfd v\xe0 cung c\u1ea5p v\u0103n b\u1ea3n gi\u1ea5y t\u1edd ch\u1ee9ng th\u1ef1c th\xf4ng tin li\xean quan \u0111\u1ebfn s\u1ef1 vi\u1ec7c \u0111ang c\xf3 khi\u1ebfu n\u1ea1i, tranh ch\u1ea5p v\u1edbi Kh\xe1ch h\xe0ng. C\xf4ng ty ch\u1ec9 \u0111\xf3ng vai tr\xf2 h\u1ed7 tr\u1ee3, ph\u1ed1i h\u1ee3p vi\u1ec7c th\u01b0\u01a1ng l\u01b0\u1ee3ng, h\xf2a gi\u1ea3i v\xe0 gi\u1ea3i quy\u1ebft khi\u1ebfu n\u1ea1i gi\u1eef Kh\xe1ch h\xe0ng v\xe0 Ch\u1ee7 xe. C\xf4ng ty c\u0169ng c\xf3 tr\xe1ch nhi\u1ec7m cung c\u1ea5p nh\u1eefng th\xf4ng tin li\xean quan \u0111\u1ebfn Kh\xe1ch h\xe0ng v\xe0 Ch\u1ee7 xe n\u1ebfu \u0111\u01b0\u1ee3c Ch\u1ee7 xe ho\u1eb7c Kh\xe1ch h\xe0ng ho\u1eb7c C\u01a1 quan Ph\xe1p lu\u1eadt c\xf3 th\u1ea9m quy\u1ec1n y\xeau c\u1ea7u."}),Object(oe.jsx)("p",{children:"Sau khi Kh\xe1ch h\xe0ng v\xe0 Ch\u1ee7 xe \u0111\xe3 gi\u1ea3i quy\u1ebft xong tranh ch\u1ea5p, c\u1ea7n c\xf3 tr\xe1ch nhi\u1ec7m b\xe1o l\u1ea1i cho C\xf4ng ty \u0111\u1ec3 c\u1eadp nh\u1eadt t\xecnh h\xecnh. Trong tr\u01b0\u1eddng h\u1ee3p giao d\u1ecbch ph\xe1t sinh m\xe2u thu\u1eabn m\xe0 l\u1ed7i thu\u1ed9c v\u1ec1 Ch\u1ee7 xe: C\xf4ng ty s\u1ebd \xe1p d\u1ee5ng c\xe1c bi\u1ec7n ph\xe1p x\u1eed l\xfd vi ph\u1ea1m t\u01b0\u01a1ng \u1ee9ng bao g\u1ed3m nh\u01b0ng kh\xf4ng gi\u1edbi h\u1ea1n: c\u1ea3nh c\xe1o, kh\xf3a t\xe0i kho\u1ea3n ho\u1eb7c chuy\u1ec3n cho C\u01a1 quan Ph\xe1p lu\u1eadt c\xf3 th\u1ea9m quy\u1ec1n t\xf9y theo m\u1ee9c \u0111\u1ed9 c\u1ee7a sai ph\u1ea1m. C\xf4ng ty s\u1ebd ch\u1ea5m d\u1ee9t v\xe0 g\u1ee1 b\u1ecf to\xe0n b\u1ed9 tin b\xe0i v\u1ec1 s\u1ea3n ph\u1ea9m, d\u1ecbch v\u1ee5 c\u1ee7a Ch\u1ee7 xe \u0111\xf3 tr\xean S\xe0n giao d\u1ecbch \u0111\u1ed3ng th\u1eddi y\xeau c\u1ea7u Ch\u1ee7 xe b\u1ed3i ho\xe0n cho Kh\xe1ch h\xe0ng th\u1ecfa \u0111\xe1ng tr\xean c\u01a1 s\u1edf th\u1ecfa thu\u1eadn v\u1edbi Kh\xe1ch h\xe0ng."})]}),Object(oe.jsxs)("div",{className:"main-place pointer ".concat(t[3]?"text-primary":""),onClick:()=>n(3),children:[Object(oe.jsx)("h6",{children:"IV. \u0110\u1ea3m b\u1ea3o an to\xe0n giao d\u1ecbch"}),Object(oe.jsx)("div",{className:"wrap-svg",children:t[3]?Object(oe.jsx)(ee.Hd,{}):Object(oe.jsx)(ee.Xd,{})})]}),t[3]&&Object(oe.jsxs)(oe.Fragment,{children:[Object(oe.jsx)("p",{children:"C\xf4ng ty \u0111\xe3 s\u1eed d\u1ee5ng c\xe1c d\u1ecbch v\u1ee5 \u0111\u1ec3 b\u1ea3o v\u1ec7 th\xf4ng tin v\u1ec1 n\u1ed9i dung m\xe0 Ch\u1ee7 xe \u0111\xe3 \u0111\u0103ng v\u1ec1 xe cho thu\xea nh\u1eb1m \u0111\u1ea3m b\u1ea3o c\xe1c giao d\u1ecbch \u0111\u01b0\u1ee3c ti\u1ebfn h\xe0nh th\xe0nh c\xf4ng, h\u1ea1n ch\u1ebf t\u1ed1i \u0111a r\u1ee7i ro c\xf3 th\u1ec3 ph\xe1t sinh."}),Object(oe.jsx)("p",{children:"Ch\u1ee7 xe ph\u1ea3i cung c\u1ea5p th\xf4ng tin \u0111\u1ea7y \u0111\u1ee7 (t\xean, \u0111\u1ecba ch\u1ec9, s\u1ed1 \u0111i\u1ec7n tho\u1ea1i, email) trong m\u1ed7i gian h\xe0ng xe cho thu\xea."}),Object(oe.jsx)("p",{children:"Kh\xe1ch h\xe0ng v\xe0 Ch\u1ee7 xe kh\xf4ng n\xean \u0111\u01b0a th\xf4ng tin chi ti\u1ebft v\u1ec1 vi\u1ec7c thanh to\xe1n v\u1edbi b\u1ea5t k\u1ef3 ai b\u1eb1ng email ho\u1eb7c h\xecnh th\u1ee9c li\xean l\u1ea1c kh\xe1c, C\xf4ng ty kh\xf4ng ch\u1ecbu tr\xe1ch nhi\u1ec7m v\u1ec1 nh\u1eefng thi\u1ec7t h\u1ea1i hay r\u1ee7i ro m\xe0 Th\xe0nh vi\xean (Kh\xe1ch h\xe0ng v\xe0 Ch\u1ee7 xe) c\xf3 th\u1ec3 g\xe1nh ch\u1ecbu trong vi\u1ec7c trao \u0111\u1ed5i th\xf4ng tin c\u1ee7a Th\xe0nh vi\xean qua Internet ho\u1eb7c email."}),Object(oe.jsx)("p",{children:"Trong tr\u01b0\u1eddng h\u1ee3p Kh\xe1ch h\xe0ng li\xean h\u1ec7 tr\u1ef1c ti\u1ebfp v\u1edbi Ch\u1ee7 xe v\xe0 kh\xf4ng s\u1eed d\u1ee5ng d\u1ecbch v\u1ee5 c\u1ee7a C\xf4ng ty th\xec Kh\xe1ch h\xe0ng ph\u1ea3i c\xe2n nh\u1eafc c\u1ea9n th\u1eadn vi\u1ec7c giao ti\u1ec1n tr\u01b0\u1edbc cho Ch\u1ee7 xe."}),Object(oe.jsx)("p",{children:"Th\xe0nh vi\xean tuy\u1ec7t \u0111\u1ed1i kh\xf4ng s\u1eed d\u1ee5ng b\u1ea5t k\u1ef3 ch\u01b0\u01a1ng tr\xecnh, c\xf4ng c\u1ee5 hay h\xecnh th\u1ee9c n\xe0o kh\xe1c \u0111\u1ec3 can thi\u1ec7p v\xe0o h\u1ec7 th\u1ed1ng hay l\xe0m thay \u0111\u1ed5i c\u1ea5u tr\xfac d\u1eef li\u1ec7u. Nghi\xeam c\u1ea5m vi\u1ec7c ph\xe1t t\xe1n, truy\u1ec1n b\xe1 hay c\u1ed5 v\u0169 cho b\u1ea5t k\u1ef3 ho\u1ea1t \u0111\u1ed9ng n\xe0o nh\u1eb1m can thi\u1ec7p, ph\xe1 ho\u1ea1i hay x\xe2m h\u1ea1i h\u1ec7 th\u1ed1ng c\u1ee7a C\xf4ng ty. M\u1ecdi vi ph\u1ea1m s\u1ebd b\u1ecb x\u1eed l\xfd theo Quy ch\u1ebf v\xe0 Quy \u0111\u1ecbnh c\u1ee7a Ph\xe1p lu\u1eadt."}),Object(oe.jsx)("p",{children:"M\u1ecdi th\xf4ng tin giao d\u1ecbch \u0111\u1ec1u \u0111\u01b0\u1ee3c b\u1ea3o m\u1eadt an to\xe0n, tr\u1eeb tr\u01b0\u1eddng h\u1ee3p bu\u1ed9c ph\u1ea3i cung c\u1ea5p khi C\u01a1 quan Ph\xe1p lu\u1eadt y\xeau c\u1ea7u."})]}),Object(oe.jsxs)("div",{className:"main-place pointer ".concat(t[4]?"text-primary":""),onClick:()=>n(4),children:[Object(oe.jsx)("h6",{children:"V. B\u1ea3o v\u1ec7 th\xf4ng tin c\xe1 nh\xe2n Kh\xe1ch h\xe0ng thu\xea xe"}),Object(oe.jsx)("div",{className:"wrap-svg",children:t[4]?Object(oe.jsx)(ee.Hd,{}):Object(oe.jsx)(ee.Xd,{})})]}),t[4]&&Object(oe.jsxs)(oe.Fragment,{children:[Object(oe.jsx)("p",{className:"subtitle",children:"1. M\u1ee5c \u0111\xedch s\u1eed d\u1ee5ng th\xf4ng tin"}),Object(oe.jsx)("p",{children:"Th\xf4ng tin c\xe1 nh\xe2n c\u1ee7a Kh\xe1ch h\xe0ng ch\u1ec9 \u0111\u01b0\u1ee3c d\xf9ng trong nh\u1eefng m\u1ee5c \u0111\xedch sau \u0111\xe2y"}),Object(oe.jsx)("p",{children:"H\u1ed7 tr\u1ee3 vi\u1ec7c \u0111\u1eb7t xe v\xe0 cung c\u1ea5p xe cho Kh\xe1ch h\xe0ng;"}),Object(oe.jsx)("p",{children:"Li\xean l\u1ea1c v\u1edbi Kh\xe1ch h\xe0ng trong cho m\u1ee5c \u0111\xedch ti\u1ebfp th\u1ecb c\u1ee7a C\xf4ng ty;"}),Object(oe.jsx)("p",{children:"N\xe2ng cao ch\u1ea5t