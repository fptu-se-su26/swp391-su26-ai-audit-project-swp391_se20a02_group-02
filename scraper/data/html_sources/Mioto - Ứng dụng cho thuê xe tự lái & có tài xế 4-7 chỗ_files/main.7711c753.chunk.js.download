t(t[7]?"text-primary":""),onClick:()=>n(7),children:[Object(oe.jsx)("h6",{children:"VIII. Quy\u1ec1n v\xe0 ngh\u0129a v\u1ee5 c\u1ee7a Ban qu\u1ea3n l\xfd S\xe0n giao d\u1ecbch TM\u0110T Mioto.vn"}),Object(oe.jsx)("div",{className:"wrap-svg",children:t[7]?Object(oe.jsx)(ee.Hd,{}):Object(oe.jsx)(ee.Xd,{})})]}),t[7]&&Object(oe.jsxs)(oe.Fragment,{children:[Object(oe.jsx)("p",{className:"subtitle",children:"1. Quy\u1ec1n c\u1ee7a Ban Qu\u1ea3n l\xed"}),Object(oe.jsx)("p",{children:"Ban Qu\u1ea3n l\xed s\u1ebd ti\u1ebfn h\xe0nh cung c\u1ea5p c\xe1c d\u1ecbch v\u1ee5 cho nh\u1eefng Th\xe0nh vi\xean tham gia sau khi \u0111\xe3 ho\xe0n th\xe0nh c\xe1c th\u1ee7 t\u1ee5c v\xe0 c\xe1c \u0111i\u1ec1u ki\u1ec7n b\u1eaft bu\u1ed9c m\xe0 S\xe0n giao d\u1ecbch n\xeau ra."}),Object(oe.jsx)("p",{children:"Trong tr\u01b0\u1eddng h\u1ee3p c\xf3 c\u01a1 s\u1edf \u0111\u1ec3 ch\u1ee9ng minh Th\xe0nh vi\xean cung c\u1ea5p th\xf4ng tin cho S\xe0n giao d\u1ecbch kh\xf4ng ch\xednh x\xe1c, sai l\u1ec7ch, kh\xf4ng \u0111\u1ea7y \u0111\u1ee7 ho\u1eb7c vi ph\u1ea1m ph\xe1p lu\u1eadt hay thu\u1ea7n phong m\u1ef9 t\u1ee5c Vi\u1ec7t Nam th\xec Ban Qu\u1ea3n l\xed c\xf3 quy\u1ec1n t\u1eeb ch\u1ed1i, t\u1ea1m ng\u1eebng ho\u1eb7c ch\u1ea5m d\u1ee9t quy\u1ec1n s\u1eed d\u1ee5ng d\u1ecbch v\u1ee5 c\u1ee7a Th\xe0nh vi\xean."}),Object(oe.jsx)("p",{children:"Ban Qu\u1ea3n l\xed c\xf3 th\u1ec3 ch\u1ea5m d\u1ee9t quy\u1ec1n th\xe0nh vi\xean v\xe0 quy\u1ec1n s\u1eed d\u1ee5ng m\u1ed9t ho\u1eb7c t\u1ea5t c\u1ea3 c\xe1c d\u1ecbch v\u1ee5 c\u1ee7a Th\xe0nh vi\xean v\xe0 s\u1ebd th\xf4ng b\xe1o cho Th\xe0nh vi\xean trong th\u1eddi h\u1ea1n \xedt nh\u1ea5t l\xe0 m\u1ed9t (01) th\xe1ng trong tr\u01b0\u1eddng h\u1ee3p Th\xe0nh vi\xean vi ph\u1ea1m c\xe1c Quy ch\u1ebf c\u1ee7a S\xe0n giao d\u1ecbch ho\u1eb7c c\xf3 nh\u1eefng h\xe0nh vi \u1ea3nh h\u01b0\u1edfng \u0111\u1ebfn ho\u1ea1t \u0111\u1ed9ng kinh doanh tr\xean S\xe0n giao d\u1ecbch."}),Object(oe.jsx)("p",{children:"Ban Qu\u1ea3n l\xed s\u1ebd xem x\xe9t vi\u1ec7c ch\u1ea5m d\u1ee9t quy\u1ec1n s\u1eed d\u1ee5ng d\u1ecbch v\u1ee5 v\xe0 quy\u1ec1n Th\xe0nh vi\xean c\u1ee7a Th\xe0nh vi\xean n\u1ebfu Th\xe0nh vi\xean kh\xf4ng tham gia ho\u1ea1t \u0111\u1ed9ng giao d\u1ecbch v\xe0 trao \u0111\u1ed5i th\xf4ng tin tr\xean S\xe0n giao d\u1ecbch li\xean t\u1ee5c trong ba (03) th\xe1ng. N\u1ebfu mu\u1ed1n ti\u1ebfp t\u1ee5c tr\u1edf Th\xe0nh th\xe0nh vi\xean v\xe0 \u0111\u01b0\u1ee3c c\u1ea5p l\u1ea1i quy\u1ec1n s\u1eed d\u1ee5ng d\u1ecbch v\u1ee5 th\xec Th\xe0nh vi\xean ph\u1ea3i \u0111\u0103ng k\xfd l\u1ea1i t\u1eeb \u0111\u1ea7u theo th\u1ee7 t\u1ee5c c\u1ee7a S\xe0n giao d\u1ecbch."}),Object(oe.jsx)("p",{children:"Ban Qu\u1ea3n l\xed c\xf3 th\u1ec3 ch\u1ea5m d\u1ee9t ngay quy\u1ec1n s\u1eed d\u1ee5ng d\u1ecbch v\u1ee5 v\xe0 quy\u1ec1n Th\xe0nh vi\xean c\u1ee7a Th\xe0nh vi\xean n\u1ebfu Ban Qu\u1ea3n l\xed ph\xe1t hi\u1ec7n Th\xe0nh vi\xean \u0111\xe3 ph\xe1 s\u1ea3n, b\u1ecb k\u1ebft \xe1n ho\u1eb7c \u0111ang trong th\u1eddi gian th\u1ee5 \xe1n, trong tr\u01b0\u1eddng h\u1ee3p Th\xe0nh vi\xean ti\u1ebfp t\u1ee5c ho\u1ea1t \u0111\u1ed9ng c\xf3 th\u1ec3 t\u1ea1o ra tr\xe1ch nhi\u1ec7m ph\xe1p l\xfd li\xean \u0111\u1edbi cho C\xf4ng ty, c\xf3 nh\u1eefng ho\u1ea1t \u0111\u1ed9ng l\u1eeba \u0111\u1ea3o, gi\u1ea3 m\u1ea1o, g\xe2y r\u1ed1i lo\u1ea1n th\u1ecb tr\u01b0\u1eddng, g\xe2y m\u1ea5t \u0111o\xe0n k\u1ebft \u0111\u1ed1i v\u1edbi c\xe1c Th\xe0nh vi\xean kh\xe1c c\u1ee7a S\xe0n giao d\u1ecbch, ho\u1ea1t \u0111\u1ed9ng vi ph\u1ea1m Ph\xe1p lu\u1eadt hi\u1ec7n h\xe0nh c\u1ee7a Vi\u1ec7t Nam. Trong tr\u01b0\u1eddng h\u1ee3p ch\u1ea5m d\u1ee9t quy\u1ec1n Th\xe0nh vi\xean v\xe0 quy\u1ec1n s\u1eed d\u1ee5ng d\u1ecbch v\u1ee5 th\xec t\u1ea5t c\u1ea3 c\xe1c ch\u1ee9ng nh\u1eadn, c\xe1c quy\u1ec1n c\u1ee7a Th\xe0nh vi\xean \u0111\u01b0\u1ee3c c\u1ea5p s\u1ebd m\u1eb7c nhi\xean h\u1ebft gi\xe1 tr\u1ecb v\xe0 b\u1ecb ch\u1ea5m d\u1ee9t."}),Object(oe.jsx)("p",{children:"Ban Qu\u1ea3n l\xed gi\u1eef b\u1ea3n quy\u1ec1n s\u1eed d\u1ee5ng d\u1ecbch v\u1ee5 v\xe0 c\xe1c n\u1ed9i dung tr\xean S\xe0n giao d\u1ecbch theo c\xe1c quy \u0111\u1ecbnh Ph\xe1p lu\u1eadt v\u1ec1 B\u1ea3o h\u1ed9 s\u1edf h\u1eefu tr\xed tu\u1ec7 t\u1ea1i Vi\u1ec7t Nam. T\u1ea5t c\u1ea3 c\xe1c bi\u1ec3u t\u01b0\u1ee3ng, n\u1ed9i dung theo c\xe1c ng\xf4n ng\u1eef kh\xe1c nhau \u0111\u1ec1u thu\u1ed9c quy\u1ec1n s\u1edf h\u1eefu c\u1ee7a C\xf4ng ty. Nghi\xeam c\u1ea5m m\u1ecdi h\xe0nh vi sao ch\xe9p, s\u1eed d\u1ee5ng v\xe0 ph\u1ed5 bi\u1ebfn b\u1ea5t h\u1ee3p ph\xe1p c\xe1c quy\u1ec1n s\u1edf h\u1eefu tr\xean."}),Object(oe.jsx)("p",{children:"Ban Qu\u1ea3n l\xed gi\u1eef quy\u1ec1n \u0111\u01b0\u1ee3c thay \u0111\u1ed5i bi\u1ec3u gi\xe1 d\u1ecbch v\u1ee5 v\xe0 ph\u01b0\u01a1ng th\u1ee9c thanh to\xe1n trong th\u1eddi gian cung c\u1ea5p d\u1ecbch v\u1ee5 cho Th\xe0nh vi\xean theo nhu c\u1ea7u v\xe0 \u0111i\u1ec1u ki\u1ec7n kh\u1ea3 n\u0103ng c\u1ee7a Ban Qu\u1ea3n l\xed v\xe0 s\u1ebd b\xe1o tr\u01b0\u1edbc cho Th\xe0nh vi\xean th\u1eddi h\u1ea1n l\xe0 m\u1ed9t (01) th\xe1ng."}),Object(oe.jsx)("p",{className:"subtitle",children:"2. Ngh\u0129a v\u1ee5 v\xe0 tr\xe1ch nhi\u1ec7m c\u1ee7a Ban qu\u1ea3n l\xfd"}),Object(oe.jsx)("p",{children:"Ban Qu\u1ea3n l\xed c\xf3 tr\xe1ch nhi\u1ec7m x\xe2y d\u1ef1ng, th\u1ef1c hi\u1ec7n c\u01a1 ch\u1ebf ki\u1ec3m tra, gi\xe1m s\xe1t \u0111\u1ec3 \u0111\u1ea3m b\u1ea3o vi\u1ec7c cung c\u1ea5p th\xf4ng tin c\u1ee7a Th\xe0nh vi\xean tr\xean S\xe0n giao d\u1ecbch \u0111\u01b0\u1ee3c th\u1ef1c hi\u1ec7n ch\xednh x\xe1c \u0111\u1ea7y \u0111\u1ee7 theo quy \u0111\u1ecbnh t\u1ea1i Kho\u1ea3n 4 \u0110i\u1ec1u 36 Ngh\u1ecb \u0111\u1ecbnh 52/2013/N\u0110-CP; Ban Qu\u1ea3n l\xed s\u1ebd n\u1ed7 l\u1ef1c t\u1ed1i \u0111a v\xe0 nghi\xeam t\xfac lo\u1ea1i b\u1ecf nh\u1eefng th\xf4ng tin kh\xf4ng trung th\u1ef1c ho\u1eb7c h\xe0ng h\xf3a gi\u1ea3 nh\u01b0 sau:"}),Object(oe.jsx)("p",{children:"Lo\u1ea1i b\u1ecf nh\u1eefng th\xf4ng tin b\xe1n h\xe0ng h\xf3a, d\u1ecbch v\u1ee5 thu\u1ed9c danh m\u1ee5c h\xe0ng h\xf3a, d\u1ecbch v\u1ee5 c\u1ea5m kinh doanh v\xe0 h\xe0ng h\xf3a h\u1ea1n ch\u1ebf kinh doanh theo quy \u0111\u1ecbnh c\u1ee7a ph\xe1p lu\u1eadt;"}),Object(oe.jsx)("p",{children:"Lo\u1ea1i b\u1ecf nh\u1eefng th\xf4ng tin b\xe1n h\xe0ng gi\u1ea3, h\xe0ng nh\xe1i, h\xe0ng nh\u1eadp l\u1eadu, h\xe0ng vi ph\u1ea1m quy\u1ec1n s\u1edf h\u1eefu tr\xed tu\u1ec7;"}),Object(oe.jsx)("p",{children:"Y\xeau c\u1ea7u c\xe1c Th\xe0nh vi\xean khi cung c\u1ea5p c\xe1c h\xe0ng h\xf3a, d\u1ecbch v\u1ee5 thu\u1ed9c danh m\u1ee5c h\xe0ng h\xf3a, d\u1ecbch v\u1ee5 kinh doanh c\xf3 \u0111i\u1ec1u ki\u1ec7n ph\u1ea3i cung c\u1ea5p gi\u1ea5y ch\u1ee9ng nh\u1eadn \u0111\u1ee7 \u0111i\u1ec1u ki\u1ec7n kinh doanh \u0111\u1ed1i v\u1edbi h\xe0ng h\xf3a, d\u1ecbch v\u1ee5 \u0111\xf3. Ban Qu\u1ea3n l\xed ch\u1ecbu tr\xe1ch nhi\u1ec7m x\xe2y d\u1ef1ng S\xe0n giao d\u1ecbch, bao g\u1ed3m m\u1ed9t s\u1ed1 c\xf4ng vi\u1ec7c ch\xednh nh\u01b0: nghi\xean c\u1ee9u, thi\u1ebft k\u1ebf, mua s\u1eafm c\xe1c thi\u1ebft b\u1ecb ph\u1ea7n c\u1ee9ng v\xe0 ph\u1ea7n m\u1ec1m, k\u1ebft n\u1ed1i Internet, x\xe2y d\u1ef1ng ch\xednh s\xe1ch ph\u1ee5c v\u1ee5 cho ho\u1ea1t \u0111\u1ed9ng c\u1ee7a S\xe0n giao d\u1ecbch trong \u0111i\u1ec1u ki\u1ec7n v\xe0 ph\u1ea1m vi cho ph\xe9p. Ban Qu\u1ea3n l\xed s\u1ebd ti\u1ebfn h\xe0nh tri\u1ec3n khai v\xe0 h\u1ee3p t\xe1c v\u1edbi c\xe1c \u0111\u1ed1i t\xe1c trong vi\u1ec7c x\xe2y d\u1ef1ng h\u1ec7 th\u1ed1ng c\xe1c d\u1ecbch v\u1ee5, c\xe1c c\xf4ng c\u1ee5 ti\u1ec7n \xedch ph\u1ee5c v\u1ee5 cho vi\u1ec7c giao d\u1ecbch c\u1ee7a c\xe1c Th\xe0nh vi\xean tham gia ho\u1ea1t \u0111\u1ed9ng tr\xean S\xe0n giao d\u1ecbch; Th\xf4ng b\xe1o \u0111\u1ebfn Th\xe0nh vi\xean c\xe1c \u0111i\u1ec1u kho\u1ea3n, \u0111i\u1ec1u ki\u1ec7n \xe1p d\u1ee5ng c\u1ee7a d\u1ecbch v\u1ee5 cung c\u1ea5p tr\xean S\xe0n giao d\u1ecbch v\xe0 c\xe1c quy\u1ec1n l\u1ee3i c\u1ee7a Th\xe0nh vi\xean khi tham gia ho\u1ea1t \u0111\u1ed9ng tr\xean S\xe0n giao d\u1ecbch;"}),Object(oe.jsx)("p",{children:"Ban Qu\u1ea3n l\xed c\xf3 tr\xe1ch nhi\u1ec7m \u0111\u1ee9ng ra l\xe0m trung gian trong vi\u1ec7c h\xf2a gi\u1ea3i n\u1ebfu x\u1ea3y ra tranh ch\u1ea5p gi\u1eefa Kh\xe1ch h\xe0ng v\xe0 Ch\u1ee7 xe. Ban Qu\u1ea3n l\xed s\u1ebd ti\u1ebfp nh\u1eadn th\xf4ng tin ph\u1ea3n \u1ea3nh, khi\u1ebfu n\u1ea1i t\u1eeb Kh\xe1ch h\xe0ng v\xe0 ki\u1ec3m tra n\u1ed9i dung ph\u1ea3n \xe1nh, khi\u1ebfu n\u1ea1i \u0111\xf3. N\u1ebfu x\xe9t th\u1ea5y nh\u1eefng ph\u1ea3n \xe1nh \u0111\xf3 l\xe0 \u0111\xfang, Ban Qu\u1ea3n l\xed s\u1ebd y\xeau c\u1ea7u Ch\u1ee7 xe ph\u1ea3i gi\u1ea3i tr\xecnh v\u1ec1 nh\u0169ng th\xf4ng tin \u0111\xf3. T\xf9y theo m\u1ee9c \u0111\u1ed9 sai ph\u1ea1m, Ban Qu\u1ea3n l\xed s\u1ebd c\xf3 ph\u01b0\u01a1ng \xe1n gi\u1ea3i quy\u1ebft y\xeau c\u1ea7u Ch\u1ee7 xe \u0111\u1ec1n b\xf9 cho Kh\xe1ch h\xe0ng, s\u1ebd kh\xf3a t\xe0i kho\xe0n Th\xe0nh vi\xean c\u1ee7a Ch\u1ee7 xe; Ban Qu\u1ea3n l\xed c\xf3 nhi\u1ec7m v\u1ee5 h\u1ed7 tr\u1ee3 C\u01a1 quan qu\u1ea3n l\xfd Nh\xe0 n\u01b0\u1edbc \u0111i\u1ec1u tra c\xe1c h\xe0nh vi kinh doanh vi ph\u1ea1m Ph\xe1p lu\u1eadt, cung c\u1ea5p th\xf4ng tin \u0111\u0103ng k\xfd, l\u1ecbch s\u1eed giao d\u1ecbch v\xe0 c\xe1c t\xe0i li\u1ec7u kh\xe1c v\u1ec1 \u0111\u1ed1i t\u01b0\u1ee3ng c\xf3 h\xe0nh vi vi ph\u1ea1m ph\xe1p lu\u1eadt tr\xean S\xe0n giao d\u1ecbch; Ban Qu\u1ea3n l\xed ch\u1ecbu tr\xe1ch nhi\u1ec7m x\xe2y d\u1ef1ng, b\u1ed5 sung h\u1ec7 th\u1ed1ng c\xe1c ki\u1ebfn th\u1ee9c, th\xf4ng tin v\u1ec1: nghi\u1ec7p v\u1ee5 ngo\u1ea1i th\u01b0\u01a1ng, th\u01b0\u01a1ng m\u1ea1i \u0111i\u1ec7n t\u1eed, h\u1ec7 th\u1ed1ng v\u0103n b\u1ea3n ph\xe1p lu\u1eadt th\u01b0\u01a1ng m\u1ea1i trong n\u01b0\u1edbc v\xe0 qu\u1ed1c t\u1ebf, th\u1ecb tr\u01b0\u1eddng n\u01b0\u1edbc ngo\xe0i, c\u0169ng nh\u01b0 c\xe1c tin t\u1ee9c c\xf3 li\xean quan \u0111\u1ebfn ho\u1ea1t \u0111\u1ed9ng c\u1ee7a S\xe0n giao d\u1ecbch; Ban Qu\u1ea3n l\xed s\u1ebd ti\u1ebfn h\xe0nh c\xe1c ho\u1ea1t \u0111\u1ed9ng x\xfac ti\u1ebfn, qu\u1ea3ng b\xe1 S\xe0n giao d\u1ecbch ra th\u1ecb tr\u01b0\u1eddng n\u01b0\u1edbc ngo\xe0i trong ph\u1ea1m vi v\xe0 \u0111i\u1ec1u ki\u1ec7n cho ph\xe9p, g\xf3p ph\u1ea7n m\u1edf r\u1ed9ng, k\u1ebft n\u1ed1i \u0111\xe1p \u1ee9ng c\xe1c nhu c\u1ea7u t\xecm ki\u1ebfm b\u1ea1n h\xe0ng v\xe0 ph\xe1t tri\u1ec3n th\u1ecb tr\u01b0\u1eddng n\u01b0\u1edbc ngo\xe0i c\u1ee7a c\xe1c Th\xe0nh vi\xean tham gia S\xe0n giao d\u1ecbch; Ban Qu\u1ea3n l\xed s\u1ebd c\u1ed1 g\u1eafng \u0111\u1ebfn m\u1ee9c cao nh\u1ea5t trong ph\u1ea1m vi v\xe0 \u0111i\u1ec1u ki\u1ec7n c\xf3 th\u1ec3 \u0111\u1ec3 duy tr\xec ho\u1ea1t \u0111\u1ed9ng b\xecnh th\u01b0\u1eddng c\u1ee7a S\xe0n giao d\u1ecbch v\xe0 kh\u1eafc ph\u1ee5c c\xe1c s\u1ef1 c\u1ed1 nh\u01b0: s\u1ef1 c\u1ed1 k\u1ef9 thu\u1eadt v\u1ec1 m\xe1y m\xf3c, l\u1ed7i ph\u1ea7n m\u1ec1m, h\u1ec7 th\u1ed1ng \u0111\u01b0\u1eddng truy\u1ec1n internet, nh\xe2n s\u1ef1, c\xe1c bi\u1ebfn \u0111\u1ed9ng x\xe3 h\u1ed9i, thi\xean tai, m\u1ea5t \u0111i\u1ec7n, c\xe1c quy\u1ebft \u0111\u1ecbnh c\u1ee7a C\u01a1 quan Nh\xe0 n\u01b0\u1edbc hay m\u1ed9t t\u1ed5 ch\u1ee9c li\xean quan th\u1ee9 ba. Tuy nhi\xean, n\u1ebfu nh\u1eefng s\u1ef1 c\u1ed1 tr\xean x\u1ea3y ra n\u1eb1m ngo\xe0i kh\u1ea3 n\u0103ng ki\u1ec3m so\xe1t, l\xe0 nh\u1eefng tr\u01b0\u1eddng h\u1ee3p b\u1ea5t kh\u1ea3 kh\xe1ng g\xe2y thi\u1ec7t h\u1ea1i cho Th\xe0nh vi\xean th\xec Ban Qu\u1ea3n l\xed kh\xf4ng ph\u1ea3i ch\u1ecbu tr\xe1ch nhi\u1ec7m li\xean \u0111\u1edbi."}),Object(oe.jsx)("p",{children:"L\u01b0u tr\u1eef th\xf4ng tin \u0111\u0103ng k\xfd c\u1ee7a c\xe1c th\u01b0\u01a1ng nh\xe2n, t\u1ed5 ch\u1ee9c, c\xe1 nh\xe2n tham gia s\xe0n giao d\u1ecbch th\u01b0\u01a1ng m\u1ea1i \u0111i\u1ec7n t\u1eed v\xe0 th\u01b0\u1eddng xuy\xean c\u1eadp nh\u1eadt nh\u1eefng th\xf4ng tin thay \u0111\u1ed5i, b\u1ed5 sung c\xf3 li\xean quan. \xc1p d\u1ee5ng c\xe1c bi\u1ec7n ph\xe1p c\u1ea7n thi\u1ebft \u0111\u1ec3 \u0111\u1ea3m b\u1ea3o an to\xe0n th\xf4ng tin li\xean quan \u0111\u1ebfn b\xed m\u1eadt kinh doanh c\u1ee7a th\u01b0\u01a1ng nh\xe2n, t\u1ed5 ch\u1ee9c, c\xe1 nh\xe2n v\xe0 th\xf4ng tin c\xe1 nh\xe2n c\u1ee7a Th\xe0nh vi\xean. C\xf3 bi\u1ec7n ph\xe1p x\u1eed l\xfd k\u1ecbp th\u1eddi khi ph\xe1t hi\u1ec7n ho\u1eb7c nh\u1eadn \u0111\u01b0\u1ee3c ph\u1ea3n \xe1nh v\u1ec1 h\xe0nh vi kinh doanh vi ph\u1ea1m ph\xe1p lu\u1eadt tr\xean s\xe0n giao d\u1ecbch th\u01b0\u01a1ng m\u1ea1i \u0111i\u1ec7n t\u1eed. H\u1ed7 tr\u1ee3 C\u01a1 quan Qu\u1ea3n l\xfd nh\xe0 n\u01b0\u1edbc \u0111i\u1ec1u tra c\xe1c h\xe0nh vi kinh doanh vi ph\u1ea1m ph\xe1p lu\u1eadt, cung c\u1ea5p th\xf4ng tin \u0111\u0103ng k\xfd, l\u1ecbch s\u1eed giao d\u1ecbch v\xe0 c\xe1c t\xe0i li\u1ec7u kh\xe1c v\u1ec1 \u0111\u1ed1i t\u01b0\u1ee3ng c\xf3 h\xe0nh vi vi ph\u1ea1m ph\xe1p lu\u1eadt tr\xean s\xe0n giao d\u1ecbch th\u01b0\u01a1ng m\u1ea1i \u0111i\u1ec7n t\u1eed."}),Object(oe.jsx)("p",{children:"C\xf4ng b\u1ed1 c\xf4ng khai c\u01a1 ch\u1ebf gi\u1ea3i quy\u1ebft c\xe1c tranh ch\u1ea5p ph\xe1t sinh trong qu\xe1 tr\xecnh giao d\u1ecbch tr\xean S\xe0n giao d\u1ecbch. Khi Th\xe0nh vi\xean tr\xean S\xe0n giao d\u1ecbch ph\xe1t sinh m\xe2u thu\u1eabn v\u1edbi nhau (gi\u1eefa Kh\xe1ch h\xe0ng v\xe0 Ch\u1ee7 xe ho\u1eb7c ng\u01b0\u1ee3c l\u1ea1i) ho\u1eb7c b\u1ecb t\u1ed5n h\u1ea1i l\u1ee3i \xedch h\u1ee3p ph\xe1p, s\u1ebd cung c\u1ea5p cho Th\xe0nh vi\xean th\xf4ng tin v\u1ec1 Kh\xe1ch h\xe0ng/Ch\u1ee7 xe, t\xedch c\u1ef1c h\u1ed7 tr\u1ee3 Th\xe0nh vi\xean b\u1ea3o v\u1ec7 quy\u1ec1n v\xe0 l\u1ee3i \xedch h\u1ee3p ph\xe1p c\u1ee7a m\xecnh."}),Object(oe.jsx)("p",{children:"Y\xeau c\u1ea7u th\u01b0\u01a1ng nh\xe2n, t\u1ed5 ch\u1ee9c, c\xe1 nh\xe2n tr\xean S\xe0n giao d\u1ecbch cung c\u1ea5p c\xe1c th\xf4ng tin theo quy \u0111\u1ecbnh:"}),Object(oe.jsx)("p",{children:"T\xean v\xe0 \u0111\u1ecba ch\u1ec9 tr\u1ee5 s\u1edf c\u1ee7a th\u01b0\u01a1ng nh\xe2n, t\u1ed5 ch\u1ee9c ho\u1eb7c t\xean v\xe0 \u0111\u1ecba ch\u1ec9 th\u01b0\u1eddng tr\xfa c\u1ee7a c\xe1 nh\xe2n; S\u1ed1, ng\xe0y c\u1ea5p v\xe0 n\u01a1i c\u1ea5p gi\u1ea5y ch\u1ee9ng nh\u1eadn \u0111\u0103ng k\xfd kinh doanh c\u1ee7a th\u01b0\u01a1ng nh\xe2n, ho\u1eb7c s\u1ed1, ng\xe0y c\u1ea5p v\xe0 \u0111\u01a1n v\u1ecb c\u1ea5p quy\u1ebft \u0111\u1ecbnh th\xe0nh l\u1eadp c\u1ee7a t\u1ed5 ch\u1ee9c, ho\u1eb7c m\xe3 s\u1ed1 thu\u1ebf c\xe1 nh\xe2n c\u1ee7a c\xe1 nh\xe2n; S\u1ed1 \u0111i\u1ec7n tho\u1ea1i ho\u1eb7c m\u1ed9t ph\u01b0\u01a1ng th\u1ee9c li\xean h\u1ec7 tr\u1ef1c tuy\u1ebfn kh\xe1c;"}),Object(oe.jsx)("p",{children:"Ng\u0103n ch\u1eb7n v\xe0 lo\u1ea1i b\u1ecf kh\u1ecfi website nh\u1eefng th\xf4ng tin b\xe1n h\xe0ng h\xf3a, d\u1ecbch v\u1ee5 thu\u1ed9c danh m\u1ee5c h\xe0ng h\xf3a, d\u1ecbch v\u1ee5 c\u1ea5m kinh doanh theo quy \u0111\u1ecbnh c\u1ee7a Ph\xe1p lu\u1eadt v\xe0 h\xe0ng h\xf3a h\u1ea1n ch\u1ebf kinh doanh nh\u01b0:"}),Object(oe.jsx)("p",{children:"S\xfang s\u0103n v\xe0 \u0111\u1ea1n s\xfang s\u0103n, v\u0169 kh\xed th\u1ec3 thao, c\xf4ng c\u1ee5 h\u1ed7 tr\u1ee3; Thu\u1ed1c l\xe1 \u0111i\u1ebfu, x\xec g\xe0 v\xe0 c\xe1c d\u1ea1ng thu\u1ed1c l\xe1 th\xe0nh ph\u1ea9m kh\xe1c; R\u01b0\u1ee3u c\xe1c lo\u1ea1i; Th\u1ef1c v\u1eadt, \u0111\u1ed9ng v\u1eadt hoang d\xe3 qu\xfd hi\u1ebfm, bao g\u1ed3m c\u1ea3 v\u1eadt s\u1ed1ng v\xe0 c\xe1c b\u1ed9 ph\u1eadn c\u1ee7a ch\xfang \u0111\xe3 \u0111\u01b0\u1ee3c ch\u1ebf bi\u1ebfn; C\xe1c h\xe0ng h\xf3a h\u1ea1n ch\u1ebf kinh doanh kh\xe1c theo quy \u0111\u1ecbnh c\u1ee7a ph\xe1p lu\u1eadt."}),Object(oe.jsx)("p",{children:"Lo\u1ea1i b\u1ecf kh\u1ecfi website nh\u1eefng th\xf4ng tin b\xe1n h\xe0ng gi\u1ea3, h\xe0ng nh\xe1i, h\xe0ng nh\u1eadp l\u1eadu, h\xe0ng vi ph\u1ea1m quy\u1ec1n s\u1edf h\u1eefu tr\xed tu\u1ec7 v\xe0 c\xe1c h\xe0ng h\xf3a, d\u1ecbch v\u1ee5 vi ph\u1ea1m ph\xe1p lu\u1eadt kh\xe1c khi ph\xe1t hi\u1ec7n ho\u1eb7c nh\u1eadn \u0111\u01b0\u1ee3c ph\u1ea3n \xe1nh c\xf3 c\u0103n c\u1ee9 x\xe1c th\u1ef1c v\u1ec1 nh\u1eefng th\xf4ng tin n\xe0y."})]}),Object(oe.jsxs)("div",{className:"main-place pointer ".concat(t[8]?"text-primary":""),onClick:()=>n(8),children:[Object(oe.jsx)("h6",{children:"IX. Quy\u1ec1n v\xe0 tr\xe1ch nhi\u1ec7m ch\u1ee7 xe (ng\u01b0\u1eddi b\xe1n) tham gia s\xe0n giao d\u1ecbch"}),Object(oe.jsx)("div",{className:"wrap-svg",children:t[8]?Object(oe.jsx)(ee.Hd,{}):Object(oe.jsx)(ee.Xd,{})})]}),t[8]&&Object(oe.jsxs)(oe.Fragment,{children:[Object(oe.jsx)("p",{className:"subtitle",children:"1. Quy\u1ec1n c\u1ee7a ch\u1ee7 xe (ng\u01b0\u1eddi b\xe1n) tham gia s\xe0n giao d\u1ecbch"}),Object(oe.jsx)("p",{children:"- Khi \u0111\u0103ng k\xfd tr\u1edf th\xe0nh Th\xe0nh vi\xean Ch\u1ee7 xe c\u1ee7a Mioto v\xe0 \u0111\u01b0\u1ee3c Ban Qu\u1ea3n l\xed \u0111\u1ed3ng \xfd, Ch\u1ee7 xe s\u1ebd \u0111\u01b0\u1ee3c mua b\xe1n d\u1ecbch v\u1ee5 t\u1ea1i S\xe0n giao d\u1ecbch."}),Object(oe.jsx)("p",{children:"- Ch\u1ee7 xe s\u1ebd \u0111\u01b0\u1ee3c c\u1ea5p t\xean \u0111\u0103ng k\xfd v\xe0 m\u1eadt kh\u1ea9u ri\xeang \u0111\u1ec3 s\u1eed d\u1ee5ng trong vi\u1ec7c qu\u1ea3n l\xfd nh\u1eefng giao d\u1ecbch t\u1ea1i S\xe0n giao d\u1ecbch v\xe0 \u0111\u0103ng b\xe1n d\u1ecbch v\u1ee5 c\u1ee7a m\xecnh tr\xean S\xe0n giao d\u1ecbch."}),Object(oe.jsx)("p",{children:"- Ch\u1ee7 xe s\u1ebd \u0111\u01b0\u1ee3c Ban Qu\u1ea3n l\xed h\u01b0\u1edbng d\u1eabn s\u1eed d\u1ee5ng \u0111\u01b0\u1ee3c c\xe1c c\xf4ng c\u1ee5, c\xe1c t\xednh n\u0103ng ph\u1ee5c v\u1ee5 cho vi\u1ec7c \u0111\u0103ng tin rao v\u1eb7t v\xe0 s\u1eed d\u1ee5ng c\xe1c d\u1ecbch v\u1ee5 ti\u1ec7n \xedch tr\xean S\xe0n giao d\u1ecbch."}),Object(oe.jsx)("p",{children:"- Ch\u1ee7 xe c\xf3 quy\u1ec1n \u0111\xf3ng g\xf3p \xfd ki\u1ebfn cho Ban Qu\u1ea3n l\xed trong qu\xe1 tr\xecnh ho\u1ea1t \u0111\u1ed9ng. C\xe1c ki\u1ebfn ngh\u1ecb \u0111\u01b0\u1ee3c g\u1eedi tr\u1ef1c ti\u1ebfp b\u1eb1ng th\u01b0, fax ho\u1eb7c email \u0111\u1ebfn cho Ban Qu\u1ea3n l\xed."}),Object(oe.jsx)("p",{className:"subtitle",children:"2. Ngh\u0129a v\u1ee5 c\u1ee7a ch\u1ee7 xe (ng\u01b0\u1eddi b\xe1n) tham gia s\xe0n giao d\u1ecbch"}),Object(oe.jsx)("p",{children:"- Ch\u1ee7 xe ph\u1ea3i cung c\u1ea5p \u0111\u1ea7y \u0111\u1ee7 v\xe0 ch\xednh x\xe1c c\xe1c th\xf4ng tin bao g\u1ed3m t\xean v\xe0 \u0111\u1ecba ch\u1ec9 tr\u1ee5 s\u1edf c\u1ee7a th\u01b0\u01a1ng nh\xe2n, t\u1ed5 ch\u1ee9c ho\u1eb7c t\xean v\xe0 \u0111\u1ecba ch\u1ec9 th\u01b0\u1eddng tr\xfa c\u1ee7a c\xe1 nh\xe2n; s\u1ed1, ng\xe0y c\u1ea5p v\xe0 n\u01a1i c\u1ea5p gi\u1ea5y ch\u1ee9ng nh\u1eadn \u0111\u0103ng k\xfd kinh doanh c\u1ee7a th\u01b0\u01a1ng nh\xe2n, ho\u1eb7c s\u1ed1, ng\xe0y c\u1ea5p v\xe0 \u0111\u01a1n v\u1ecb c\u1ea5p quy\u1ebft \u0111\u1ecbnh th\xe0nh l\u1eadp c\u1ee7a t\u1ed5 ch\u1ee9c, ho\u1eb7c m\xe3 s\u1ed1 thu\u1ebf c\xe1 nh\xe2n c\u1ee7a c\xe1 nh\xe2n; s\u1ed1 \u0111i\u1ec7n tho\u1ea1i ho\u1eb7c m\u1ed9t ph\u01b0\u01a1ng th\u1ee9c li\xean h\u1ec7 tr\u1ef1c tuy\u1ebfn kh\xe1c."}),Object(oe.jsx)("p",{children:"- Ch\u1ee7 xe s\u1ebd t\u1ef1 ch\u1ecbu tr\xe1ch nhi\u1ec7m v\u1ec1 vi\u1ec7c b\u1ea3o m\u1eadt v\xe0 l\u01b0u gi\u1eef m\u1ecdi ho\u1ea1t \u0111\u1ed9ng s\u1eed d\u1ee5ng d\u1ecbch v\u1ee5 d\u01b0\u1edbi t\xean \u0111\u0103ng k\xfd, m\u1eadt kh\u1ea9u v\xe0 h\u1ed9p th\u01b0 \u0111i\u1ec7n t\u1eed c\u1ee7a m\xecnh. Ch\u1ee7 xe c\xf3 tr\xe1ch nhi\u1ec7m th\xf4ng b\xe1o k\u1ecbp th\u1eddi cho Ban Qu\u1ea3n l\xed v\u1ec1 nh\u1eefng h\xe0nh vi s\u1eed d\u1ee5ng tr\xe1i ph\xe9p, l\u1ea1m d\u1ee5ng, vi ph\u1ea1m b\u1ea3o m\u1eadt, l\u01b0u gi\u1eef t\xean \u0111\u0103ng k\xfd v\xe0 m\u1eadt kh\u1ea9u c\u1ee7a m\xecnh \u0111\u1ec3 hai b\xean c\xf9ng h\u1ee3p t\xe1c x\u1eed l\xfd."}),Object(oe.jsx)("p",{children:"- Ch\u1ee7 xe t\u1ef1 ch\u1ecbu tr\xe1ch nhi\u1ec7m v\u1ec1 n\u1ed9i dung, h\xecnh \u1ea3nh c\u1ee7a doanh nghi\u1ec7p v\xe0 c\xe1c th\xf4ng tin kh\xe1c c\u0169ng nh\u01b0 b\u1ea3n quy\u1ec1n n\u1ed9i dung, h\xecnh \u1ea3nh, qu\xe1 tr\xecnh giao d\u1ecbch v\u1edbi c\xe1c \u0111\u1ed1i t\xe1c tr\xean S\xe0n giao d\u1ecbch v\xe0 ch\u1ecbu tr\xe1ch nhi\u1ec7m v\u1ec1 t\xednh ch\xednh x\xe1c, trung th\u1ef1c c\u1ee7a th\xf4ng tin v\u1ec1 s\u1ea3n ph\u1ea9m/d\u1ecbch v\u1ee5 \u0111\u01b0\u1ee3c trao \u0111\u1ed5i mua b\xe1n tr\xean S\xe0n giao d\u1ecbch."}),Object(oe.jsx)("p",{children:"- Ch\u1ee7 xe ph\u1ea3i cung c\u1ea5p th\xf4ng tin v\u1ec1 t\xecnh h\xecnh kinh doanh c\u1ee7a m\xecnh khi c\xf3 y\xeau c\u1ea7u c\u1ee7a C\u01a1 quan Nh\xe0 n\u01b0\u1edbc c\xf3 th\u1ea9m quy\u1ec1n \u0111\u1ec3 ph\u1ee5c v\u1ee5 ho\u1ea1t \u0111\u1ed9ng th\u1ed1ng k\xea th\u01b0\u01a1ng m\u1ea1i \u0111i\u1ec7n t\u1eed."}),Object(oe.jsx)("p",{children:"- Ch\u1ee7 xe ph\u1ea3i tu\xe2n th\u1ee7 quy \u0111\u1ecbnh c\u1ee7a Ph\xe1p lu\u1eadt v\u1ec1 thanh to\xe1n, qu\u1ea3ng c\xe1o, khuy\u1ebfn m\u1ea1i, b\u1ea3o v\u1ec7 quy\u1ec1n s\u1edf h\u1eefu tr\xed tu\u1ec7, v\xe0 c\xe1c quy \u0111\u1ecbnh c\u1ee7a Ph\xe1p lu\u1eadt c\xf3 li\xean quan kh\xe1c khi tham gia S\xe0n giao d\u1ecbch."}),Object(oe.jsx)("p",{children:"- Ch\u1ee7 xe c\xf3 tr\xe1ch nhi\u1ec7m cung c\u1ea5p th\xf4ng tin v\u1ec1 giao d\u1ecbch, h\u1ed7 tr\u1ee3 S\xe0n giao d\u1ecbch trong vi\u1ec7c gi\u1ea3i quy\u1ebft tranh ch\u1ea5p ph\xe1t sinh gi\u1eefa c\xe1c th\xe0nh vi\xean di\u1ec5n ra th\xf4ng qua S\xe0n giao d\u1ecbch."}),Object(oe.jsx)("p",{children:"- Ch\u1ee7 xe c\xf3 tr\xe1ch nhi\u1ec7m b\u1ed3i th\u01b0\u1eddng thi\u1ec7t h\u1ea1i cho c\xe1c th\xe0nh vi\xean kh\xe1c n\u1ebfu c\xf3 b\u1eb1ng ch\u1ee9ng ch\u1ee9ng minh \u0111\u01b0\u1ee3c l\u1ed7i \u0111\xf3 thu\u1ed9c v\u1ec1 Ch\u1ee7 xe \u0111\xe3 g\xe2y ra thi\u1ec7t h\u1ea1i."}),Object(oe.jsx)("p",{children:"- Ch\u1ee7 xe cam k\u1ebft, \u0111\u1ed3ng \xfd kh\xf4ng s\u1eed d\u1ee5ng d\u1ecbch v\u1ee5 c\u1ee7a S\xe0n giao d\u1ecbch v\xe0o nh\u1eefng m\u1ee5c \u0111\xedch b\u1ea5t h\u1ee3p ph\xe1p, kh\xf4ng h\u1ee3p l\xfd, l\u1eeba \u0111\u1ea3o, \u0111e do\u1ea1, th\u0103m r\xf2 th\xf4ng tin b\u1ea5t h\u1ee3p ph\xe1p, ph\xe1 ho\u1ea1i, t\u1ea1o ra v\xe0 ph\xe1t t\xe1n virus g\xe2y h\u01b0 h\u1ea1i t\u1edbi h\u1ec7 th\u1ed1ng, c\u1ea5u h\xecnh, truy\u1ec1n t\u1ea3i th\xf4ng tin c\u1ee7a S\xe0n giao d\u1ecbch hay s\u1eed d\u1ee5ng d\u1ecbch v\u1ee5 c\u1ee7a m\xecnh v\xe0o m\u1ee5c \u0111\xedch \u0111\u1ea7u c\u01a1, l\u0169ng \u0111o\u1ea1n th\u1ecb tr\u01b0\u1eddng t\u1ea1o nh\u1eefng \u0111\u01a1n \u0111\u1eb7t h\xe0ng, ch\xe0o h\xe0ng gi\u1ea3, k\u1ec3 c\u1ea3 ph\u1ee5c v\u1ee5 cho vi\u1ec7c ph\xe1n \u0111o\xe1n nhu c\u1ea7u th\u1ecb tr\u01b0\u1eddng. Trong tr\u01b0\u1eddng h\u1ee3p vi ph\u1ea1m th\xec Ch\u1ee7 xe ph\u1ea3i ch\u1ecbu tr\xe1ch nhi\u1ec7m v\u1ec1 c\xe1c h\xe0nh vi c\u1ee7a m\xecnh tr\u01b0\u1edbc Ph\xe1p lu\u1eadt."}),Object(oe.jsx)("p",{children:"- Ch\u1ee7 xe cam k\u1ebft kh\xf4ng \u0111\u01b0\u1ee3c thay \u0111\u1ed5i, ch\u1ec9nh s\u1eeda, sao ch\xe9p, truy\u1ec1n b\xe1, ph\xe2n ph\u1ed1i, cung c\u1ea5p v\xe0 t\u1ea1o nh\u1eefng c\xf4ng c\u1ee5 t\u01b0\u01a1ng t\u1ef1 c\u1ee7a d\u1ecbch v\u1ee5 do S\xe0n giao d\u1ecbch cung c\u1ea5p cho m\u1ed9t b\xean th\u1ee9 ba n\u1ebfu kh\xf4ng \u0111\u01b0\u1ee3c s\u1ef1 \u0111\u1ed3ng \xfd c\u1ee7a Ban Qu\u1ea3n l\xed."}),Object(oe.jsx)("p",{children:"- Ch\u1ee7 xe c\u1ea7n c\xf3 tr\xe1ch nhi\u1ec7m v\u1edbi vi\u1ec7c giao ti\u1ebfp ri\xeang v\xe0 ch\u1ecbu tr\xe1ch nhi\u1ec7m v\u1edbi k\u1ebft qu\u1ea3 c\u1ee7a vi\u1ec7c \u0111\u0103ng t\u1ea3i. Ch\u1ee7 xe kh\xf4ng \u0111\u01b0\u1ee3c ph\xe9p l\xe0m nh\u01b0ng \u0111i\u1ec1u nh\u01b0: \u0111\u0103ng t\u1ea3i nh\u1eefng n\u1ed9i dung \u0111\u01b0\u1ee3c \u0111\u0103ng k\xfd b\u1ea3n quy\u1ec1n n\u1ebfu Ch\u1ee7 xe kh\xf4ng ph\u1ea3i l\xe0 ng\u01b0\u1eddi ch\u1ee7 b\u1ea3n quy\u1ec1n ho\u1eb7c kh\xf4ng \u0111\u01b0\u1ee3c ng\u01b0\u1eddi ch\u1ee7 b\u1ea3n quy\u1ec1n cho ph\xe9p \u0111\u0103ng t\u1ea3i n\xf3; \u0111\u0103ng t\u1ea3i n\u1ed9i dung ti\u1ebft l\u1ed9 nh\u1eefng b\xed m\u1eadt th\u01b0\u01a1ng m\u1ea1i n\u1ebfu Ch\u1ee7 xe kh\xf4ng l\xe0m ch\u1ee7 ho\u1eb7c kh\xf4ng \u0111\u01b0\u1ee3c ph\xe9p c\u1ee7a ng\u01b0\u1eddi ch\u1ee7; \u0111\u0103ng t\u1ea3i nh\u1eefng n\u1ed9i dung vi ph\u1ea1m b\u1ea5t c\u1ee9 quy\u1ec1n s\u1edf h\u1eefu tr\xed tu\u1ec7 n\xe0o kh\xe1c c\u1ee7a ng\u01b0\u1eddi kh\xe1c ho\u1eb7c x\xe2m ph\u1ea1m b\u1ea3o m\u1eadt hay quy\u1ec1n c\xf4ng c\u1ed9ng c\u1ee7a ng\u01b0\u1eddi kh\xe1c; \u0111\u0103ng t\u1ea3i nh\u1eefng n\u1ed9i dung t\u1ee5c t\u0129u, l\xe0m m\u1ea5t danh d\u1ef1, \u0111e d\u1ecda, qu\u1ea5y r\u1ea7y, s\u1ec9 nh\u1ee5c, c\u0103m gh\xe9t hay g\xe2y c\u1ea3n tr\u1edf cho ng\u01b0\u1eddi s\u1eed d\u1ee5ng kh\xe1c hay b\u1ea5t c\u1ee9 ng\u01b0\u1eddi n\xe0o kh\xe1c hay t\u1ed5 ch\u1ee9c n\xe0o kh\xe1c; \u0111\u0103ng t\u1ea3i nh\u1eefng th\xf4ng tin kh\xf4ng c\xf3 ch\u1ee7 \u0111\u1ec1 hay c\xf3 ch\u1ee7 \u0111\u1ec1 \u0111\u1eb7c bi\u1ec7t; \u0111\u0103ng t\u1ea3i m\u1ed9t h\xecnh \u1ea3nh hay n\u1ed9i dung sex; \u0111\u0103ng t\u1ea3i nh\u1eefng m\u1eabu qu\u1ea3ng c\xe1o hay x\xfai gi\u1ee5c kinh doanh hay \u0111\u0103ng t\u1ea3i n\u1ed9i dung ch\u1ee9a virus, Trojan, bom th\u1eddi gian\u2026 hay nh\u1eefng quy tr\xecnh hay ch\u01b0\u01a1ng tr\xecnh m\xe1y t\xednh kh\xe1c v\u1edbi m\u1ee5c \u0111\xedch h\u1ee7y di\u1ec7t, g\xe2y c\u1ea3n tr\u1edf b\u1ea5t l\u1ee3i, ng\u0103n ch\u1eb7n l\u1eeba d\u1ed1i hay chi\u1ebfm \u0111o\u1ea1t b\u1ea5t c\u1ee9 h\u1ec7 th\u1ed1ng, d\u1eef li\u1ec7u hay th\xf4ng tin n\xe0o."}),Object(oe.jsx)("p",{children:"- Ch\u1ee7 xe kh\xf4ng \u0111\u01b0\u1ee3c h\xe0nh \u0111\u1ed9ng g\xe2y m\u1ea5t uy t\xedn c\u1ee7a S\xe0n giao d\u1ecbch d\u01b0\u1edbi m\u1ecdi h\xecnh th\u1ee9c nh\u01b0 g\xe2y m\u1ea5t \u0111o\xe0n k\u1ebft gi\u1eefa c\xe1c Ch\u1ee7 xe b\u1eb1ng c\xe1ch s\u1eed d\u1ee5ng t\xean \u0111\u0103ng k\xfd th\u1ee9 hai, th\xf4ng qua m\u1ed9t b\xean th\u1ee9 ba ho\u1eb7c tuy\xean truy\u1ec1n, ph\u1ed5 bi\u1ebfn nh\u1eefng th\xf4ng tin kh\xf4ng c\xf3 l\u1ee3i cho uy t\xedn c\u1ee7a S\xe0n giao d\u1ecbch."}),Object(oe.jsx)("p",{children:"- Ch\u1ee7 xe \u0111\u1ea3m b\u1ea3o t\xednh trung th\u1ef1c, ch\xednh x\xe1c c\xe1c th\xf4ng tin v\u1ec1 h\xe0ng h\xf3a/d\u1ecbch v\u1ee5 c\u1ee7a m\xecnh \u0111\u0103ng tr\xean S\xe0n Giao D\u1ecbch TM\u0110T Mioto.vn"}),Object(oe.jsx)("p",{children:"- Ch\u1ee7 xe c\u1eadp nh\u1eadt c\xe1c th\xf4ng tin thay \u0111\u1ed5i v\u1ec1 h\xe0ng h\xf3a/d\u1ecbch v\u1ee5 \u0111\xe3 \u0111\u0103ng t\u1ea3i tr\xean S\xe0n Giao D\u1ecbch TM\u0110T Mioto.vn"}),Object(oe.jsx)("p",{children:"- Ch\u1ee7 xe ch\u1ecbu tr\xe1ch nhi\u1ec7m v\u1ec1 ch\u1ea5t l\u01b0\u1ee3ng h\xe0ng h\xf3a, d\u1ecbch v\u1ee5 cung c\u1ea5p cho Kh\xe1ch h\xe0ng."}),Object(oe.jsx)("p",{children:"- Ch\u1ee7 xe ch\u1ecbu tr\xe1ch nhi\u1ec7m gi\u1ea3i quy\u1ebft khi\u1ebfu n\u1ea1i v\xe0 b\u1ed3i th\u01b0\u1eddng thi\u1ec7t h\u1ea1i cho Kh\xe1ch h\xe0ng (n\u1ebfu c\xf3)."}),Object(oe.jsx)("p",{children:"- Ch\u1ee7 xe thanh to\xe1n ph\xed d\u1ecbch v\u1ee5 qu\u1ea3ng c\xe1o v\xe0 \u0111\u0103ng tin cho S\xe0n Giao D\u1ecbch TM\u0110T Mioto.vn."}),Object(oe.jsx)("p",{children:"- Ch\u1ee7 xe th\xf4ng b\xe1o ho\u1eb7c \u0111\u0103ng k\xfd v\u1edbi c\u01a1 quan nh\xe0 n\u01b0\u1edbc c\xf3 th\u1ea9m quy\u1ec1n c\xe1c Ch\u01b0\u01a1ng tr\xecnh khuy\u1ebfn m\u1ea1i h\xe0ng h\xf3a/d\u1ecbch v\u1ee5 (n\u1ebfu c\xf3)."}),Object(oe.jsx)("p",{children:"- Ch\u1ee7 xe cung c\u1ea5p \u0111\u1ea7y \u0111\u1ee7 th\xf4ng tin v\u1ec1 ch\u1ee7 s\u1edf h\u1eefu gian h\xe0ng v\xe0 h\xe0ng h\xf3a, d\u1ecbch v\u1ee5 (n\u1ebfu c\xf3) theo quy \u0111\u1ecbnh t\u1eeb \u0110i\u1ec1u 29 \u0111\u1ebfn \u0110i\u1ec1u 34 Ngh\u1ecb \u0111\u1ecbnh 52/2013/N\u0110-CP v\u1ec1 Th\u01b0\u01a1ng m\u1ea1i \u0111i\u1ec7n t\u1eed khi b\xe1n h\xe0ng h\xf3a ho\u1eb7c cung \u1ee9ng d\u1ecbch v\u1ee5 tr\xean S\xe0n Giao D\u1ecbch TM\u0110T Mioto.vn"}),Object(oe.jsx)("p",{children:"- Ch\u1ee7 xe cung c\u1ea5p th\xf4ng tin v\u1ec1 t\xecnh h\xecnh kinh doanh c\u1ee7a m\xecnh khi c\xf3 y\xeau c\u1ea7u c\u1ee7a c\u01a1 quan nh\xe0 n\u01b0\u1edbc c\xf3 th\u1ea9m quy\u1ec1n \u0111\u1ec3 ph\u1ee5c v\u1ee5 ho\u1ea1t \u0111\u1ed9ng th\u1ed1ng k\xea th\u01b0\u01a1ng m\u1ea1i \u0111i\u1ec7n t\u1eed."}),Object(oe.jsx)("p",{children:"- Ch\u1ee7 xe tu\xe2n th\u1ee7 quy \u0111\u1ecbnh c\u1ee7a ph\xe1p lu\u1eadt v\u1ec1 thanh to\xe1n, qu\u1ea3ng c\xe1o, khuy\u1ebfn m\u1ea1i, b\u1ea3o v\u1ec7 quy\u1ec1n s\u1edf h\u1eefu tr\xed tu\u1ec7, b\u1ea3o v\u1ec7 quy\u1ec1n l\u1ee3i ng\u01b0\u1eddi ti\xeau d\xf9ng v\xe0 c\xe1c quy \u0111\u1ecbnh c\u1ee7a ph\xe1p lu\u1eadt c\xf3 li\xean quan kh\xe1c khi b\xe1n h\xe0ng h\xf3a ho\u1eb7c cung \u1ee9ng d\u1ecbch v\u1ee5 tr\xean s\xe0n giao d\u1ecbch th\u01b0\u01a1ng m\u1ea1i \u0111i\u1ec7n t\u1eed."}),Object(oe.jsx)("p",{children:"- Ch\u1ee7 xe ho\xe0n to\xe0n ch\u1ecbu tr\xe1ch nhi\u1ec7m tr\u01b0\u1edbc ph\xe1p lu\u1eadt trong tr\u01b0\u1eddng h\u1ee3p h\xe0ng h\xf3a, d\u1ecbch v\u1ee5 do ng\u01b0\u1eddi b\xe1n h\xe0ng \u0111\u0103ng t\u1ea3i tr\xean S\xe0n Giao D\u1ecbch TM\u0110T Mioto.vn thu\u1ed9c danh m\u1ee5c h\xe0ng h\xf3a c\u1ea5m qu\u1ea3ng c\xe1o, c\u1ea5m kinh doanh ho\u1eb7c/v\xe0 vi ph\u1ea1m c\xe1c quy \u0111\u1ecbnh kh\xe1c c\u1ee7a ph\xe1p lu\u1eadt."}),Object(oe.jsx)("p",{children:"- Ch\u1ee7 xe ho\xe0n to\xe0n ch\u1ecbu tr\xe1ch nhi\u1ec7m tr\u01b0\u1edbc Kh\xe1ch h\xe0ng trong tr\u01b0\u1eddng h\u1ee3p h\xe0ng h\xf3a, d\u1ecbch v\u1ee5 kh\xf4ng \u0111\u1ea1t ch\u1ea5t l\u01b0\u1ee3ng nh\u01b0 th\xf4ng tin ng\u01b0\u1eddi b\xe1n \u0111\xe3 \u0111\u0103ng t\u1ea3i tr\xean S\xe0n Giao D\u1ecbch Mioto.vn."})]}),Object(oe.jsxs)("div",{className:"main-place pointer ".concat(t[9]?"text-primary":""),onClick:()=>n(9),children:[Object(oe.jsx)("h6",{children:"X. Quy\u1ec1n v\xe0 tr\xe1ch nhi\u1ec7m kh\xe1ch h\xe0ng (ng\u01b0\u1eddi mua) tham gia s\xe0n giao d\u1ecbch"}),Object(oe.jsx)("div",{className:"wrap-svg",children:t[9]?Object(oe.jsx)(ee.Hd,{}):Object(oe.jsx)(ee.Xd,{})})]}),t[9]&&Object(oe.jsxs)(oe.Fragment,{children:[Object(oe.jsx)("p",{className:"subtitle",children:"1. Quy\u1ec1n c\u1ee7a Kh\xe1ch h\xe0ng (ng\u01b0\u1eddi mua) tham gia s\xe0n giao d\u1ecbch"}),Object(oe.jsx)("p",{children:"- Khi \u0111\u0103ng k\xfd tr\u1edf th\xe0nh Th\xe0nh vi\xean c\u1ee7a Mioto v\xe0 \u0111\u01b0\u1ee3c Ban Qu\u1ea3n l\xed \u0111\u1ed3ng \xfd, Kh\xe1ch h\xe0ng s\u1ebd \u0111\u01b0\u1ee3c mua b\xe1n d\u1ecbch v\u1ee5 t\u1ea1i S\xe0n giao d\u1ecbch."}),Object(oe.jsx)("p",{children:"- Kh\xe1ch h\xe0ng s\u1ebd \u0111\u01b0\u1ee3c c\u1ea5p t\xean \u0111\u0103ng k\xfd v\xe0 m\u1eadt kh\u1ea9u ri\xeang \u0111\u1ec3 s\u1eed d\u1ee5ng trong vi\u1ec7c qu\u1ea3n l\xfd nh\u1eefng giao d\u1ecbch t\u1ea1i S\xe0n giao d\u1ecbch."}),Object(oe.jsx)("p",{children:"- Kh\xe1ch h\xe0ng s\u1ebd \u0111\u01b0\u1ee3c Ban Qu\u1ea3n l\xed h\u01b0\u1edbng d\u1eabn s\u1eed d\u1ee5ng \u0111\u01b0\u1ee3c c\xe1c c\xf4ng c\u1ee5, c\xe1c t\xednh n\u0103ng ph\u1ee5c v\u1ee5 cho vi\u1ec7c s\u1eed d\u1ee5ng c\xe1c d\u1ecbch v\u1ee5 ti\u1ec7n \xedch tr\xean S\xe0n giao d\u1ecbch."}),Object(oe.jsx)("p",{children:"- Kh\xe1ch h\xe0ng c\xf3 quy\u1ec1n \u0111\xf3ng g\xf3p \xfd ki\u1ebfn cho Ban Qu\u1ea3n l\xed trong qu\xe1 tr\xecnh ho\u1ea1t \u0111\u1ed9ng. C\xe1c ki\u1ebfn ngh\u1ecb \u0111\u01b0\u1ee3c g\u1eedi tr\u1ef1c ti\u1ebfp b\u1eb1ng th\u01b0, fax ho\u1eb7c email \u0111\u1ebfn cho Ban Qu\u1ea3n l\xed."}),Object(oe.jsx)("p",{className:"subtitle",children:"2. Ngh\u0129a v\u1ee5 c\u1ee7a kh\xe1ch h\xe0ng (ng\u01b0\u1eddi mua) tham gia s\xe0n giao d\u1ecbch"}),Object(oe.jsx)("p",{children:"- Kh\xe1ch h\xe0ng c\xf3 tr\xe1ch nhi\u1ec7m cung c\u1ea5p c\xe1c th\xf4ng tin c\u1ea7n thi\u1ebft li\xean quan \u0111\u1ebfn b\u1ea3n th\xe2n \u0111\u1ec3 \u0111\u1ea3m b\u1ea3o ho\xe0n th\xe0nh \u0111\u01a1n h\xe0ng bao g\u1ed3m: t\xean giao d\u1ecbch, \u0111\u1ecba ch\u1ec9, ph\u01b0\u01a1ng th\u1ee9c thanh to\xe1n l\u1ef1a ch\u1ecdn, \u0111i\u1ec7n tho\u1ea1i li\xean h\u1ec7."}),Object(oe.jsx)("p",{children:"- Kh\xe1ch h\xe0ng s\u1ebd t\u1ef1 ch\u1ecbu tr\xe1ch nhi\u1ec7m v\u1ec1 vi\u1ec7c b\u1ea3o m\u1eadt v\xe0 l\u01b0u gi\u1eef m\u1ecdi ho\u1ea1t \u0111\u1ed9ng s\u1eed d\u1ee5ng d\u1ecbch v\u1ee5 d\u01b0\u1edbi t\xean \u0111\u0103ng k\xfd, m\u1eadt kh\u1ea9u v\xe0 h\u1ed9p th\u01b0 \u0111i\u1ec7n t\u1eed c\u1ee7a m\xecnh. Kh\xe1ch h\xe0ng c\xf3 tr\xe1ch nhi\u1ec7m th\xf4ng b\xe1o k\u1ecbp th\u1eddi cho Ban Qu\u1ea3n l\xed v\u1ec1 nh\u1eefng h\xe0nh vi s\u1eed d\u1ee5ng tr\xe1i ph\xe9p, l\u1ea1m d\u1ee5ng, vi ph\u1ea1m b\u1ea3o m\u1eadt, l\u01b0u gi\u1eef t\xean \u0111\u0103ng k\xfd v\xe0 m\u1eadt kh\u1ea9u c\u1ee7a m\xecnh \u0111\u1ec3 hai b\xean c\xf9ng h\u1ee3p t\xe1c x\u1eed l\xfd."}),Object(oe.jsx)("p",{children:"- Kh\xe1ch h\xe0ng t\u1ef1 ch\u1ecbu tr\xe1ch nhi\u1ec7m v\u1ec1 n\u1ed9i dung, h\xecnh \u1ea3nh c\u1ee7a Doanh nghi\u1ec7p v\xe0 c\xe1c th\xf4ng tin kh\xe1c c\u0169ng nh\u01b0 b\u1ea3n quy\u1ec1n n\u1ed9i dung, h\xecnh \u1ea3nh, qu\xe1 tr\xecnh giao d\u1ecbch v\u1edbi c\xe1c \u0111\u1ed1i t\xe1c tr\xean S\xe0n giao d\u1ecbch."}),Object(oe.jsx)("p",{children:"- Kh\xe1ch h\xe0ng c\xf3 tr\xe1ch nhi\u1ec7m cung c\u1ea5p th\xf4ng tin v\u1ec1 giao d\u1ecbch, h\u1ed7 tr\u1ee3 S\xe0n giao d\u1ecbch trong vi\u1ec7c gi\u1ea3i quy\u1ebft tranh ch\u1ea5p ph\xe1t sinh gi\u1eefa c\xe1c th\xe0nh vi\xean di\u1ec5n ra th\xf4ng qua S\xe0n giao d\u1ecbch."}),Object(oe.jsx)("p",{children:"- Kh\xe1ch h\xe0ng c\xf3 tr\xe1ch nhi\u1ec7m b\u1ed3i th\u01b0\u1eddng thi\u1ec7t h\u1ea1i cho Th\xe0nh vi\xean kh\xe1c n\u1ebfu c\xf3 b\u1eb1ng ch\u1ee9ng ch\u1ee9ng minh \u0111\u01b0\u1ee3c l\u1ed7i \u0111\xf3 thu\u1ed9c v\u1ec1 Kh\xe1ch h\xe0ng \u0111\xe3 g\xe2y ra thi\u1ec7t h\u1ea1i."}),Object(oe.jsx)("p",{children:"- Kh\xe1ch h\xe0ng cam k\u1ebft kh\xf4ng \u0111\u01b0\u1ee3c thay \u0111\u1ed5i, ch\u1ec9nh s\u1eeda, sao ch\xe9p, truy\u1ec1n b\xe1, ph\xe2n ph\u1ed1i, cung c\u1ea5p v\xe0 t\u1ea1o nh\u1eefng c\xf4ng c\u1ee5 t\u01b0\u01a1ng t\u1ef1 c\u1ee7a d\u1ecbch v\u1ee5 do S\xe0n giao d\u1ecbch cung c\u1ea5p cho m\u1ed9t b\xean th\u1ee9 ba n\u1ebfu kh\xf4ng \u0111\u01b0\u1ee3c s\u1ef1 \u0111\u1ed3ng \xfd c\u1ee7a Ban Qu\u1ea3n l\xed."}),Object(oe.jsx)("p",{children:"- Kh\xe1ch h\xe0ng kh\xf4ng \u0111\u01b0\u1ee3c h\xe0nh \u0111\u1ed9ng g\xe2y m\u1ea5t uy t\xedn c\u1ee7a S\xe0n giao d\u1ecbch d\u01b0\u1edbi m\u1ecdi h\xecnh th\u1ee9c nh\u01b0 g\xe2y m\u1ea5t \u0111o\xe0n k\u1ebft gi\u1eefa c\xe1c Th\xe0nh vi\xean b\u1eb1ng c\xe1ch s\u1eed d\u1ee5ng t\xean \u0111\u0103ng k\xfd th\u1ee9 hai, th\xf4ng qua m\u1ed9t b\xean th\u1ee9 ba ho\u1eb7c tuy\xean truy\u1ec1n, ph\u1ed5 bi\u1ebfn nh\u1eefng th\xf4ng tin kh\xf4ng c\xf3 l\u1ee3i cho uy t\xedn c\u1ee7a S\xe0n giao d\u1ecbch."}),Object(oe.jsx)("p",{children:"- Kh\xe1ch h\xe0ng ch\u1ecbu tr\xe1ch nhi\u1ec7m b\u1ea3o m\u1eadt t\xean \u0111\u0103ng k\xfd, m\u1eadt kh\u1ea9u v\xe0 h\u1ed9p th\u01b0 \u0111i\u1ec7n t\u1eed d\xf9ng \u0111\u1ec3 \u0111\u0103ng k\xfd tr\xean S\xe0n Giao D\u1ecbch TM\u0110T Mioto.vn"}),Object(oe.jsx)("p",{children:"- Kh\xe1ch h\xe0ng cam k\u1ebft nh\u1eefng th\xf4ng tin cung c\u1ea5p cho S\xe0n Giao D\u1ecbch TM\u0110T Mioto.vn l\xe0 \u0111\u1ea7y \u0111\u1ee7 v\xe0 ch\xednh x\xe1c. N\u1ebfu th\xe0nh vi\xean ph\xe1t hi\u1ec7n b\u1ea5t c\u1ee9 b\xean th\u1ee9 ba n\xe0o c\xf3 h\xe0nh vi s\u1eed d\u1ee5ng tr\xe1i ph\xe9p, l\u1ea1m d\u1ee5ng t\xean \u0111\u0103ng k\xfd v\xe0 m\u1eadt kh\u1ea9u c\u1ee7a m\xecnh tr\xean S\xe0n Giao D\u1ecbch TM\u0110T Mioto.vn th\xec Kh\xe1ch h\xe0ng c\xf3 tr\xe1ch nhi\u1ec7m th\xf4ng b\xe1o k\u1ecbp th\u1eddi cho S\xe0n Giao D\u1ecbch TM\u0110T Mioto.vn \u0111\u1ec3 c\xf3 bi\u1ec7n ph\xe1p gi\u1ea3i quy\u1ebft ph\xf9 h\u1ee3p."}),Object(oe.jsx)("p",{children:"- Kh\xe1ch h\xe0ng kh\xf4ng \u0111\u01b0\u1ee3c s\u1eed d\u1ee5ng d\u1ecbch v\u1ee5 c\u1ee7a S\xe0n Giao D\u1ecbch TM\u0110T Mioto.vn v\xe0o m\u1ee5c \u0111\xedch l\u1eeba \u0111\u1ea3o, de d\u1ecda, th\u0103m d\xf2 th\xf4ng tin b\u1ea5t h\u1ee3p ph\xe1p, ph\xe1 ho\u1ea1i, t\u1ea1o ra v\xe0 ph\xe1t t\xe1n virut g\xe2y h\u01b0 h\u1ea1i t\u1edbi h\u1ec7 th\u1ed1ng m\xe1y ch\u1ee7, website S\xe0n Giao D\u1ecbch TM\u0110T Mioto.vn. Th\xe0nh vi\xean n\xe0o vi ph\u1ea1m s\u1ebd ph\u1ea3i ch\u1ecbu ho\xe0n to\xe0n tr\xe1ch nhi\u1ec7m tr\u01b0\u1edbc ph\xe1p lu\u1eadt."})]}),Object(oe.jsxs)("div",{className:"main-place pointer ".concat(t[10]?"text-pri