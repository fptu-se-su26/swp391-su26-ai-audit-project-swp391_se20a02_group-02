,{className:"subtitle",children:"8. C\u01a1 ch\u1ebf ti\u1ebfp nh\u1eadn v\xe0 gi\u1ea3i quy\u1ebft khi\u1ebfu n\u1ea1i li\xean quan \u0111\u1ebfn vi\u1ec7c th\xf4ng tin c\xe1 nh\xe2n kh\xe1ch h\xe0ng"}),Object(oe.jsx)("p",{children:"Ng\u01b0\u1eddi d\xf9ng c\xf3 quy\u1ec1n g\u1eedi khi\u1ebfu n\u1ea1i li\xean quan \u0111\u1ebfn vi\u1ec7c th\u1ef1c hi\u1ec7n ch\xednh s\xe1ch b\u1ea3o m\u1eadt th\xf4ng tin \u0111\u1ebfn Ban qu\u1ea3n l\xed S\xe0n giao d\u1ecbch TM\u0110T Mioto. Khi ti\u1ebfp nh\u1eadn nh\u1eefng ph\u1ea3n h\u1ed3i n\xe0y, S\xe0n giao d\u1ecbch TM\u0110T Mioto s\u1ebd x\xe1c nh\u1eadn l\u1ea1i th\xf4ng tin, v\xe0 c\xf3 tr\xe1ch nhi\u1ec7m ph\u1ea3n h\u1ed3i l\xfd do v\xe0 h\u01b0\u1edbng d\u1eabn th\xe0nh vi\xean kh\xf4i ph\u1ee5c v\xe0 b\u1ea3o m\u1eadt l\u1ea1i th\xf4ng tin. C\xe1c b\u01b0\u1edbc th\u1ef1c hi\u1ec7n nh\u01b0 sau:"}),Object(oe.jsx)("p",{children:"B\u01b0\u1edbc 1: Ti\u1ebfp nh\u1eadn khi\u1ebfu n\u1ea1i"}),Object(oe.jsx)("p",{children:"Kh\xe1ch h\xe0ng g\u1eedi khi\u1ebfu n\u1ea1i cho S\xe0n giao d\u1ecbch TM\u0110T Mioto theo c\xe1c k\xeanh nh\u01b0 email, \u0111i\u1ec7n tho\u1ea1i ho\u1eb7c g\u1eedi v\u0103n b\u1ea3n tr\u1ef1c ti\u1ebfp \u0111\u1ebfn \u0111\u1ecba ch\u1ec9 c\u1ee7a S\xe0n giao d\u1ecbch. B\u1ed9 ph\u1eadn CSKH c\u1ee7a S\xe0n giao d\u1ecbch c\xf3 tr\xe1ch nhi\u1ec7m ti\u1ebfp nh\u1eadn v\xe0 y\xeau c\u1ea7u kh\xe1ch h\xe0ng n\xeau r\xf5 n\u1ed9i dung khi\u1ebfu n\u1ea1i v\xe0 cung c\u1ea5p c\xe1c th\xf4ng tin, t\xe0i li\u1ec7u c\xf3 li\xean quan."}),Object(oe.jsx)("p",{children:"B\u01b0\u1edbc 2: X\xe1c minh n\u1ed9i dung khi\u1ebfu n\u1ea1i"}),Object(oe.jsx)("p",{children:"Sau khi ti\u1ebfp nh\u1eadn, B\u1ed9 ph\u1eadn CSKH s\u1ebd c\u0103n c\u1ee9 tr\xean n\u1ed9i dung khi\u1ebfu n\u1ea1i, th\u1ef1c hi\u1ec7n ph\xe2n lo\u1ea1i v\xe0 chuy\u1ec3n n\u1ed9i dung khi\u1ebfu n\u1ea1i \u0111\u1ebfn B\u1ed9 ph\u1eadn ph\u1ee5 tr\xe1ch \u0111\u1ec3 x\u1eed l\xfd."}),Object(oe.jsx)("p",{children:"B\u01b0\u1edbc 3: T\u1ed5n